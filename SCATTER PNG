            <button id="close-guide-btn" class="w-full py-3 bg-gradient-to-r from-indigo-600 to-blue-600 hover:from-indigo-500 hover:to-blue-500 text-white rounded-2xl font-bold tracking-wide transition-all shadow-lg shadow-indigo-600/20">
                Enter Studio Workspace
            </button>
        </div>
    </div>

    <!-- Interactive JS Scripts -->
    <script>
        // Shader Definition Strings for absolute hardware performance using GPU memory
        const particleVertexShader = `
            attribute vec3 targetPos;
            attribute vec3 velocity;
            attribute float delay;
            
            uniform float progress; 
            uniform float noiseIntensity;
            uniform float scatterRadius;
            uniform float size;
            uniform float swirlForce;
            uniform float gravityForce;
            uniform float time;
            uniform float effectType; // 0: Vortex, 1: Disperse, 2: Gravity, 3: Swarm

            varying vec3 vColor;
            
            // Simplex-like pseudo noise generator
            float rand(vec2 co){
                return fract(sin(dot(co.xy ,vec2(12.9898,78.233))) * 43758.5453);
            }

            void main() {
                vColor = color;
                
                // Base target position
                vec3 target = targetPos;
                
                // Calculated scattered position
                vec3 scattered;
                
                // Scaled progress with simple time offsetting per particle to yield stardust flow feel
                float localProgress = clamp((progress - delay) / (1.0 - delay), 0.0, 1.0);
                
                if (effectType < 0.5) {
                    // Vortex spiral scatter state
                    float angle = scatterRadius * (1.0 - localProgress) * swirlForce;
                    float radius = length(target.xy) * (1.0 + scatterRadius * (1.0 - localProgress));
                    scattered.x = cos(angle + target.x) * radius;
                    scattered.y = sin(angle + target.y) * radius;
                    scattered.z = sin(time * 0.5 + target.x) * noiseIntensity * (1.0 - localProgress);
                } 
                else if (effectType < 1.5) {
                    // Linear Scatter
                    vec3 offsetDir = vec3(
                        rand(target.xy) - 0.5,
                        rand(target.zx) - 0.5,
                        rand(target.yz) - 0.5
                    ) * scatterRadius;
                    scattered = target + offsetDir * (1.0 - localProgress);
                } 
                else if (effectType < 2.5) {
                    // Heavy Gravity pull from bottom sphere
                    float fall = (1.0 - localProgress) * scatterRadius;
                    scattered = target;
                    scattered.y -= fall * gravityForce;
                    scattered.x += sin(target.y * 2.0) * noiseIntensity * 0.1 * (1.0 - localProgress);
                } 
                else {
                    // Cosmic Aurora Swarm noise scatter
                    float noiseX = sin(target.y * 3.0 + time) * noiseIntensity * 0.3;
                    float noiseY = cos(target.x * 3.0 + time) * noiseIntensity * 0.3;
                    float noiseZ = sin(target.z * 3.0 + time * 1.5) * noiseIntensity * 0.5;
                    scattered = target + vec3(noiseX, noiseY, noiseZ) * (1.0 - localProgress) * scatterRadius * 0.5;
                }

                // Smooth linear interpolation back into reconstructed image plane
                vec3 finalPos = mix(scattered, target, localProgress);

                // Transform to Camera projection matrix space
                vec4 mvPosition = modelViewMatrix * vec4(finalPos, 1.0);
                gl_Position = projectionMatrix * mvPosition;
                
                // Depth-attenuated particle sizes
                gl_PointSize = size * (300.0 / -mvPosition.z);
            }
        `;

        const particleFragmentShader = `
            varying vec3 vColor;
            uniform float renderType; // 0: Dot, 1: Quad

            void main() {
                // If rendering glowing rounded points, transform standard coordinates
                if (renderType < 0.5) {
                    vec2 coord = gl_PointCoord - vec2(0.5);
                    if (length(coord) > 0.5) {
                        discard;
                    }
                    // Create glowing halo falloff
                    float intensity = 1.0 - (length(coord) * 2.0);
                    gl_FragColor = vec4(vColor, intensity);
                } else {
                    // Square particle quad
                    gl_FragColor = vec4(vColor, 1.0);
                }
            }
        `;

        // Interactive GUI elements
        const offscreenCanvas = document.getElementById('offscreen-processing');
        const offscreenCtx = offscreenCanvas.getContext('2d');
        const canvasContainer = document.getElementById('canvas3d-container');
        const fileInput = document.getElementById('image-upload');
        
        const densitySlider = document.getElementById('density-slider');
        const densityVal = document.getElementById('density-val');
        const scatterSlider = document.getElementById('scatter-slider');
        const scatterVal = document.getElementById('scatter-val');
        const sizeSlider = document.getElementById('size-slider');
        const sizeVal = document.getElementById('size-val');
        const noiseSlider = document.getElementById('noise-slider');
        const noiseVal = document.getElementById('noise-val');
        const progressSlider = document.getElementById('progress-slider');
        const manualProgressVal = document.getElementById('manual-progress-val');
        const convergencePercentage = document.getElementById('convergence-percentage');
        
        const typeVortex = document.getElementById('type-vortex');
        const typeDisperse = document.getElementById('type-disperse');
        const typeGravity = document.getElementById('type-gravity');
        const typeAurora = document.getElementById('type-aurora');

        const btnPlay = document.getElementById('btn-play');
        const btnDisperse = document.getElementById('btn-disperse');
        const resetDialsBtn = document.getElementById('reset-dials-btn');
        const showGuideBtn = document.getElementById('show-guide-btn');
        const closeGuideBtn = document.getElementById('close-guide-btn');
        const guideModal = document.getElementById('guide-modal');

        const renderDots = document.getElementById('render-dots');
        const renderQuads = document.getElementById('render-quads');
        const fpsCounter = document.getElementById('fps-counter');

        // Dynamic State variables
        let scene, camera, renderer, particlesGeometry, particlesMaterial, particleSystem;
        let globalSwirlForce = 0.40;
        let globalDamping = 0.90;
        let globalGravityForce = 0.50;
        let effectTypeIndex = 0.0; // 0: Vortex, 1: Disperse, 2: Gravity, 3: Swarm
        let renderTypeIndex = 0.0; // 0: Point circle, 1: Point Square
        
        let targetProgress = 0.0;
        let animationProgress = 0.0;
        let isAutoAssembling = false;
        let currentDensity = 100; // 100x100 grid

        let frameCount = 0;
        let lastFpsUpdate = 0;

        // Custom Orbit tracking variables
        let theta = 0, phi = Math.PI / 2, radius = 6.0;
        let isOrbiting = false, prevMouseX = 0, prevMouseY = 0;

        // Procedural Vector Generators
        const ProceduralVectors = {
            drawPreset1: function(ctx, w, h) {
                // Nebula Rings
                ctx.fillStyle = "#ffffff";
                ctx.fillRect(0,0,w,h);
                // Celestial spiral center
                let gradient = ctx.createRadialGradient(w/2, h/2, 5, w/2, h/2, w/2);
                gradient.addColorStop(0, '#f43f5e'); // vibrant rose
                gradient.addColorStop(0.3, '#3b82f6'); // electric blue
                gradient.addColorStop(0.7, '#4f46e5'); // stardust indigo
                gradient.addColorStop(1, '#0f172a'); // deep space
                ctx.fillStyle = gradient;
                ctx.fillRect(0,0,w,h);

                // Add dust rings
                ctx.strokeStyle = '#ffffff';
                ctx.lineWidth = 3;
                ctx.beginPath();
                ctx.arc(w/2, h/2, w*0.25, 0, Math.PI * 2);
                ctx.stroke();

                ctx.strokeStyle = '#38bdf8';
                ctx.lineWidth = 2;
                ctx.beginPath();
                ctx.arc(w/2, h/2, w*0.35, 0, Math.PI * 2);
                ctx.stroke();
            },
            drawPreset2: function(ctx, w, h) {
                // Geo Vortex Graphic
                ctx.fillStyle = "#ffffff";
                ctx.fillRect(0,0,w,h);

                ctx.fillStyle = "#1e1b4b";
                ctx.fillRect(0,0,w,h);

                // Triangles & polygons
                ctx.fillStyle = "#e11d48";
                ctx.beginPath();
                ctx.moveTo(w*0.5, h*0.2);
                ctx.lineTo(w*0.8, h*0.8);
                ctx.lineTo(w*0.2, h*0.8);
                ctx.closePath();
                ctx.fill();

                ctx.fillStyle = "#10b981";
                ctx.beginPath();
                ctx.moveTo(w*0.5, h*0.8);
                ctx.lineTo(w*0.8, h*0.3);
                ctx.lineTo(w*0.2, h*0.3);
                ctx.closePath();
                ctx.fill();
            },
            drawPreset3: function(ctx, w, h) {
                // Digital Aurora
                ctx.fillStyle = "#020617";
                ctx.fillRect(0,0,w,h);

                // Swerving vertical waves
                let grad = ctx.createLinearGradient(0,0,w,0);
                grad.addColorStop(0, "#06b6d4");
                grad.addColorStop(0.5, "#a855f7");
                grad.addColorStop(1, "#ec4899");
                ctx.fillStyle = grad;
                
                ctx.beginPath();
                ctx.moveTo(0, h*0.5);
                ctx.bezierCurveTo(w*0.25, h*0.2, w*0.75, h*0.8, w, h*0.5);
                ctx.lineTo(w, h);
                ctx.lineTo(0, h);
                ctx.closePath();
                ctx.fill();
            }
        };

        // Render thumbnails on preload
        function renderThumbnails() {
            for(let i=1; i<=3; i++) {
                const c = document.getElementById(`preset-canvas-${i}`);
                if (c) {
                    c.width = 100;
                    c.height = 75;
                    ProceduralVectors[`drawPreset${i}`](c.getContext('2d'), 100, 75);
                }
            }
        }

        // Initialize WebGL & Three.js Particle Environment
        function initApp() {
            initCardPerspectiveTilt();
            renderThumbnails();

            offscreenCanvas.width = 200;
            offscreenCanvas.height = 150;

            // Preload Preset 1 inside offscreen buffer
            ProceduralVectors.drawPreset1(offscreenCtx, 200, 150);

            // Init WebGL Engine
            setupWebGL();
            setupParticleSystem();
            setupEventListeners();

            // Open intro modal smoothly
            setTimeout(() => {
                guideModal.classList.remove('opacity-0', 'pointer-events-none');
            }, 600);
        }

        // Interactive perspective tilt hover effect (Pristine Light Theme)
        function initCardPerspectiveTilt() {
            const cards = [
                document.getElementById('upload-card'),
                document.getElementById('settings-card'),
                document.getElementById('viewport-card'),
                document.getElementById('dials-card')
            ];

            cards.forEach(card => {
                if(!card) return;
                card.addEventListener('mousemove', (e) => {
                    const rect = card.getBoundingClientRect();
                    const x = e.clientX - rect.left;
                    const y = e.clientY - rect.top;
                    const midX = rect.width / 2;
                    const midY = rect.height / 2;
                    
                    const rotX = (y - midY) / midY * -4; // subtle elegant tilt
                    const rotY = (x - midX) / midX * 4;
                    
                    card.style.transform = `rotateX(${rotX}deg) rotateY(${rotY}deg) scale(1.01)`;
                    card.style.boxShadow = '0 30px 60px -15px rgba(148, 163, 184, 0.25), 0 0 30px rgba(79, 70, 229, 0.04)';
                });

                card.style.transition = 'transform 0.1s ease-out, box-shadow 0.1s ease-out';

                card.addEventListener('mouseleave', () => {
                    card.style.transform = 'rotateX(0deg) rotateY(0deg) scale(1.0)';
                    card.style.boxShadow = 'none';
                });
            });
        }

        // Build WebGL Framework Elements
        function setupWebGL() {
            scene = new THREE.Scene();
            scene.background = new THREE.Color(0xf8fafc); // Premium light mode bg

            camera = new THREE.PerspectiveCamera(45, 4/3, 0.1, 100);
            updateCameraPosition();

            renderer = new THREE.WebGLRenderer({ antialias: true, alpha: false });
            renderer.setSize(canvasContainer.clientWidth, canvasContainer.clientHeight);
            renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
            canvasContainer.appendChild(renderer.domElement);

            animateLoop();
        }

        // Generate Buffer Attributes & Mesh Positions for Particle System
        function setupParticleSystem() {
            if (particleSystem) {
                scene.remove(particleSystem);
            }

            const w = offscreenCanvas.width;
            const h = offscreenCanvas.height;
            const imgData = offscreenCtx.getImageData(0, 0, w, h);

            // Recompute dynamic spacing matching target resolution density
            const stepX = Math.max(1, Math.floor(w / currentDensity));
            const stepY = Math.max(1, Math.floor(h / currentDensity));

            const positions = [];
            const targetPositions = [];
            const colors = [];
            const delays = [];

            // Draw and translate coordinates into spatial nodes
            for (let y = 0; y < h; y += stepY) {
                for (let x = 0; x < w; x += stepX) {
                    const idx = (y * w + x) * 4;
                    const r = imgData.data[idx] / 255;
                    const g = imgData.data[idx+1] / 255;
                    const b = imgData.data[idx+2] / 255;
                    const a = imgData.data[idx+3] / 255;

                    // Skip translucent transparent pixels if uploaded
                    if (a < 0.1) continue;

                    // Centered coordinate bounds mapping perfectly inside viewport aspect boundaries
                    const targetX = ((x / w) - 0.5) * 5.0;
                    const targetY = (0.5 - (y / h)) * 3.75;
                    const targetZ = 0.0;

                    positions.push(targetX, targetY, targetZ); // Standard base position attribute
                    targetPositions.push(targetX, targetY, targetZ); // Extracted final coalesced mesh destination
                    colors.push(r, g, b);
                    delays.push(Math.random() * 0.4); // Wave assembly delay mapping
                }
            }

            particlesGeometry = new THREE.BufferGeometry();
            particlesGeometry.setAttribute('position', new THREE.Float32BufferAttribute(positions, 3));
            particlesGeometry.setAttribute('targetPos', new THREE.Float32BufferAttribute(targetPositions, 3));
            particlesGeometry.setAttribute('color', new THREE.Float32BufferAttribute(colors, 3));
            particlesGeometry.setAttribute('delay', new THREE.Float32BufferAttribute(delays, 1));

            // Setup Custom GLSL WebGL Shader for rapid hardware computation
            particlesMaterial = new THREE.ShaderMaterial({
                vertexShader: particleVertexShader,
                fragmentShader: particleFragmentShader,
                uniforms: {
                    progress: { value: 0.0 },
                    noiseIntensity: { value: parseFloat(noiseSlider.value) / 10.0 },
                    scatterRadius: { value: parseFloat(scatterSlider.value) },
                    size: { value: parseFloat(sizeSlider.value) / 100.0 },
                    swirlForce: { value: globalSwirlForce },
                    gravityForce: { value: globalGravityForce },
                    time: { value: 0.0 },
                    effectType: { value: effectTypeIndex },
                    renderType: { value: renderTypeIndex }
                },
                transparent: true,
                depthWrite: false,
                blending: THREE.NormalBlending
            });

            particleSystem = new THREE.Points(particlesGeometry, particlesMaterial);
            scene.add(particleSystem);
        }

        // Camera positioning geometry calculations
        function updateCameraPosition() {
            camera.position.x = radius * Math.sin(phi) * Math.sin(theta);
            camera.position.y = radius * Math.cos(phi);
            camera.position.z = radius * Math.sin(phi) * Math.cos(theta);
            camera.lookAt(0, 0, 0);
        }

        // Active animation render loop running at constant framerates
        function animateLoop() {
            requestAnimationFrame(animateLoop);

            // Compute performance metrics
            frameCount++;
            const t = performance.now();
            if (t >= lastFpsUpdate + 1000) {
                const fps = Math.round((frameCount * 1000) / (t - lastFpsUpdate));
                fpsCounter.textContent = `${fps} FPS`;
                frameCount = 0;
                lastFpsUpdate = t;
            }

            // Interpolate dynamic particle progression
            if (isAutoAssembling) {
                animationProgress += (1.0 - animationProgress) * (0.02 * globalDamping);
                if (animationProgress > 0.999) {
                    animationProgress = 1.0;
                    isAutoAssembling = false;
                }
                
                // Keep manual progress slider in sync
                progressSlider.value = Math.round(animationProgress * 100);
                updateProgressUI(animationProgress);
            }

            // Feed updated values into Three.js materials
            if (particlesMaterial) {
                particlesMaterial.uniforms.progress.value = animationProgress;
                particlesMaterial.uniforms.time.value = t * 0.002;
            }

            renderer.render(scene, camera);
        }

        // Smooth UI State and Dial Updates
        function updateProgressUI(progressVal) {
            manualProgressVal.textContent = progressVal.toFixed(2);
            const percentage = Math.round(progressVal * 100);
            convergencePercentage.textContent = `${percentage}%`;
        }

        // Register interactive events
        function setupEventListeners() {
            
            // Image file upload processing
            fileInput.addEventListener('change', (e) => {
                const file = e.target.files[0];
                if (!file) return;

                const reader = new FileReader();
                reader.onload = function(event) {
                    const img = new Image();
                    img.onload = function() {
                        // Clear offscreen workspace and scale uploaded image safely
                        offscreenCtx.clearRect(0,0,200,150);
                        offscreenCtx.drawImage(img, 0, 0, 200, 150);

                        // Scatter system & rebuild
                        resetDispersalState();
                    };
                    img.src = event.target.result;
                };
                reader.readAsDataURL(file);
            });

            // Prevent drag event defaults
            ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(ev => {
                dropzone.addEventListener(ev, e => e.preventDefault());
            });

            dropzone.addEventListener('drop', (e) => {
                const dt = e.dataTransfer;
                const file = dt.files[0];
                if (file && file.type.startsWith('image/')) {
                    const reader = new FileReader();
                    reader.onload = function(event) {
                        const img = new Image();
                        img.onload = function() {
                            offscreenCtx.clearRect(0,0,200,150);
                            offscreenCtx.drawImage(img, 0, 0, 200, 150);
                            resetDispersalState();
                        };
                        img.src = event.target.result;
                    };
                    reader.readAsDataURL(file);
                }
            });

            // Coalescing Force Selectors
            typeVortex.addEventListener('click', () => setCoalescingType('vortex', 0.0));
            typeDisperse.addEventListener('click', () => setCoalescingType('disperse', 1.0));
            typeGravity.addEventListener('click', () => setCoalescingType('gravity', 2.0));
            typeAurora.addEventListener('click', () => setCoalescingType('aurora', 3.0));

            function setCoalescingType(type, index) {
                effectTypeIndex = index;
                if (particlesMaterial) {
                    particlesMaterial.uniforms.effectType.value = index;
                }

                // Reset visual highlight styles
                const ids = ['type-vortex', 'type-disperse', 'type-gravity', 'type-aurora'];
                ids.forEach(id => {
                    const btn = document.getElementById(id);
                    if (id === `type-${type}`) {
                        btn.className = "type-btn p-2.5 bg-indigo-50 text-indigo-700 border border-indigo-200 rounded-xl text-xs font-bold transition-all flex items-center justify-center gap-1.5";
                    } else {
                        btn.className = "type-btn p-2.5 bg-slate-50 hover:bg-slate-100 text-slate-600 border border-slate-200 rounded-xl text-xs font-bold transition-all flex items-center justify-center gap-1.5";
                    }
                });
            }

            // Assembly Controls
            btnPlay.addEventListener('click', () => {
                isAutoAssembling = true;
            });

            btnDisperse.addEventListener('click', () => {
                resetDispersalState();
            });

            function resetDispersalState() {
                isAutoAssembling = false;
                animationProgress = 0.0;
                progressSlider.value = 0;
                updateProgressUI(0.0);
                setupParticleSystem();
            }

            // Density Slider rebuilds active geometry
            densitySlider.addEventListener('input', (e) => {
                const val = parseInt(e.target.value);
                currentDensity = val;
                densityVal.textContent = `${val * val} (${val}x${val})`;
                setupParticleSystem();
            });

            // Live updates for visual sliders
            scatterSlider.addEventListener('input', (e) => {
                const val = parseFloat(e.target.value);
                scatterVal.textContent = `${val.toFixed(1)} units`;
                if (particlesMaterial) {
                    particlesMaterial.uniforms.scatterRadius.value = val;
                }
            });

            sizeSlider.addEventListener('input', (e) => {
                const val = parseFloat(e.target.value) / 100.0;
                sizeVal.textContent = val.toFixed(2);
                if (particlesMaterial) {
                    particlesMaterial.uniforms.size.value = val;
                }
            });

            noiseSlider.addEventListener('input', (e) => {
                const val = parseFloat(e.target.value) / 10.0;
                noiseVal.textContent = val.toFixed(1);
                if (particlesMaterial) {
                    particlesMaterial.uniforms.noiseIntensity.value = val;
                }
            });

            progressSlider.addEventListener('input', (e) => {
                isAutoAssembling = false; // Pause playback on drag
                const val = parseFloat(e.target.value) / 100.0;
                animationProgress = val;
                updateProgressUI(val);
            });

            // Render style dot toggles
            renderDots.addEventListener('click', () => {
                renderTypeIndex = 0.0;
                renderDots.className = "px-3.5 py-1.5 bg-white text-indigo-600 font-semibold text-xs rounded-lg transition-all shadow-sm";
                renderQuads.className = "px-3.5 py-1.5 text-slate-500 hover:text-slate-800 text-xs rounded-lg transition-all";
                if (particlesMaterial) particlesMaterial.uniforms.renderType.value = 0.0;
            });

            renderQuads.addEventListener('click', () => {
                renderTypeIndex = 1.0;
                renderQuads.className = "px-3.5 py-1.5 bg-white text-indigo-600 font-semibold text-xs rounded-lg transition-all shadow-sm";
                renderDots.className = "px-3.5 py-1.5 text-slate-500 hover:text-slate-800 text-xs rounded-lg transition-all";
                if (particlesMaterial) particlesMaterial.uniforms.renderType.value = 1.0;
            });

            // Preset Template Selectors
            for(let i=1; i<=3; i++) {
                document.getElementById(`preset-${i}`).addEventListener('click', () => {
                    offscreenCtx.clearRect(0,0,200,150);
                    ProceduralVectors[`drawPreset${i}`](offscreenCtx, 200, 150);
                    resetDispersalState();
                });
            }

            // WebGL Orbit dragging mechanism
            canvasContainer.addEventListener('mousedown', (e) => {
                isOrbiting = true;
                prevMouseX = e.clientX;
                prevMouseY = e.clientY;
            });

            window.addEventListener('mousemove', (e) => {
                if (!isOrbiting) return;
                const deltaX = e.clientX - prevMouseX;
                const deltaY = e.clientY - prevMouseY;
                
                theta -= deltaX * 0.007;
                phi = Math.max(0.1, Math.min(Math.PI - 0.1, phi - deltaY * 0.007));

                prevMouseX = e.clientX;
                prevMouseY = e.clientY;

                updateCameraPosition();
            });

            window.addEventListener('mouseup', () => {
                isOrbiting = false;
            });

            // Dynamic Physical Tuning Dials Setup
            setupForceDials();

            // Reset Dials Action
            resetDialsBtn.addEventListener('click', () => {
                const defaults = {
                    'dial-swirl': 0.40,
                    'dial-damping': 0.90,
                    'dial-gravity': 0.50
                };
                Object.keys(defaults).forEach(id => {
                    const el = document.getElementById(id);
                    if (el) {
                        el.setAttribute('data-val', defaults[id]);
                        const indicator = el.querySelector('.dial-indicator');
                        const percent = (defaults[id] - parseFloat(el.getAttribute('data-min'))) / (parseFloat(el.getAttribute('data-max')) - parseFloat(el.getAttribute('data-min')));
                        indicator.style.transform = `rotate(${-120 + (percent * 240)}deg)`;
                    }
                });

                globalSwirlForce = 0.40;
                globalDamping = 0.90;
                globalGravityForce = 0.50;

                document.getElementById('dial-swirl-label').textContent = '0.40 rad';
                document.getElementById('dial-damping-label').textContent = '0.90 μ';
                document.getElementById('dial-gravity-label').textContent = '0.50 G';

                if (particlesMaterial) {
                    particlesMaterial.uniforms.swirlForce.value = 0.40;
                    particlesMaterial.uniforms.gravityForce.value = 0.50;
                }
            });

            // Guide triggers
            showGuideBtn.addEventListener('click', () => {
                guideModal.classList.remove('opacity-0', 'pointer-events-none');
            });
            closeGuideBtn.addEventListener('click', () => {
                guideModal.classList.add('opacity-0', 'pointer-events-none');
            });

            // Viewport resizing
            window.addEventListener('resize', () => {
                if (!renderer || !camera) return;
                renderer.setSize(canvasContainer.clientWidth, canvasContainer.clientHeight);
                camera.aspect = canvasContainer.clientWidth / canvasContainer.clientHeight;
                camera.updateProjectionMatrix();
            });
        }

        // Setup the physical dial rotation event listeners
        function setupForceDials() {
            const dials = [
                { id: 'dial-swirl', labelId: 'dial-swirl-label', unit: 'rad', setter: (val) => { globalSwirlForce = val; if (particlesMaterial) particlesMaterial.uniforms.swirlForce.value = val; } },
                { id: 'dial-damping', labelId: 'dial-damping-label', unit: 'μ', setter: (val) => { globalDamping = val; } },
                { id: 'dial-gravity', labelId: 'dial-gravity-label', unit: 'G', setter: (val) => { globalGravityForce = val; if (particlesMaterial) particlesMaterial.uniforms.gravityForce.value = val; } }
            ];

            dials.forEach(dialInfo => {
                const el = document.getElementById(dialInfo.id);
                if (!el) return;
                const indicator = el.querySelector('.dial-indicator');
                const label = document.getElementById(dialInfo.labelId);
                const min = parseFloat(el.getAttribute('data-min'));
                const max = parseFloat(el.getAttribute('data-max'));

                let isDraggingDial = false;
                let startY = 0;
                let startVal = parseFloat(el.getAttribute('data-val'));

                function updateDialVisual(val) {
                    const percent = (val - min) / (max - min);
                    const angle = -120 + (percent * 240); // 240 degree rotation Sweep
                    indicator.style.transform = `rotate(${angle}deg)`;
                    label.textContent = `${val.toFixed(2)} ${dialInfo.unit}`;
                }

                updateDialVisual(startVal);
                dialInfo.setter(startVal);

                el.addEventListener('mousedown', (e) => {
                    isDraggingDial = true;
                    startY = e.clientY;
                    startVal = parseFloat(el.getAttribute('data-val'));
                    e.preventDefault();
                });

                window.addEventListener('mousemove', (e) => {
                    if (!isDraggingDial) return;
                    const deltaY = startY - e.clientY;
                    const sensitivity = 0.004;
                    let newVal = startVal + (deltaY * sensitivity);
                    newVal = Math.max(min, Math.min(max, newVal));

                    el.setAttribute('data-val', newVal);
                    updateDialVisual(newVal);
                    dialInfo.setter(newVal);
                });

                window.addEventListener('mouseup', () => {
                    isDraggingDial = false;
                });
            });
        }

        // Launch Application
        window.onload = initApp;
    </script>
</body>
</html>
