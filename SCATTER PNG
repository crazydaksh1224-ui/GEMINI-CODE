<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>3D Particle Assembly Studio</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300..800&family=Space+Grotesk:wght@300..700&display=swap" rel="stylesheet">
    <!-- Three.js Library -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #f8fafc;
            color: #0f172a;
            overflow-x: hidden;
        }
        h1, h2, h3, .heading-font {
            font-family: 'Space Grotesk', sans-serif;
        }
        /* Premium Light-Theme Frosted Glass Cards */
        .glass-panel {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(226, 232, 240, 0.8);
            box-shadow: 0 10px 30px -10px rgba(148, 163, 184, 0.12), 0 1px 3px rgba(148, 163, 184, 0.05);
            transition: transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
            transform-style: preserve-3d;
            perspective: 1000px;
        }
        .glass-panel:hover {
            box-shadow: 0 30px 60px -15px rgba(148, 163, 184, 0.25), 0 0 40px rgba(59, 130, 246, 0.04);
        }
        /* Sliders */
        input[type="range"] {
            -webkit-appearance: none;
            appearance: none;
            background: #e2e8f0;
            height: 6px;
            border-radius: 9999px;
            outline: none;
        }
        input[type="range"]::-webkit-slider-thumb {
            -webkit-appearance: none;
            appearance: none;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            background: #4f46e5;
            cursor: pointer;
            box-shadow: 0 4px 10px rgba(79, 70, 229, 0.3);
            transition: transform 0.1s;
        }
        input[type="range"]::-webkit-slider-thumb:hover {
            transform: scale(1.15);
        }
        /* Tooltip animation */
        .tooltip {
            visibility: hidden;
            opacity: 0;
            transition: opacity 0.2s, visibility 0.2s;
        }
        .has-tooltip:hover .tooltip {
            visibility: visible;
            opacity: 1;
        }
        /* Custom dynamic custom scrollbar */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        ::-webkit-scrollbar-track {
            background: #f1f5f9;
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 9999px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }
    </style>
</head>
<body class="min-h-screen flex flex-col justify-between p-4 sm:p-6 lg:p-8 relative">

    <!-- Ambient glowing backgrounds -->
    <div class="fixed top-[-10%] left-[-10%] w-[50%] h-[50%] rounded-full bg-indigo-500/5 blur-[120px] pointer-events-none z-[-1]"></div>
    <div class="fixed bottom-[-10%] right-[-10%] w-[50%] h-[50%] rounded-full bg-blue-500/5 blur-[120px] pointer-events-none z-[-1]"></div>

    <!-- Header Section -->
    <header class="max-w-7xl w-full mx-auto mb-8 flex flex-col lg:flex-row items-start lg:items-center justify-between gap-6 z-10">
        <div>
            <div class="flex items-center gap-2 mb-1.5">
                <span class="w-3 h-3 bg-indigo-600 rounded-full animate-ping shadow-[0_0_8px_#4f46e5]"></span>
                <span class="text-xs uppercase tracking-[0.25em] font-bold text-indigo-600 heading-font">3D Physical Simulation</span>
            </div>
            <h1 class="text-4xl lg:text-5xl font-extrabold tracking-tight text-slate-900">
                Stardust Assembly Studio
            </h1>
            <p class="text-sm text-slate-500 mt-1 max-w-xl">
                Watch thousands of dispersed spatial particles coalesce from raw cosmic dust to form your favorite high-fidelity photos.
            </p>
        </div>
        <div class="flex items-center gap-3 bg-white/80 p-1.5 rounded-2xl border border-slate-200/80 w-full lg:w-auto shadow-sm">
            <button id="show-guide-btn" class="px-5 py-2.5 bg-slate-50 hover:bg-slate-100 text-slate-600 hover:text-slate-900 rounded-xl text-xs font-semibold tracking-wide transition-all border border-slate-200">
                Explore Mechanics
            </button>
            <a href="#studio-viewport" class="px-5 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white rounded-xl text-xs font-bold tracking-wide shadow-lg shadow-indigo-600/15 transition-all">
                Launch Space
            </a>
        </div>
    </header>

    <!-- Main Workspace Grid -->
    <main class="max-w-7xl w-full mx-auto grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-8 items-start mb-8 z-10">
        
        <!-- Left Column: Source Upload & Preset Configuration (5 Cols) -->
        <section class="lg:col-span-5 flex flex-col gap-6">
            
            <!-- Card 1: Upload Source -->
            <div class="glass-panel rounded-3xl p-5 sm:p-6" id="upload-card">
                <div class="flex items-center justify-between mb-4 border-b border-slate-100 pb-3">
                    <h2 class="text-lg font-bold text-slate-800 flex items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                        1. Source Canvas Image
                    </h2>
                    <span class="text-[9px] uppercase font-bold text-slate-400 tracking-wider">Upload Layer</span>
                </div>

                <!-- Dropzone -->
                <div id="dropzone" class="border-2 border-dashed border-slate-200 hover:border-indigo-500/50 rounded-2xl p-6 text-center cursor-pointer transition-all bg-slate-50/50 hover:bg-white group relative overflow-hidden flex flex-col items-center justify-center min-h-[140px]">
                    <input type="file" id="image-upload" accept="image/*" class="absolute inset-0 opacity-0 cursor-pointer z-10" />
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-slate-400 group-hover:text-indigo-500 group-hover:scale-110 transition-all mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
                    </svg>
                    <p class="text-xs font-semibold text-slate-600 group-hover:text-slate-900 transition-all">Drag and drop your image here</p>
                    <p class="text-[10px] text-slate-400 mt-1">PNG, JPG, JPEG or WebP (processed locally inside browser)</p>
                </div>

                <!-- Template Presets (CORS-Safe) -->
                <div class="mt-5">
                    <p class="text-[10px] uppercase font-bold text-slate-400 tracking-wider mb-2.5">Or Choose an In-house Template</p>
                    <div class="grid grid-cols-3 gap-2">
                        <button id="preset-1" class="preset-btn p-1.5 bg-slate-50 hover:bg-white rounded-xl border border-slate-200 transition-all text-left flex flex-col gap-1.5 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500">
                            <canvas id="preset-canvas-1" class="w-full aspect-[4/3] rounded-lg border border-slate-100 shadow-inner"></canvas>
                            <span class="px-1 text-[10px] font-bold truncate w-full text-slate-600">Nebula Orbit</span>
                        </button>
                        <button id="preset-2" class="preset-btn p-1.5 bg-slate-50 hover:bg-white rounded-xl border border-slate-200 transition-all text-left flex flex-col gap-1.5 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500">
                            <canvas id="preset-canvas-2" class="w-full aspect-[4/3] rounded-lg border border-slate-100 shadow-inner"></canvas>
                            <span class="px-1 text-[10px] font-bold truncate w-full text-slate-600">Geo Vortex</span>
                        </button>
                        <button id="preset-3" class="preset-btn p-1.5 bg-slate-50 hover:bg-white rounded-xl border border-slate-200 transition-all text-left flex flex-col gap-1.5 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500">
                            <canvas id="preset-canvas-3" class="w-full aspect-[4/3] rounded-lg border border-slate-100 shadow-inner"></canvas>
                            <span class="px-1 text-[10px] font-bold truncate w-full text-slate-600">Digital Aurora</span>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Card 2: Physical Forces Settings -->
            <div class="glass-panel rounded-3xl p-5 sm:p-6" id="settings-card">
                <div class="flex items-center justify-between mb-4 border-b border-slate-100 pb-3">
                    <h2 class="text-lg font-bold text-slate-800 flex items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
                        </svg>
                        2. Simulation Variables
                    </h2>
                    <span class="text-[9px] uppercase font-bold text-slate-400 tracking-wider">Physics Core</span>
                </div>

                <!-- Simulation Settings -->
                <div class="space-y-4">
                    
                    <!-- Coalescence Type -->
                    <div>
                        <label class="block text-xs font-bold text-slate-600 mb-2">Dust Coalescing Force Engine</label>
                        <div class="grid grid-cols-2 gap-2">
                            <button id="type-vortex" class="type-btn p-2.5 bg-indigo-50 text-indigo-700 border border-indigo-200 rounded-xl text-xs font-bold transition-all flex items-center justify-center gap-1.5">
                                🌀 Vortex Spin
                            </button>
                            <button id="type-disperse" class="type-btn p-2.5 bg-slate-50 hover:bg-slate-100 text-slate-600 border border-slate-200 rounded-xl text-xs font-bold transition-all flex items-center justify-center gap-1.5">
                                💥 Linear Scatter
                            </button>
                            <button id="type-gravity" class="type-btn p-2.5 bg-slate-50 hover:bg-slate-100 text-slate-600 border border-slate-200 rounded-xl text-xs font-bold transition-all flex items-center justify-center gap-1.5">
                                🌌 Heavy Gravity
                            </button>
                            <button id="type-aurora" class="type-btn p-2.5 bg-slate-50 hover:bg-slate-100 text-slate-600 border border-slate-200 rounded-xl text-xs font-bold transition-all flex items-center justify-center gap-1.5">
                                ✨ Cosmic Swarm
                            </button>
                        </div>
                    </div>

                    <!-- Slide controls -->
                    <div class="space-y-3.5 pt-2">
                        
                        <!-- Particle Density -->
                        <div>
                            <div class="flex items-center justify-between text-xs mb-1.5">
                                <span class="font-bold text-slate-600">Density (Particle Grid Size)</span>
                                <span id="density-val" class="text-indigo-600 font-bold font-mono">10,000 (100x100)</span>
                            </div>
                            <input type="range" id="density-slider" min="50" max="180" value="100" class="w-full" />
                            <div class="flex items-center justify-between text-[9px] text-slate-400 mt-1">
                                <span>2,500 (Max FPS)</span>
                                <span>32,400 (Highly Detailed)</span>
                            </div>
                        </div>

                        <!-- Scatter Radius -->
                        <div>
                            <div class="flex items-center justify-between text-xs mb-1.5">
                                <span class="font-bold text-slate-600">Scattering Range (Drift Distance)</span>
                                <span id="scatter-val" class="text-indigo-600 font-bold font-mono">15.0 units</span>
                            </div>
                            <input type="range" id="scatter-slider" min="5" max="30" value="15" class="w-full" />
                        </div>

                        <!-- Particle Diameter -->
                        <div>
                            <div class="flex items-center justify-between text-xs mb-1.5">
                                <span class="font-bold text-slate-600">Pixel Size (Dust Diameter)</span>
                                <span id="size-val" class="text-indigo-600 font-bold font-mono">0.05</span>
                            </div>
                            <input type="range" id="size-slider" min="1" max="15" value="5" class="w-full" />
                        </div>

                        <!-- Coalescing Noise Intensity -->
                        <div>
                            <div class="flex items-center justify-between text-xs mb-1.5">
                                <span class="font-bold text-slate-600">Drift Turbulence (Fluctuation)</span>
                                <span id="noise-val" class="text-indigo-600 font-bold font-mono">2.0</span>
                            </div>
                            <input type="range" id="noise-slider" min="0" max="50" value="20" class="w-full" />
                        </div>

                    </div>
                </div>
            </div>

        </section>

        <!-- Right Column: 3D WebGL Viewport & Convergence Dials (7 Cols) -->
        <section class="lg:col-span-7 flex flex-col gap-6" id="studio-viewport">
            
            <!-- Three.js Visualizer Panel -->
            <div class="glass-panel rounded-3xl p-4 sm:p-6" id="viewport-card">
                <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between mb-4 pb-3 border-b border-slate-100 gap-3">
                    <div>
                        <h2 class="text-lg font-bold text-slate-800 flex items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                            </svg>
                            Stardust Assembly Viewport
                        </h2>
                        <p class="text-[10px] text-slate-400 mt-0.5">Click and drag inside viewport to rotate perspective camera</p>
                    </div>
                    
                    <!-- Render Type Toggles -->
                    <div class="flex items-center gap-2 bg-slate-100 p-1 rounded-xl self-stretch sm:self-auto justify-center border border-slate-200/50">
                        <button id="render-dots" class="px-3.5 py-1.5 bg-white text-indigo-600 font-semibold text-xs rounded-lg transition-all shadow-sm">
                            Glowing Points
                        </button>
                        <button id="render-quads" class="px-3.5 py-1.5 text-slate-500 hover:text-slate-800 text-xs rounded-lg transition-all">
                            Small Squares
                        </button>
                    </div>
                </div>

                <!-- WebGL Canvas Container -->
                <div class="relative w-full aspect-[4/3] rounded-2xl overflow-hidden bg-white border border-slate-200 group shadow-inner">
                    <!-- Offscreen Canvas for pixel processing -->
                    <canvas id="offscreen-processing" class="hidden"></canvas>
                    
                    <!-- WebGL viewport -->
                    <div id="canvas3d-container" class="w-full h-full cursor-grab active:cursor-grabbing"></div>

                    <!-- Overlay State Indicators -->
                    <div class="absolute bottom-3 left-3 flex items-center gap-3 pointer-events-none">
                        <div class="bg-white/90 backdrop-blur border border-slate-200/80 px-2.5 py-1.5 rounded-xl text-[9px] text-slate-500 font-mono tracking-wider flex items-center gap-2 shadow-sm">
                            <span class="flex h-2 w-2 relative">
                                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                                <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
                            </span>
                            RENDER: <span id="fps-counter" class="font-bold text-slate-800">60 FPS</span>
                        </div>
                        <div class="bg-white/90 backdrop-blur border border-slate-200/80 px-2.5 py-1.5 rounded-xl text-[9px] text-slate-500 font-mono tracking-wider shadow-sm">
                            COALESCED: <span id="convergence-percentage" class="font-bold text-indigo-600">0%</span>
                        </div>
                    </div>

                    <!-- Ambient Playback Overlay Controls -->
                    <div class="absolute bottom-3 right-3 flex items-center gap-2">
                        <!-- Disperse (Reset) -->
                        <button id="btn-disperse" class="p-3 bg-white hover:bg-slate-50 text-slate-600 hover:text-slate-900 rounded-xl border border-slate-200 shadow-sm transition-all hover:scale-105 active:scale-95 flex items-center justify-center" title="Scatter Particles">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
                            </svg>
                        </button>
                        <!-- Play/Coalesce -->
                        <button id="btn-play" class="py-3 px-5 bg-indigo-600 hover:bg-indigo-500 text-white font-bold rounded-xl shadow-lg shadow-indigo-600/20 transition-all hover:scale-105 active:scale-95 flex items-center justify-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 fill-current" viewBox="0 0 24 24">
                                <path d="M8 5v14l11-7z" />
                            </svg>
                            Coalesce Assembly
                        </button>
                    </div>
                </div>

                <!-- Custom Convergence Progress Slider -->
                <div class="mt-4 bg-slate-50 border border-slate-200/80 p-4 rounded-2xl">
                    <div class="flex items-center justify-between text-xs mb-2">
                        <span class="font-bold text-slate-700">Manual Progression Interpolation</span>
                        <span id="manual-progress-val" class="text-indigo-600 font-mono font-bold">0.00</span>
                    </div>
                    <input type="range" id="progress-slider" min="0" max="100" value="0" class="w-full" />
                    <div class="flex items-center justify-between text-[10px] text-slate-400 mt-1">
                        <span>Fully Scattered (Dust Cloud State)</span>
                        <span>Perfect Assembly (Reconstructed Image Plane)</span>
                    </div>
                </div>
            </div>

            <!-- Dial Control Section -->
            <div class="glass-panel rounded-3xl p-5 sm:p-6 shadow-2xl relative overflow-hidden" id="dials-card">
                <div class="absolute top-0 right-0 w-24 h-24 bg-gradient-to-bl from-indigo-500/5 to-transparent pointer-events-none"></div>
                <div class="flex items-center justify-between mb-5 border-b border-slate-100 pb-3">
                    <div>
                        <h2 class="text-lg font-bold text-slate-800 flex items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
                            </svg>
                            3. Physical Forces Tuning Dials
                        </h2>
                        <p class="text-[10px] text-slate-400 mt-0.5">Click and drag dials up/down to adjust environmental math parameters</p>
                    </div>
                    <button id="reset-dials-btn" class="text-slate-400 hover:text-indigo-600 text-xs transition-colors flex items-center gap-1 font-semibold">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 8H18" />
                        </svg>
                        Default Dials
                    </button>
                </div>

                <!-- Three physical force dials -->
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 justify-items-center">
                    
                    <!-- Dial 1: Swirl Force -->
                    <div class="flex flex-col items-center">
                        <span class="text-xs font-bold text-slate-500 mb-2.5 tracking-wide uppercase">Swirl Vortex Torque</span>
                        <div id="dial-swirl" class="dial-container relative w-[100px] h-[100px] rounded-full bg-slate-50 border-4 border-slate-200 shadow-inner cursor-grab touch-action-none" data-val="0.4" data-min="0.0" data-max="2.0">
                            <div class="dial-indicator absolute w-1 h-[35px] bg-indigo-600 rounded-full top-[12px] left-[44px] transform-origin-[2px_35px] shadow-[0_0_10px_rgba(79,70,229,0.5)] pointer-events-none"></div>
                        </div>
                        <span id="dial-swirl-label" class="text-xs font-mono font-bold text-indigo-600 mt-3 bg-indigo-50 px-3 py-1 rounded-full border border-indigo-100">0.40 rad</span>
                        <p class="text-[9px] text-slate-400 text-center mt-2 max-w-[130px]">Rotational vector angular frequency pull</p>
                    </div>

                    <!-- Dial 2: Coalesce Friction -->
                    <div class="flex flex-col items-center">
                        <span class="text-xs font-bold text-slate-500 mb-2.5 tracking-wide uppercase">Dampening Friction</span>
                        <div id="dial-damping" class="dial-container relative w-[100px] h-[100px] rounded-full bg-slate-50 border-4 border-slate-200 shadow-inner cursor-grab touch-action-none" data-val="0.9" data-min="0.5" data-max="1.0">
                            <div class="dial-indicator absolute w-1 h-[35px] bg-indigo-600 rounded-full top-[12px] left-[44px] transform-origin-[2px_35px] shadow-[0_0_10px_rgba(79,70,229,0.5)] pointer-events-none"></div>
                        </div>
                        <span id="dial-damping-label" class="text-xs font-mono font-bold text-indigo-600 mt-3 bg-indigo-50 px-3 py-1 rounded-full border border-indigo-100">0.90 μ</span>
                        <p class="text-[9px] text-slate-400 text-center mt-2 max-w-[130px]">Resistance holding back extreme scattering energy</p>
                    </div>

                    <!-- Dial 3: Gravitational Core Pull -->
                    <div class="flex flex-col items-center">
                        <span class="text-xs font-bold text-slate-500 mb-2.5 tracking-wide uppercase">Centripetal Gravitational Pull</span>
                        <div id="dial-gravity" class="dial-container relative w-[100px] h-[100px] rounded-full bg-slate-50 border-4 border-slate-200 shadow-inner cursor-grab touch-action-none" data-val="0.5" data-min="0.0" data-max="3.0">
                            <div class="dial-indicator absolute w-1 h-[35px] bg-indigo-600 rounded-full top-[12px] left-[44px] transform-origin-[2px_35px] shadow-[0_0_10px_rgba(79,70,229,0.5)] pointer-events-none"></div>
