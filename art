<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Angy Frog Pixel Studio</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts for Playful Bubbly Vibe -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@300..700&family=Plus+Jakarta+Sans:wght@300..800&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #0f172a;
            color: #f8fafc;
        }
        h1, h2, h3, .bubbly-font {
            font-family: 'Fredoka', sans-serif;
        }
        /* Custom scrollbars */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #1e293b;
        }
        ::-webkit-scrollbar-thumb {
            background: #475569;
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #64748b;
        }
        /* Prevent dragging images */
        img {
            user-select: none;
            -webkit-user-drag: none;
        }
    </style>
</head>
<body class="min-h-screen flex flex-col justify-between">

    <!-- Header -->
    <header class="border-b border-slate-800 bg-slate-900/80 backdrop-blur sticky top-0 z-50 px-4 py-3">
        <div class="max-w-7xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
            <div class="flex items-center gap-3">
                <div class="bg-emerald-500 text-slate-950 p-2 rounded-xl font-bold text-xl shadow-lg shadow-emerald-500/20 bubbly-font">
                    🐸 Angy
                </div>
                <div>
                    <h1 class="text-xl sm:text-2xl font-bold text-white tracking-wide">Frog Pixel Studio</h1>
                    <p class="text-xs text-slate-400">Recreate &amp; customize your favorite grumpy graduate</p>
                </div>
            </div>
            
            <div class="flex items-center gap-3">
                <span class="px-3 py-1 bg-slate-800 text-xs font-semibold rounded-full border border-slate-700 text-slate-300">
                    Grid: 40 × 40
                </span>
                <span class="px-3 py-1 bg-emerald-500/10 text-emerald-400 text-xs font-semibold rounded-full border border-emerald-500/20">
                    Borderless Output Enabled
                </span>
            </div>
        </div>
    </header>

    <!-- Main Workspace -->
    <main class="flex-grow max-w-7xl w-full mx-auto px-4 py-6 grid grid-cols-1 lg:grid-cols-12 gap-6">
        
        <!-- Left Side: Interactive Canvas Workspace (7 Cols) -->
        <section class="lg:col-span-7 flex flex-col gap-4">
            
            <!-- Canvas Controls Header -->
            <div class="bg-slate-900 border border-slate-800 rounded-2xl p-4 flex flex-wrap items-center justify-between gap-4 shadow-xl">
                <!-- Undo / Redo -->
                <div class="flex items-center gap-2">
                    <button id="undo-btn" title="Undo (Ctrl+Z)" class="p-2.5 bg-slate-800 hover:bg-slate-700 text-slate-200 hover:text-white rounded-xl transition-all border border-slate-700 disabled:opacity-40 disabled:cursor-not-allowed">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6" />
                        </svg>
                    </button>
                    <button id="redo-btn" title="Redo (Ctrl+Y)" class="p-2.5 bg-slate-800 hover:bg-slate-700 text-slate-200 hover:text-white rounded-xl transition-all border border-slate-700 disabled:opacity-40 disabled:cursor-not-allowed">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M21 10h-10a8 8 0 00-8 8v2m18-2l-6 6m6-6l-6-6" />
                        </svg>
                    </button>
                </div>

                <!-- Grid Visual States -->
                <div class="flex items-center gap-3">
                    <label class="flex items-center gap-2 cursor-pointer text-sm text-slate-300 hover:text-white select-none">
                        <input type="checkbox" id="toggle-grid" class="w-4.5 h-4.5 rounded text-emerald-500 bg-slate-800 border-slate-700 focus:ring-emerald-500 focus:ring-offset-slate-900" checked>
                        <span>Show Gridlines</span>
                    </label>
                    <div class="h-5 w-px bg-slate-800"></div>
                    <label class="flex items-center gap-2 cursor-pointer text-sm text-slate-300 hover:text-white select-none">
                        <input type="checkbox" id="toggle-overlay" class="w-4.5 h-4.5 rounded text-emerald-500 bg-slate-800 border-slate-700 focus:ring-emerald-500 focus:ring-offset-slate-900">
                        <span>Compare Overlay</span>
                    </label>
                </div>

                <!-- Zoom Level -->
                <div class="flex items-center gap-2">
                    <span class="text-xs text-slate-400">Zoom:</span>
                    <input type="range" id="zoom-slider" min="8" max="20" value="12" class="w-24 accent-emerald-500 cursor-pointer">
                    <span id="zoom-val" class="text-xs font-mono text-slate-300 w-8">480px</span>
                </div>
            </div>

            <!-- Drawing Area Window -->
            <div class="relative bg-slate-950 border-2 border-slate-800 rounded-3xl p-6 flex items-center justify-center overflow-auto shadow-2xl min-h-[500px]">
                
                <!-- Main Pixel Canvas Container -->
                <div id="canvas-container" class="relative transition-all duration-200 ease-out" style="width: 480px; height: 480px;">
                    <!-- The Grid itself -->
                    <div id="pixel-grid" class="grid grid-cols-40 grid-rows-40 w-full h-full select-none cursor-crosshair"></div>
                    
                    <!-- Overlay Comparison Reference Image (semi-transparent) -->
                    <div id="reference-overlay" class="absolute inset-0 pointer-events-none opacity-0 transition-opacity duration-200">
                        <img id="overlay-img" class="w-full h-full object-contain opacity-40 mix-blend-normal" alt="Reference Frog">
                    </div>
                </div>

            </div>

            <!-- Canvas Quick Actions -->
            <div class="flex flex-wrap items-center gap-3">
                <button id="reset-original" class="flex-1 py-3 px-4 bg-slate-800 hover:bg-slate-700 text-slate-100 font-medium rounded-xl border border-slate-700 transition-all flex items-center justify-center gap-2 shadow-lg">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 8H18" />
                    </svg>
                    Reset to Original Angy Frog
                </button>
                <button id="clear-canvas" class="py-3 px-5 bg-red-500/10 hover:bg-red-500/20 text-red-400 font-medium rounded-xl border border-red-500/20 transition-all flex items-center justify-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                    </svg>
                    Clear All
                </button>
            </div>

        </section>

        <!-- Right Side: Tools, Palette, and Export Panels (5 Cols) -->
        <section class="lg:col-span-5 flex flex-col gap-6">
            
            <!-- Tool Selection & Palette Card -->
            <div class="bg-slate-900 border border-slate-800 rounded-3xl p-6 shadow-xl flex flex-col gap-6">
                
                <!-- Action Tools Selection -->
                <div>
                    <h3 class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-3">Drawing Mode</h3>
                    <div class="grid grid-cols-4 gap-2">
                        <button id="tool-draw" class="tool-btn py-3 px-2 bg-emerald-600 text-white rounded-2xl font-medium transition-all flex flex-col items-center gap-2 border border-emerald-500 shadow-lg shadow-emerald-500/10">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                            </svg>
                            <span class="text-xs">Pencil</span>
                        </button>
                        
                        <button id="tool-paint" class="tool-btn py-3 px-2 bg-slate-800 hover:bg-slate-700 text-slate-300 rounded-2xl font-medium transition-all flex flex-col items-center gap-2 border border-slate-700">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                            </svg>
                            <span class="text-xs">Fill bucket</span>
                        </button>

                        <button id="tool-erase" class="tool-btn py-3 px-2 bg-slate-800 hover:bg-slate-700 text-slate-300 rounded-2xl font-medium transition-all flex flex-col items-center gap-2 border border-slate-700">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                            </svg>
                            <span class="text-xs">Eraser</span>
                        </button>

                        <button id="tool-picker" class="tool-btn py-3 px-2 bg-slate-800 hover:bg-slate-700 text-slate-300 rounded-2xl font-medium transition-all flex flex-col items-center gap-2 border border-slate-700">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
                            </svg>
                            <span class="text-xs">Picker</span>
                        </button>
                    </div>
                </div>

                <!-- Custom Color Palette -->
                <div>
                    <div class="flex items-center justify-between mb-3">
                        <h3 class="text-sm font-semibold text-slate-400 uppercase tracking-wider">Frog Color Palette</h3>
                        <div class="flex items-center gap-2">
                            <span class="text-xs text-slate-500">Custom Color:</span>
                            <div class="relative w-8 h-8 rounded-lg overflow-hidden border border-slate-700 bg-slate-850 cursor-pointer">
                                <input type="color" id="custom-color-picker" value="#73cca8" class="absolute inset-0 opacity-0 cursor-pointer w-full h-full scale-150">
                                <div id="custom-color-preview" class="w-full h-full bg-[#73cca8]"></div>
                            </div>
                        </div>
                    </div>
                    
                    <div id="palette-grid" class="grid grid-cols-5 gap-3">
                        <!-- Palette Items are dynamically populated here -->
                    </div>
                </div>

            </div>

            <!-- Exporters Box -->
            <div class="bg-slate-900 border border-slate-800 rounded-3xl p-6 shadow-xl flex flex-col gap-5">
                <h3 class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-1">Export &amp; Share</h3>
                
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                    <!-- Export PNG -->
                    <button id="export-png-btn" class="p-4 bg-emerald-600 hover:bg-emerald-500 text-white font-semibold rounded-2xl transition-all flex flex-col items-center justify-center gap-2 border border-emerald-500 shadow-lg shadow-emerald-500/15">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                        </svg>
                        <span class="text-sm">Download PNG</span>
                        <span class="text-[10px] text-emerald-100 font-light">Saves as High-res Image</span>
                    </button>

                    <!-- Export CSS Box Shadow -->
                    <button id="export-css-btn" class="p-4 bg-slate-800 hover:bg-slate-700 text-slate-200 hover:text-white font-semibold rounded-2xl transition-all flex flex-col items-center justify-center gap-2 border border-slate-700">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                        </svg>
                        <span class="text-sm">Copy CSS Shadow</span>
                        <span class="text-[10px] text-slate-400 font-light">Pure HTML element!</span>
                    </button>
                </div>

                <div class="border-t border-slate-800 pt-4 flex flex-col gap-3">
                    <button id="copy-json-btn" class="w-full py-2.5 px-4 bg-slate-800/50 hover:bg-slate-800 text-slate-300 hover:text-white text-xs font-mono rounded-xl border border-slate-700/50 transition-all flex items-center justify-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
                        </svg>
                        Copy Pixel Matrix Data (JSON)
                    </button>
                </div>
            </div>

            <!-- Instructions & Information Section -->
            <div class="bg-slate-900/50 border border-slate-800 rounded-3xl p-6 flex flex-col gap-4">
                <h3 class="text-md font-semibold text-white bubbly-font flex items-center gap-2">
                    🎓 Grumpy Graduate Trivia
                </h3>
                <p class="text-sm text-slate-300 leading-relaxed">
                    This "angy frog" pixel art representation is laid out on an exact 40x40 grid mapping the beautiful hand-drawn feel of the meme. Use the **Pencil tool** to add your own flair (like sunglasses, custom diplomas, or party hats!), or change the gown colors to match your university colors!
                </p>
                <div class="grid grid-cols-2 gap-3 text-xs text-slate-400 bg-slate-950/40 p-3 rounded-2xl border border-slate-800/60">
                    <div>
                        <strong class="text-slate-200">Draw:</strong> Click &amp; Drag
                    </div>
                    <div>
                        <strong class="text-slate-200">Erase:</strong> Right Click or Erase Mode
                    </div>
                    <div>
                        <strong class="text-slate-200">Eyedropper:</strong> Alt + Click
                    </div>
                    <div>
                        <strong class="text-slate-200">Fill Bucket:</strong> Flood Fill Same Colors
                    </div>
                </div>
            </div>

        </section>

    </main>

    <!-- Footer -->
    <footer class="border-t border-slate-800 bg-slate-950 px-4 py-4 text-center text-xs text-slate-500">
        <div class="max-w-7xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
            <p>Designed with premium aesthetics &amp; pixel-perfect precision for the ultimate Angy Frog fan.</p>
            <p>&copy; 2026 Angy Frog Pixel Studio. All Rights Reserved.</p>
        </div>
    </footer>

    <!-- CSS Grid Layout System Style Generator -->
    <style>
        /* Specific Grid sizing rules */
        .grid-cols-40 {
            grid-template-columns: repeat(40, minmax(0, 1fr));
        }
        .grid-rows-40 {
            grid-template-rows: repeat(40, minmax(0, 1fr));
        }
    </style>

    <!-- App Script & Pixel Data Matrix -->
    <script>
        // The original template encoded in characters:
        // . = transparent/background (#fcfbfc)
        // k = outline (#1d1d1f)
        // g = mint green frog skin (#73cca8)
        // p = pink cheeks (#ff9ca8)
        // y = gold tassel/trim (#ebb53d)
        // w = diploma paper (#ffffff)
        // r = diploma ribbon (#db3b3b)
        // b = gown dark grey (#2a2b30)
        
        const ORIGINAL_FROG_TEMPLATE = [
            "........................................", // 0
            "........................................", // 1
            "........kk...k...kk...k...k...k..k..kk...k.", // 2  "now what?" custom pixel art rendering
            "........k.k..k..k..k..k...k...k..k.k..k..k.", // 3
            "........k..k.k..k..k..k.k.k...kkkk.kkkk..k.", // 4
            "........k...kk...kk....k.k....k..k.k..k..k.", // 5
            "........................................", // 6
            "........................................", // 7
            "........................................", // 8
            "...................kk...................", // 9 (graduation cap apex)
            ".................kkkkkk.................", // 10
            "...............kkkkkkkkkk...............", // 11
            ".............kkkkkkkkkkkkkk.............", // 12
            "...........kkkkkkkkkkkkkkkkkk...........", // 13
            ".........kkkkkkkkkkkkkkkkkkkkkk.........", // 14
            ".......kkkkkkkkkkkkkkkkkkkkkkkkkk.......", // 15
            ".....kkkkkkkkkkkkkkkkkkkkkkkkkkkkkk.....", // 16
            "...kkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkk...", // 17 (mortarboard left tip)
            "kkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkk", // 18 (mortarboard right tip)
            "..kkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkk.y..", // 19 (tassel thread hanging)
            "....kkkkkkkkkkkkkkkkkkkkkkkkkkkkkk...y..", // 20
            "......kkkkkkkkkkkkkkkkkkkkkkkkkk.....y..", // 21
            "........kkkkkkkkkkkkkkkkkkkkkk......yy..", // 22 (tassel ball)
            "..........kkkkkkkkkkkkkkkkkk........yy..", // 23
            "............kkkkkkkkkkkkkk..............", // 24
            "............kkggggggggggkk..............", // 25 (skullcap fits onto head)
            "...........kkggggggggggggkk.............", // 26
            "..........kkggkkggggkkggkkkk............", // 27 (eyes and furrows)
            "..........kkggkkggggkkggkkkk............", // 28
            ".........kkggkkkkkkkkkkggkkkk...........", // 29
            ".........kkggppppggggppppggkk...........", // 30 (pink cheeks)
            ".........kkggggggggggggggggkk...........", // 31
            ".........kkbbyyyyyyyyyyyybbkk...........", // 32 (gown collar with golden sash)
            ".........kkbbyyyyyyyyyyyybbkk...........", // 33
            ".........kkbbbyyyyyyyyybbbbkk...........", // 34
            ".........kkbbbwkkkkkkkkwwbbkk...........", // 35 (holding scroll)
            ".........kkbbbwkrrkrrkkwwbbkk...........", // 36 (red ribbon)
            "..........kkbbwkrrkrrkwwbbkk............", // 37
            "...........kkbbbbbbbbbbbbkk.............", // 38
            "............kk..kk..kk..kk.............."  // 39 (little feet)
        ];

        // Color definitions
        const COLORS = {
            '.': '#fcfbfc', // Background Off-white
            'k': '#1d1d1f', // Dark Outline / Black text
            'g': '#73cca8', // Frog Mint Green
            'p': '#ff9ca8', // Cheeks Pink
            'y': '#ebb53d', // Gold Tassel/Trim
            'w': '#ffffff', // White Scroll
            'r': '#db3b3b', // Red Ribbon
            'b': '#2a2b30'  // Gown Dark Slate
        };

        const COLOR_NAMES = {
            '.': 'Background Off-White',
            'k': 'Ink Charcoal Black',
            'g': 'Minty Frog Skin',
            'p': 'Bashful Pink Cheeks',
            'y': 'Academic Golden Yellow',
            'w': 'Parchment White',
            'r': 'Graduation Ribbon Red',
            'b': 'Ceremonial Gown Blue'
        };

        // Current App State
        let currentGrid = [];
        let selectedColorChar = 'g'; // Default to Frog Green
        let customColor = '#73cca8'; // Custom selected color hex
        let currentTool = 'draw'; // 'draw', 'paint' (fill), 'erase', 'picker'
        let undoStack = [];
        let redoStack = [];
        let isDrawing = false;
        let isGridlinesOn = true;
        let isOverlayOn = false;

        // Dom Elements
        const pixelGridEl = document.getElementById('pixel-grid');
        const paletteGridEl = document.getElementById('palette-grid');
        const customColorPicker = document.getElementById('custom-color-picker');
        const customColorPreview = document.getElementById('custom-color-preview');
        
        const toolDrawBtn = document.getElementById('tool-draw');
        const toolPaintBtn = document.getElementById('tool-paint');
        const toolEraseBtn = document.getElementById('tool-erase');
        const toolPickerBtn = document.getElementById('tool-picker');

        const undoBtn = document.getElementById('undo-btn');
        const redoBtn = document.getElementById('redo-btn');
        const toggleGrid = document.getElementById('toggle-grid');
        const toggleOverlay = document.getElementById('toggle-overlay');
        const zoomSlider = document.getElementById('zoom-slider');
        const zoomVal = document.getElementById('zoom-val');
        const canvasContainer = document.getElementById('canvas-container');
        const referenceOverlay = document.getElementById('reference-overlay');
        const overlayImg = document.getElementById('overlay-img');

        const resetOriginalBtn = document.getElementById('reset-original');
        const clearCanvasBtn = document.getElementById('clear-canvas');

        const exportPngBtn = document.getElementById('export-png-btn');
        const exportCssBtn = document.getElementById('export-css-btn');
        const copyJsonBtn = document.getElementById('copy-json-btn');

        // Initializing the reference overlay image automatically
        // We render the original layout onto an offscreen canvas to create the reference image dynamically!
        function generateReferenceImageBase64() {
            const tempCanvas = document.createElement('canvas');
            tempCanvas.width = 400;
            tempCanvas.height = 400;
            const ctx = tempCanvas.getContext('2d');
            
            for (let r = 0; r < 40; r++) {
                for (let c = 0; c < 40; c++) {
                    const char = ORIGINAL_FROG_TEMPLATE[r][c];
                    ctx.fillStyle = COLORS[char];
                    ctx.fillRect(c * 10, r * 10, 10, 10);
                }
            }
            return tempCanvas.toDataURL('image/png');
        }

        // Initialize state
        function initApp() {
            // Set up reference overlay image
            overlayImg.src = generateReferenceImageBase64();

            // Populate palette
            buildPalette();

            // Load original artwork
            loadTemplate(ORIGINAL_FROG_TEMPLATE);

            // Register event listeners
            setupEventListeners();
            updateUndoRedoButtons();
        }

        // Load specific artwork template into memory & render
        function loadTemplate(template) {
            currentGrid = [];
            for (let r = 0; r < 40; r++) {
                const row = [];
                for (let c = 0; c < 40; c++) {
                    const char = template[r][c] || '.';
                    row.push(COLORS[char] || '#fcfbfc');
                }
                currentGrid.push(row);
            }
            saveState(); // push initial state to undo stack
            renderGrid();
        }

        // Generate the 40x40 pixel DOM elements
        function renderGrid() {
            pixelGridEl.innerHTML = '';
            for (let r = 0; r < 40; r++) {
                for (let c = 0; c < 40; c++) {
                    const cell = document.createElement('div');
                    cell.style.backgroundColor = currentGrid[r][c];
                    cell.dataset.row = r;
                    cell.dataset.col = c;
                    
                    // Add grid lines class if enabled
                    if (isGridlinesOn) {
                        cell.className = 'border-[0.5px] border-slate-800/20';
                    } else {
                        cell.className = 'border-0';
                    }

                    // Mouse interactions
                    cell.addEventListener('mousedown', (e) => handlePixelMouseDown(e, r, c));
                    cell.addEventListener('mouseenter', (e) => handlePixelMouseEnter(e, r, c));

                    pixelGridEl.appendChild(cell);
                }
            }
        }

        // Re-draw specific cell in UI to avoid full-grid re-render lag
        function updateCellColor(r, c, color) {
            currentGrid[r][c] = color;
            const index = r * 40 + c;
            const cell = pixelGridEl.children[index];
            if (cell) {
                cell.style.backgroundColor = color;
            }
        }

        // Color Palette Creator
        function buildPalette() {
            paletteGridEl.innerHTML = '';
            
            Object.keys(COLORS).forEach(char => {
                const colorHex = COLORS[char];
                const name = COLOR_NAMES[char];
                
                const btn = document.createElement('button');
                btn.className = `group relative p-1 rounded-2xl border transition-all duration-150 flex flex-col items-center gap-1 ${selectedColorChar === char ? 'border-emerald-400 bg-slate-800/80 shadow-md' : 'border-slate-800 hover:border-slate-700 bg-slate-950/40'}`;
                btn.dataset.char = char;
                
                btn.innerHTML = `
                    <div class="w-full h-10 rounded-xl shadow-inner border border-slate-900/40 transition-transform group-hover:scale-95" style="background-color: ${colorHex}"></div>
                    <span class="text-[9px] text-slate-400 truncate w-full text-center px-1 font-medium">${name.split(' ')[0]}</span>
                    <!-- Tooltip -->
                    <span class="absolute bottom-full mb-2 left-1/2 -translate-x-1/2 bg-slate-950 text-slate-100 text-[10px] py-1 px-2.5 rounded shadow-lg whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-50 border border-slate-800">
                        ${name} (${colorHex})
                    </span>
                `;

                btn.addEventListener('click', () => {
                    selectedColorChar = char;
                    customColor = colorHex;
                    customColorPreview.style.backgroundColor = colorHex;
                    customColorPicker.value = colorHex;
                    buildPalette(); // Redraw selection highlights
                    
                    // Automatically switch to Pencil tool when color selected
                    if (currentTool === 'erase') {
                        setTool('draw');
                    }
                });

                paletteGridEl.appendChild(btn);
            });
        }

        // Tool Selection
        function setTool(tool) {
            currentTool = tool;
            
            // Remove active classes
            [toolDrawBtn, toolPaintBtn, toolEraseBtn, toolPickerBtn].forEach(b => {
                b.className = "tool-btn py-3 px-2 bg-slate-800 hover:bg-slate-700 text-slate-300 rounded-2xl font-medium transition-all flex flex-col items-center gap-2 border border-slate-700";
            });

            // Add active class
            if (tool === 'draw') {
                toolDrawBtn.className = "tool-btn py-3 px-2 bg-emerald-600 text-white rounded-2xl font-medium transition-all flex flex-col items-center gap-2 border border-emerald-500 shadow-lg shadow-emerald-500/10";
            } else if (tool === 'paint') {
                toolPaintBtn.className = "tool-btn py-3 px-2 bg-emerald-600 text-white rounded-2xl font-medium transition-all flex flex-col items-center gap-2 border border-emerald-500 shadow-lg shadow-emerald-500/10";
            } else if (tool === 'erase') {
                toolEraseBtn.className = "tool-btn py-3 px-2 bg-emerald-600 text-white rounded-2xl font-medium transition-all flex flex-col items-center gap-2 border border-emerald-500 shadow-lg shadow-emerald-500/10";
            } else if (tool === 'picker') {
                toolPickerBtn.className = "tool-btn py-3 px-2 bg-emerald-600 text-white rounded-2xl font-medium transition-all flex flex-col items-center gap-2 border border-emerald-500 shadow-lg shadow-emerald-500/10";
            }
        }

        // Draw Logic Actions
        function drawPixel(r, c) {
            let colorToApply = customColor;
            if (currentTool === 'erase') {
                colorToApply = COLORS['.']; // Erase resets to transparent/off-white background
            }

            if (currentGrid[r][c] !== colorToApply) {
                updateCellColor(r, c, colorToApply);
            }
        }

        // Flood Fill algorithm (Paint Bucket)
        function floodFill(r, c, targetColor, replacementColor) {
            if (targetColor === replacementColor) return;
            if (currentGrid[r][c] !== targetColor) return;

            const queue = [[r, c]];
            while (queue.length > 0) {
                const [curR, curC] = queue.shift();
                
                if (currentGrid[curR][curC] === targetColor) {
                    updateCellColor(curR, curC, replacementColor);
                    
                    // Neighbors
                    if (curR > 0) queue.push([curR - 1, curC]);
                    if (curR < 39) queue.push([curR + 1, curC]);
                    if (curC > 0) queue.push([curR, curC - 1]);
                    if (curC < 39) queue.push([curR, curC + 1]);
                }
            }
        }

        // Eyedropper tool
        function pickColor(r, c) {
            const pickedHex = currentGrid[r][c];
            customColor = pickedHex;
            customColorPreview.style.backgroundColor = pickedHex;
            customColorPicker.value = pickedHex;
            
            // Check if matches predefined palette
            let matched = false;
            Object.keys(COLORS).forEach(char => {
                if (COLORS[char].toLowerCase() === pickedHex.toLowerCase()) {
                    selectedColorChar = char;
                    matched = true;
                }
            });
            if (!matched) {
                selectedColorChar = null; // custom, not in preset
            }
            
            buildPalette();
            setTool('draw'); // Switch back to drawing tool
        }

        // Handle mouse click & drag events
        function handlePixelMouseDown(e, r, c) {
            // Prevent standard text dragging select
            e.preventDefault();

            // Right click acts as an Eraser
            if (e.button === 2) {
                const prevTool = currentTool;
                currentTool = 'erase';
                drawPixel(r, c);
                isDrawing = true;
                e.stopPropagation();
                // temporary mode switch
                window.addEventListener('mouseup', () => {
                    currentTool = prevTool;
                    isDrawing = false;
                    saveState();
                }, { once: true });
                return;
            }

            // Alt + Click triggers Eyedropper automatically
            if (e.altKey) {
                pickColor(r, c);
                return;
            }

            if (currentTool === 'picker') {
                pickColor(r, c);
                return;
            }

            if (currentTool === 'paint') {
                const targetColor = currentGrid[r][c];
                const replacementColor = currentTool === 'erase' ? COLORS['.'] : customColor;
                floodFill(r, c, targetColor, replacementColor);
                saveState();
                return;
            }

            // Pencil / Eraser
            isDrawing = true;
            drawPixel(r, c);
        }

        function handlePixelMouseEnter(e, r, c) {
            if (!isDrawing) return;
            drawPixel(r, c);
        }

        // Global mouseup handler to finalize canvas states
        window.addEventListener('mouseup', (e) => {
            if (isDrawing && e.button !== 2) {
                isDrawing = false;
                saveState();
            }
        });

        // Prevent Context Menu on canvas
        pixelGridEl.addEventListener('contextmenu', e => e.preventDefault());

        // Save state history for Undo/Redo
        function saveState() {
            // Convert current state to compact JSON string to save space/memory
            const stateString = JSON.stringify(currentGrid);
            
            // If it's identical to last save, skip
            if (undoStack.length > 0 && undoStack[undoStack.length - 1] === stateString) return;

            undoStack.push(stateString);
            redoStack = []; // Clear redo stack on new action
            
            // Constrain stack to 50 steps
            if (undoStack.length > 55) {
                undoStack.shift();
            }
            updateUndoRedoButtons();
        }

        function undo() {
            if (undoStack.length <= 1) return; // Keep at least the starting frame
            const current = undoStack.pop();
            redoStack.push(current);
            
            const prevState = JSON.parse(undoStack[undoStack.length - 1]);
            restoreState(prevState);
            updateUndoRedoButtons();
        }

        function redo() {
            if (redoStack.length === 0) return;
            const next = redoStack.pop();
            undoStack.push(next);
            
            const nextState = JSON.parse(next);
            restoreState(nextState);
            updateUndoRedoButtons();
        }

        function restoreState(stateGrid) {
            currentGrid = stateGrid;
            renderGrid();
        }

        function updateUndoRedoButtons() {
            undoBtn.disabled = undoStack.length <= 1;
            redoBtn.disabled = redoStack.length === 0;
        }

        // Set up event listeners for layout options
        function setupEventListeners() {
            // Undo/Redo
            undoBtn.addEventListener('click', undo);
            redoBtn.addEventListener('click', redo);
            
            // Keyboard shortcuts
            window.addEventListener('keydown', (e) => {
                if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 'z') {
                    e.preventDefault();
                    undo();
                }
                if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 'y') {
                    e.preventDefault();
                    redo();
                }
            });

            // Gridline Toggle
            toggleGrid.addEventListener('change', (e) => {
                isGridlinesOn = e.target.checked;
                renderGrid();
            });

            // Overlay Image Toggle
            toggleOverlay.addEventListener('change', (e) => {
                isOverlayOn = e.target.checked;
                if (isOverlayOn) {
                    referenceOverlay.classList.remove('opacity-0');
                    referenceOverlay.classList.add('opacity-100');
                } else {
                    referenceOverlay.classList.remove('opacity-100');
                    referenceOverlay.classList.add('opacity-0');
                }
            });

            // Zoom Controller
            zoomSlider.addEventListener('input', (e) => {
                const value = e.target.value;
                const sizePx = value * 40;
                canvasContainer.style.width = `${sizePx}px`;
                canvasContainer.style.height = `${sizePx}px`;
                zoomVal.textContent = `${sizePx}px`;
            });

            // Reset/Clear
            resetOriginalBtn.addEventListener('click', () => {
                if (confirm('Are you sure you want to reset your grid? Your current changes will be overwritten.')) {
                    loadTemplate(ORIGINAL_FROG_TEMPLATE);
                }
            });

            clearCanvasBtn.addEventListener('click', () => {
                if (confirm('This will wipe the workspace clean. Are you sure?')) {
                    const emptyTemplate = Array(40).fill(".".repeat(40));
                    loadTemplate(emptyTemplate);
                }
            });

            // Mode Selection Event Listeners
            toolDrawBtn.addEventListener('click', () => setTool('draw'));
            toolPaintBtn.addEventListener('click', () => setTool('paint'));
            toolEraseBtn.addEventListener('click', () => setTool('erase'));
            toolPickerBtn.addEventListener('click', () => setTool('picker'));

            // Custom Color Picker
            customColorPicker.addEventListener('input', (e) => {
                const val = e.target.value;
                customColor = val;
                customColorPreview.style.backgroundColor = val;
                selectedColorChar = null; // untracked
                buildPalette();
            });

            // Export Actions
            exportPngBtn.addEventListener('click', downloadPNG);
            exportCssBtn.addEventListener('click', copyCSSBoxShadow);
            copyJsonBtn.addEventListener('click', copyJSONData);
        }

        // Export as High Resolution PNG
        function downloadPNG() {
            const canvas = document.createElement('canvas');
            const pixelSize = 16; // 16px output per pixel = 640x640 resolution!
            canvas.width = 40 * pixelSize;
            canvas.height = 40 * pixelSize;
            const ctx = canvas.getContext('2d');

            for (let r = 0; r < 40; r++) {
                for (let c = 0; c < 40; c++) {
                    ctx.fillStyle = currentGrid[r][c];
                    ctx.fillRect(c * pixelSize, r * pixelSize, pixelSize, pixelSize);
                }
            }

            const dataUrl = canvas.toDataURL('image/png');
            const link = document.createElement('a');
            link.download = 'angy_frog_graduate.png';
            link.href = dataUrl;
            link.click();
        }

        // Export as pure box shadow CSS (Super cool feature!)
        function copyCSSBoxShadow() {
            let shadows = [];
            const pixelSize = 10; // 10px pixels in output HTML element
            
            for (let r = 0; r < 40; r++) {
                for (let c = 0; c < 40; c++) {
                    const color = currentGrid[r][c];
                    // Don't render shadow for transparent background pixels
                    if (color.toLowerCase() !== COLORS['.'].toLowerCase()) {
                        shadows.push(`${c * pixelSize}px ${r * pixelSize}px 0 ${color}`);
                    }
                }
            }

            const cssCode = `/* CSS code to render this Angy Frog pixel art in a single empty div element! */
.angy-frog-pixel-art {
    width: ${pixelSize}px;
    height: ${pixelSize}px;
    background: transparent;
    box-shadow: 
        ${shadows.join(',\n        ')};
}`;

            navigator.clipboard.writeText(cssCode).then(() => {
                alert('CSS Box-Shadow Art copied to clipboard! You can render this design inside a single div with no external image files!');
            }).catch(err => {
                // Clipboard fallback if API not supported in secure iframe
                const tempTextarea = document.createElement('textarea');
                tempTextarea.value = cssCode;
                document.body.appendChild(tempTextarea);
                tempTextarea.select();
                document.execCommand('copy');
                document.body.removeChild(tempTextarea);
                alert('CSS Box-Shadow Art copied to clipboard!');
            });
        }

        // Copy raw JSON array structure
        function copyJSONData() {
            const jsonString = JSON.stringify(currentGrid, null, 2);
            navigator.clipboard.writeText(jsonString).then(() => {
                alert('Raw pixel color data JSON copied to clipboard!');
            }).catch(err => {
                // Clipboard fallback
                const tempTextarea = document.createElement('textarea');
                tempTextarea.value = jsonString;
                document.body.appendChild(tempTextarea);
                tempTextarea.select();
                document.execCommand('copy');
                document.body.removeChild(tempTextarea);
                alert('Raw pixel color data JSON copied to clipboard!');
            });
        }

        // Run on Page Load
        window.onload = initApp;
    </script>
</body>
</html>
