<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Duolingo iOS Onboarding & Transition Simulator</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts for premium clean sans-serif typography resembling Feather -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:ital,wght@0,300;0,400;0,600;0,700;0,800;0,900;1,700&display=swap" rel="stylesheet">
    <style>
        :root {
            --brand-green: #58cc02;
            --brand-green-shadow: #46a302;
            --brand-orange: #ff9600;
            --brand-orange-shadow: #e27c00;
            --brand-dark: #3c3c3c;
            --brand-light-gray: #e5e5e5;
            --brand-text-gray: #777777;
            --brand-sky: #84d8ff;
            --brand-gold: #ffc800;
            --brand-purple: #8549ff;
            --brand-purple-shadow: #6633cc;
        }

        body {
            font-family: 'Nunito', sans-serif;
            background: radial-gradient(circle at top left, #121824 0%, #080b10 100%);
            color: #f3f4f6;
            overflow-x: hidden;
            min-height: 100vh;
        }

        /* Customize Scrollbars for visual refinement */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #111827;
        }
        ::-webkit-scrollbar-thumb {
            background: #374151;
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #4b5563;
        }

        .ios-device-frame {
            box-shadow: 
                0 0 0 12px #22252a, 
                0 0 0 13px #333842,
                0 25px 50px -12px rgba(0, 0, 0, 0.8);
            border-radius: 48px;
            transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        /* 3D Tactile Button styling classes */
        .tactile-button-green {
            background-color: var(--brand-green);
            box-shadow: 0 4px 0 0 var(--brand-green-shadow);
            transform: translateY(0);
            transition: transform 0.1s ease, box-shadow 0.1s ease;
        }
        .tactile-button-green:active {
            transform: translateY(4px);
            box-shadow: 0 0px 0 0 var(--brand-green-shadow);
        }

        .tactile-button-white {
            background-color: #ffffff;
            color: var(--brand-green);
            box-shadow: 0 4px 0 0 var(--brand-light-gray);
            border: 2px solid var(--brand-light-gray);
            transform: translateY(0);
            transition: transform 0.1s ease, box-shadow 0.1s ease;
        }
        .tactile-button-white:active {
            transform: translateY(4px);
            box-shadow: 0 0px 0 0 var(--brand-light-gray);
        }

        .tactile-button-purple {
            background-color: var(--brand-purple);
            box-shadow: 0 4px 0 0 var(--brand-purple-shadow);
            transform: translateY(0);
            transition: transform 0.1s ease, box-shadow 0.1s ease;
        }
        .tactile-button-purple:active {
            transform: translateY(4px);
            box-shadow: 0 0px 0 0 var(--brand-purple-shadow);
        }

        /* Simulated notch and curves of an iOS iPhone 15 Pro */
        .dynamic-island {
            width: 110px;
            height: 30px;
            background-color: #000000;
            border-radius: 15px;
            left: 50%;
            transform: translateX(-50%);
            top: 12px;
            z-index: 100;
            box-shadow: inset 0 0 2px rgba(255,255,255,0.1);
        }

        @keyframes float-breathing {
            0%, 100% { transform: translateY(0px) scaleY(1); }
            50% { transform: translateY(-4px) scaleY(1.02); }
        }

        .breathing-character {
            animation: float-breathing 4s ease-in-out infinite;
            transform-origin: bottom center;
        }

        @keyframes wing-flutter {
            0%, 100% { transform: rotate(0deg); }
            50% { transform: rotate(5deg); }
        }

        .animated-wing-left {
            animation: wing-flutter 4s ease-in-out infinite;
            transform-origin: top right;
        }

        .animated-wing-right {
            animation: wing-flutter 4s ease-in-out infinite;
            transform-origin: top left;
        }

        /* Interactive workshop active indicators */
        .status-dot {
            width: 8px;
            height: 8px;
            background-color: #ef4444;
            border-radius: 50%;
            display: inline-block;
        }
        .status-dot.active {
            background-color: #10b981;
            box-shadow: 0 0 8px #10b981;
        }

        /* Smooth curtain morph animation */
        #curtain-container {
            pointer-events: none;
        }
    </style>
</head>
<body class="p-2 sm:p-6 lg:p-12 flex flex-col justify-between items-center min-h-screen">

    <header class="w-full max-w-7xl mx-auto flex flex-col sm:flex-row justify-between items-center mb-8 gap-4 border-b border-gray-800 pb-4">
        <div>
            <div class="flex items-center gap-2">
                <span class="bg-green-500 text-black text-xs font-black px-2 py-0.5 rounded-md uppercase tracking-wide">VIDEO SIMULATOR</span>
                <h1 class="text-2xl font-black tracking-tight text-white">DUOLINGO ONBOARDING RIG</h1>
            </div>
            <p class="text-xs text-gray-400 mt-1">
                An exact functional recreation of file <span class="text-yellow-400 font-mono text-xs">20260530-1008-52.3564187.mp4</span> containing micro-interactions and vector morphs.
            </p>
        </div>
        <div class="flex items-center gap-3">
            <button onclick="enableAudioAndWarmup()" id="audio-enable-btn" class="bg-yellow-500 hover:bg-yellow-400 text-black font-extrabold text-xs px-4 py-2 rounded-lg flex items-center gap-2 shadow-lg transition-transform active:scale-95">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z" /></svg>
                ACTIVATE UI SOUNDS
            </button>
            <span class="text-xs text-gray-500 hidden md:block">Time State: <span id="master-clock" class="text-gray-300 font-mono">15:40:24</span></span>
        </div>
    </header>

    <main class="w-full max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-8 items-start flex-grow">
        
        <!-- Left Sidebar: Interaction Workshop Console (5 Cols) -->
        <section class="lg:col-span-5 flex flex-col gap-6 bg-gray-950/80 backdrop-blur-md p-6 rounded-3xl border border-gray-800/80 shadow-2xl">
            <div>
                <h2 class="text-lg font-black text-white flex items-center gap-2">
                    <span class="flex h-2.5 w-2.5 relative">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-green-500"></span>
                    </span>
                    Director Playback Panel
                </h2>
                <p class="text-xs text-gray-400">Control the precise phases of the target launch sequence.</p>
            </div>

            <div class="bg-gray-900/60 p-4 rounded-2xl border border-gray-800">
                <div class="flex justify-between items-center mb-2">
                    <span class="text-xs font-bold text-gray-300">VIDEO STATE TIMELINE</span>
                    <span id="timeline-progress-txt" class="text-xs font-mono font-black text-green-400">0.0s (Splash Phase)</span>
                </div>
                <!-- Interactive timeline slider that binds to the simulation states -->
                <input type="range" id="state-timeline" min="0" max="11" step="0.1" value="0" class="w-full accent-green-500 bg-gray-800 h-2 rounded-lg cursor-pointer">
                <div class="flex justify-between text-[10px] text-gray-500 font-mono mt-1">
                    <span>0s (Splash)</span>
                    <span>3s (Blink)</span>
                    <span>6s (Morph)</span>
                    <span>7s+ (Onboard)</span>
                </div>
                
                <div class="grid grid-cols-2 gap-2 mt-4">
                    <button onclick="triggerMacroPhase('splash')" class="bg-gray-800 hover:bg-gray-700 text-white text-xs py-2 px-3 rounded-lg font-bold transition-all flex items-center justify-center gap-2">
                        <div class="w-2 h-2 rounded-full bg-blue-500"></div> Splash State (0s)
                    </button>
                    <button onclick="triggerMacroPhase('blink')" class="bg-gray-800 hover:bg-gray-700 text-white text-xs py-2 px-3 rounded-lg font-bold transition-all flex items-center justify-center gap-2">
                        <div class="w-2 h-2 rounded-full bg-yellow-500"></div> Double Blink (3s)
                    </button>
                    <button onclick="triggerMacroPhase('morph')" class="bg-gray-800 hover:bg-gray-700 text-white text-xs py-2 px-3 rounded-lg font-bold transition-all flex items-center justify-center gap-2">
                        <div class="w-2 h-2 rounded-full bg-purple-500"></div> Dynamic Morph (6s)
                    </button>
                    <button onclick="triggerMacroPhase('onboarding')" class="bg-gray-800 hover:bg-gray-700 text-white text-xs py-2 px-3 rounded-lg font-bold transition-all flex items-center justify-center gap-2">
                        <div class="w-2 h-2 rounded-full bg-green-500"></div> Onboarding (7s+)
                    </button>
                </div>

                <div class="mt-4 pt-4 border-t border-gray-800 flex justify-between items-center">
                    <button onclick="autoPlaySimulation()" id="autoplay-btn" class="w-full bg-green-500 hover:bg-green-400 text-black font-extrabold text-sm py-2.5 px-4 rounded-xl shadow-lg transition-transform active:scale-95 flex items-center justify-center gap-2">
                        <svg id="play-icon" xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 fill-current" viewBox="0 0 20 20"><path d="M4.5 3a.5.5 0 00-.5.5v13a.5.5 0 00.757.429l11-6.5a.5.5 0 000-.858l-11-6.5a.5.5 0 00-.257-.071z"/></svg>
                        PLAY SEQUENTIAL VIDEO LOOP
                    </button>
                </div>
            </div>

            <div class="bg-gray-900/60 p-4 rounded-2xl border border-gray-800 flex flex-col gap-3">
                <span class="text-xs font-bold text-gray-300">CHARACTER EMOTION CONTROLLER (Duo the Owl)</span>
                <div class="grid grid-cols-3 gap-2">
                    <button onclick="changeDuoState('neutral')" class="btn-emotion bg-gray-800 text-gray-300 text-xs py-1.5 px-2 rounded-lg font-bold hover:bg-gray-700 active:scale-95 transition-all">Neutral</button>
                    <button onclick="changeDuoState('happy')" class="btn-emotion bg-gray-800 text-gray-300 text-xs py-1.5 px-2 rounded-lg font-bold hover:bg-gray-700 active:scale-95 transition-all">Excited</button>
                    <button onclick="changeDuoState('wink')" class="btn-emotion bg-gray-800 text-gray-300 text-xs py-1.5 px-2 rounded-lg font-bold hover:bg-gray-700 active:scale-95 transition-all">Playful Wink</button>
                    <button onclick="changeDuoState('shocked')" class="btn-emotion bg-gray-800 text-gray-300 text-xs py-1.5 px-2 rounded-lg font-bold hover:bg-gray-700 active:scale-95 transition-all">Shocked</button>
                    <button onclick="changeDuoState('blink')" class="btn-emotion bg-gray-800 text-gray-300 text-xs py-1.5 px-2 rounded-lg font-bold hover:bg-gray-700 active:scale-95 transition-all">Blink</button>
                    <button onclick="changeDuoState('sleepy')" class="btn-emotion bg-gray-800 text-gray-300 text-xs py-1.5 px-2 rounded-lg font-bold hover:bg-gray-700 active:scale-95 transition-all">Sleepy</button>
                </div>
                <div class="flex items-center gap-2 mt-2">
                    <input type="checkbox" id="breathing-toggle" checked class="rounded bg-gray-800 border-gray-700 text-green-500 focus:ring-green-500 w-4 h-4">
                    <label for="breathing-toggle" class="text-xs text-gray-400 select-none cursor-pointer">Enable character physics and idling breaths</label>
                </div>
            </div>

            <div class="bg-gray-900/60 p-4 rounded-2xl border border-gray-800">
                <span class="text-xs font-bold text-gray-300 block mb-3">SYSTEM BRAND STYLING THEMES</span>
                <div class="grid grid-cols-2 gap-2">
                    <button onclick="setSystemTheme('classic')" class="flex items-center gap-2 p-2 bg-gray-800 hover:bg-gray-700 rounded-lg text-xs font-bold border-2 border-green-500">
                        <span class="w-3.5 h-3.5 rounded-full bg-green-500 border border-white"></span>
                        Classic Green
                    </button>
                    <button onclick="setSystemTheme('super')" class="flex items-center gap-2 p-2 bg-gray-800 hover:bg-gray-700 rounded-lg text-xs font-bold border-2 border-transparent" id="theme-super-btn">
                        <span class="w-3.5 h-3.5 rounded-full bg-indigo-600 border border-white"></span>
                        Super Purple
                    </button>
                </div>
            </div>

            <div class="bg-gray-950/80 p-3 rounded-2xl border border-gray-800 font-mono text-[10px] text-gray-400 flex flex-col gap-1.5">
                <div class="flex justify-between text-gray-500 border-b border-gray-800 pb-1 mb-1">
                    <span>TELEMETRY VISUAL LOG</span>
                    <span id="tel-status" class="text-green-400">CONNECTING</span>
                </div>
                <div class="h-28 overflow-y-auto flex flex-col gap-1 pr-1" id="log-console">
                    <div>[00:00:00] Initializing simulation assets...</div>
                    <div>[00:00:01] Preloading vector maps and Bezier calculations...</div>
                    <div>[00:00:01] Binding canvas elements...</div>
                </div>
            </div>
        </section>

        <!-- Right / Center: iOS Simulated Device Box Frame (7 Cols) -->
        <section class="lg:col-span-7 flex justify-center items-center">
            
            <!-- Real-size interactive dynamic container imitating iPhone 15 Pro aspect ratio -->
            <div class="ios-device-frame relative w-[375px] h-[812px] bg-white overflow-hidden select-none select-none flex flex-col justify-between">
                
                <div class="absolute top-0 inset-x-0 h-11 flex justify-between items-center px-6 z-50 text-white font-semibold transition-colors duration-300" id="ios-status-bar">
                    <span class="text-xs font-bold tracking-tight">9:41</span>
                    
                    <!-- Apple Dynamic Island Container -->
                    <div class="dynamic-island absolute"></div>

                    <div class="flex items-center gap-1.5">
                        <!-- Cellular Bars -->
                        <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24">
                            <rect x="2" y="18" width="2" height="4" rx="0.5" />
                            <rect x="6" y="14" width="2" height="8" rx="0.5" />
                            <rect x="10" y="10" width="2" height="12" rx="0.5" />
                            <rect x="14" y="6" width="2" height="16" rx="0.5" />
                            <rect x="18" y="2" width="2" height="20" rx="0.5" />
                        </svg>
                        <!-- Wifi Icon -->
                        <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24">
                            <path d="M12 21a2 2 0 1 1 0-4 2 2 0 0 1 0 4zm0-6a6 6 0 0 1 6-6 1 1 0 1 1 0 2 4 4 0 0 0-4 4 1 1 0 1 1-2 0zm0-6a10 10 0 0 1 10-10 1 1 0 1 1 0 2 8 8 0 0 0-8 8 1 1 0 1 1-2 0z" />
                        </svg>
                        <!-- Battery Terminal -->
                        <div class="w-6 h-3 border border-current rounded-sm p-0.5 flex items-center relative">
                            <div class="bg-current h-full w-4/5 rounded-2xs"></div>
                            <div class="w-0.5 h-1 bg-current absolute -right-1 top-0.5 rounded-r-sm"></div>
                        </div>
                    </div>
                </div>

                <div class="absolute inset-0 z-40 bg-[var(--brand-green)] flex flex-col justify-between py-16 items-center transition-all duration-300" id="splash-view">
                    
                    <!-- Empty spacer to align items perfectly -->
                    <div></div>

                    <!-- Duo's minimalist face vector asset (0:00 to 0:06) -->
                    <div class="relative w-48 h-48 flex justify-center items-center cursor-pointer" id="splash-face-zone">
                        <svg class="w-full h-full" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <!-- Eyebrow Shadows/Patches -->
                            <path id="eyebrow-left" d="M 40 50 C 50 42, 70 42, 85 55 C 80 58, 60 58, 40 50 Z" fill="#388002" />
                            <path id="eyebrow-right" d="M 160 50 C 150 42, 130 42, 115 55 C 120 58, 140 58, 160 50 Z" fill="#388002" />
                            
                            <!-- Duo Giant Eyes Sockets -->
                            <g id="splash-eyes-group">
                                <!-- Left Eye White -->
                                <ellipse id="splash-eye-left" cx="68" cy="85" rx="30" ry="30" fill="white" transform-origin="68 85" class="transition-transform duration-100" />
                                <!-- Right Eye White -->
                                <ellipse id="splash-eye-right" cx="132" cy="85" rx="30" ry="30" fill="white" transform-origin="132 85" class="transition-transform duration-100" />
                                
                                <!-- Left Pupil -->
                                <circle id="splash-pupil-left" cx="72" cy="82" r="9" fill="black" transform-origin="68 85" />
                                <!-- Right Pupil -->
                                <circle id="splash-pupil-right" cx="128" cy="82" r="9" fill="black" transform-origin="132 85" />
                            </g>

                            <!-- Duo Splash Triangular Beak -->
                            <path id="splash-beak" d="M 100 88 L 112 108 C 112 108, 100 114, 88 108 Z" fill="var(--brand-orange)" />
                        </svg>
                    </div>

                    <!-- Duolingo lowercase logo typography at splash bottom -->
                    <div class="w-full flex justify-center items-center pb-8" id="splash-logo-container">
                        <svg class="w-32 h-8" viewBox="0 0 156 36" fill="white" xmlns="http://www.w3.org/2000/svg">
                            <!-- High precision hand-rendered typography paths matching Feather wordmark -->
                            <path d="M12.4 1.3c6 0 10.9 4.3 10.9 10.8v11.6c0 6.5-4.9 10.8-10.9 10.8H1.3V1.3h11.1zm-1.5 6.2H7.5v20h3.4c2.8 0 4.7-1.8 4.7-4.6V12.1c0-2.8-1.9-4.6-4.7-4.6z" />
                            <path d="M37.5 11.2c5.3 0 8.8 3.5 8.8 8.4v14.9h-6.2v-14c0-2.2-1.3-3.6-3.4-3.6s-3.7 1.4-3.7 3.6v14h-6.2V11.7h6.2v2.3c1.1-1.7 2.8-2.8 4.5-2.8z" />
                            <path d="M62.1 11.2c5.6 0 9.8 4.3 9.8 11.5v11.8h-6.2v-11c0-3.3-1.8-5.7-4.7-5.7s-4.8 2.4-4.8 5.7v11h-6.2V11.2h6.2v2.4c1.1-1.8 3.1-2.8 5.9-2.8z" />
                            <path d="M84.5 11.2c6.2 0 10.5 4.6 10.5 11.4s-4.3 11.4-10.5 11.4-10.5-4.6-10.5-11.4 4.3-11.4 10.5-11.4zm0 5.4c-2.9 0-4.3 2.4-4.3 6s1.4 6 4.3 6 4.3-2.4 4.3-6-1.4-6-4.3-6z" />
                            <path d="M103.2 1.3h6.2v33.2h-6.2V1.3z" />
                            <path d="M117.8 1.9c1.9 0 3.3 1.4 3.3 3.3s-1.4 3.3-3.3 3.3-3.3-1.4-3.3-3.3 1.4-3.3 3.3-3.3zm-3.1 9.3h6.2v23.3h-6.2V11.2z" />
                            <path d="M136.2 11.2c5.6 0 9.8 4.3 9.8 11.5v11.8h-6.2v-11c0-3.3-1.8-5.7-4.7-5.7s-4.8 2.4-4.8 5.7v11h-6.2V11.2h6.2v2.4c1.1-1.8 3.1-2.8 5.9-2.8z" />
                            <path d="M153.5 11.2c4.1 0 7.2 2 8.4 5.3l-5.6 2.3c-.6-1.2-1.5-1.9-2.8-1.9-1.9 0-3.1 1.4-3.1 3.6s1.2 3.6 3.1 3.6c1.3 0 2.2-.7 2.8-1.9l5.6 2.3c-1.2 3.3-4.3 5.3-8.4 5.3-6.2 0-10.5-4.6-10.5-11.4s4.3-11.4 10.5-11.4z" />
                        </svg>
                    </div>
                </div>

                <div class="absolute inset-0 z-45" id="curtain-container">
                    <svg class="w-full h-full" id="morphing-svg" viewBox="0 0 375 812" preserveAspectRatio="none">
                        <!-- Morphing path clipped with curves -->
                        <path id="morphing-curtain" d="M 0 0 L 375 0 L 375 812 Q 187.5 812 0 812 Z" fill="var(--brand-green)" />
                    </svg>
                </div>

                <div class="flex-grow flex flex-col justify-between py-12 items-center px-6 bg-white z-10 h-full w-full" id="onboard-view">
                    
                    <!-- Decorative Spacer representing top curves after scroll -->
                    <div class="w-full h-4 mt-4"></div>

                    <!-- Complete full-body Vector Asset of Duo the Owl with Breathing Idles -->
                    <div class="w-52 h-52 flex items-center justify-center relative breathing-character" id="onboard-character-holder">
                        <svg class="w-full h-full" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <!-- Background shadow depth -->
                            <ellipse cx="100" cy="180" rx="45" ry="8" fill="#e5e7eb" />
                            
                            <!-- Duo Body -->
                            <path d="M 50 130 C 50 60, 150 60, 150 130 C 150 165, 130 178, 100 178 C 70 178, 50 165, 50 130 Z" fill="var(--brand-green)" id="duo-body-main" />
                            
                            <!-- Lighter Green Belly Cover Shape -->
                            <path d="M 64 125 C 64 85, 136 85, 136 125 C 136 155, 118 168, 100 168 C 82 168, 64 155, 64 125 Z" fill="#78D61A" id="duo-belly" />
                            
                            <!-- Duo Full Wings Left and Right -->
                            <!-- Animated Wing Left -->
                            <path class="animated-wing-left" d="M 51 92 C 32 105, 34 135, 54 140 C 55 130, 52 110, 51 92 Z" fill="#46A302" id="duo-wing-l" />
                            <!-- Animated Wing Right -->
                            <path class="animated-wing-right" d="M 149 92 C 168 105, 166 135, 146 140 C 145 130, 148 110, 149 92 Z" fill="#46A302" id="duo-wing-r" />

                            <!-- Chest Feathers (V-shapes) -->
                            <path d="M 85 110 L 92 116 L 85 122" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
                            <path d="M 100 115 L 107 121 L 100 127" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
                            <path d="M 115 110 L 122 116 L 115 122" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />

                            <!-- Duo Big Eyes -->
                            <ellipse cx="73" cy="92" rx="22" ry="22" fill="white" id="main-eye-l" />
                            <ellipse cx="127" cy="92" rx="22" ry="22" fill="white" id="main-eye-r" />
                            
                            <!-- Black Pupils (Look slightly up-right like original video) -->
                            <circle cx="76" cy="90" r="7" fill="black" id="main-pupil-l" />
                            <circle cx="124" cy="90" r="7" fill="black" id="main-pupil-r" />
                            
                            <!-- Gloss shine over pupils -->
                            <circle cx="74" cy="87" r="2" fill="white" id="pupil-shine-l" />
                            <circle cx="122" cy="87" r="2" fill="white" id="pupil-shine-r" />
                            
                            <!-- Eyebrows / Feathers -->
