    <script>
        let audioCtx = null;

        // Custom chime node constructor
        function playChime(type) {
            if (!audioCtx) return;
            
            // Re-activate context if suspended by browser security
            if (audioCtx.state === 'suspended') {
                audioCtx.resume();
            }

            const now = audioCtx.currentTime;

            if (type === 'success') {
                // Classic Duolingo "ding-ding" success major sound
                const o1 = audioCtx.createOscillator();
                const o2 = audioCtx.createOscillator();
                const gain = audioCtx.createGain();

                o1.type = 'sine';
                o2.type = 'triangle';

                // Two-tone rising chord transition
                o1.frequency.setValueAtTime(523.25, now); // C5
                o1.frequency.setValueAtTime(659.25, now + 0.15); // E5
                o1.frequency.setValueAtTime(783.99, now + 0.3); // G5
                o1.frequency.setValueAtTime(1046.50, now + 0.45); // C6

                o2.frequency.setValueAtTime(261.63, now); // C4
                o2.frequency.setValueAtTime(329.63, now + 0.15); // E4
                o2.frequency.setValueAtTime(392.00, now + 0.3); // G4

                gain.gain.setValueAtTime(0.3, now);
                gain.gain.exponentialRampToValueAtTime(0.001, now + 1.2);

                o1.connect(gain);
                o2.connect(gain);
                gain.connect(audioCtx.destination);

                o1.start(now);
                o2.start(now);
                o1.stop(now + 1.2);
                o2.stop(now + 1.2);

            } else if (type === 'click') {
                // Quick woodblock-like tap click for tactile button simulation
                const osc = audioCtx.createOscillator();
                const gain = audioCtx.createGain();

                osc.type = 'triangle';
                osc.frequency.setValueAtTime(800, now);
                osc.frequency.exponentialRampToValueAtTime(150, now + 0.08);

                gain.gain.setValueAtTime(0.15, now);
                gain.gain.exponentialRampToValueAtTime(0.001, now + 0.08);

                osc.connect(gain);
                gain.connect(audioCtx.destination);

                osc.start(now);
                osc.stop(now + 0.08);

            } else if (type === 'blink') {
                // Cute bubbly sound for the blink movement
                const osc = audioCtx.createOscillator();
                const gain = audioCtx.createGain();

                osc.type = 'sine';
                osc.frequency.setValueAtTime(600, now);
                osc.frequency.exponentialRampToValueAtTime(900, now + 0.12);

                gain.gain.setValueAtTime(0.1, now);
                gain.gain.exponentialRampToValueAtTime(0.001, now + 0.12);

                osc.connect(gain);
                gain.connect(audioCtx.destination);

                osc.start(now);
                osc.stop(now + 0.12);
            }
        }

        function enableAudioAndWarmup() {
            try {
                window.AudioContext = window.AudioContext || window.webkitAudioContext;
                audioCtx = new AudioContext();
                playChime('success');
                
                const btn = document.getElementById('audio-enable-btn');
                btn.innerHTML = `
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                    SOUNDS ENABLED!
                `;
                btn.classList.remove('bg-yellow-500');
                btn.classList.add('bg-emerald-600', 'text-white');
                logToConsole("Web Audio initialized and ready.");
            } catch (e) {
                console.warn("Web Audio API not supported", e);
            }
        }

        const SIM_STATES = {
            currentTime: 0,
            activeTheme: 'classic',
            autoplayActive: false,
            autoplayInterval: null
        };

        // UI Element Selectors
        const timeline = document.getElementById('state-timeline');
        const timelineTxt = document.getElementById('timeline-progress-txt');
        const splashView = document.getElementById('splash-view');
        const iosStatusBar = document.getElementById('ios-status-bar');
        const morphingCurtain = document.getElementById('morphing-curtain');
        const morphingSvg = document.getElementById('morphing-svg');
        const logConsole = document.getElementById('log-console');

        // Dynamic log visualizer
        function logToConsole(message) {
            const timeStr = new Date().toLocaleTimeString();
            const logItem = document.createElement('div');
            logItem.innerHTML = `<span class="text-gray-600">[${timeStr}]</span> ${message}`;
            logConsole.appendChild(logItem);
            logConsole.scrollTop = logConsole.scrollHeight;
        }

        function updateTimeline(val) {
            SIM_STATES.currentTime = parseFloat(val);
            timeline.value = val;

            // Display time formatting
            timelineTxt.innerText = `${SIM_STATES.currentTime.toFixed(1)}s`;

            // Phase tracking logic
            if (SIM_STATES.currentTime < 3) {
                // Neutral Splash
                setSplashOpacity(1);
                applyInteractiveBlink(1, 1);
                setStatusBarColor('white');
                timelineTxt.innerText += " (Splash Phase)";
            } 
            else if (SIM_STATES.currentTime >= 3 && SIM_STATES.currentTime < 6) {
                // Double blink triggers around 3s in original clip
                setSplashOpacity(1);
                setStatusBarColor('white');
                
                // Emulate precise double-blink pattern dynamically
                const subProgress = SIM_STATES.currentTime - 3;
                if ((subProgress > 0.1 && subProgress < 0.4) || (subProgress > 0.8 && subProgress < 1.1)) {
                    applyInteractiveBlink(0.08, 0.08); // Eyes closed
                    setEyebrowCurve(true);
                } else {
                    applyInteractiveBlink(1, 1); // Open
                    setEyebrowCurve(false);
                }
                timelineTxt.innerText += " (Blink Action)";
            } 
            else if (SIM_STATES.currentTime >= 6 && SIM_STATES.currentTime < 7) {
                // The morphing curtain sliding upwards (at 0:06 to 0:07)
                setSplashOpacity(0);
                setStatusBarColor('black');
                
                // Calculating the curve transformation mechanics
                const transitionProgress = SIM_STATES.currentTime - 6; // Range: 0 to 1
                renderMorphingTransition(transitionProgress);
                timelineTxt.innerText += " (Morph Curtain)";
            } 
            else if (SIM_STATES.currentTime >= 7) {
                // Standard Onboarding dashboard (0:07 to 0:11)
                setSplashOpacity(0);
                setStatusBarColor('black');
                renderMorphingTransition(1); // fully retracted
                timelineTxt.innerText += " (Onboarding Ready)";
            }
        }

        function triggerMacroPhase(phase) {
            if (phase === 'splash') {
                updateTimeline(0);
                logToConsole("State set to Splash Landing (0s).");
            } else if (phase === 'blink') {
                updateTimeline(3.2);
                playChime('blink');
                logToConsole("State set to Dual-eye Blink action (3s).");
            } else if (phase === 'morph') {
                updateTimeline(6.4);
                logToConsole("State set to Splash Transition Pull-up (6s).");
            } else if (phase === 'onboarding') {
                updateTimeline(8);
                playChime('success');
                logToConsole("State set to Interactive Onboarding Panel (7s+).");
            }
        }

        function renderMorphingTransition(progress) {
            // progress ranges from 0 (curtain fully closed) to 1 (curtain fully offscreen)
            // Curtain height logic
            const width = 375;
            const height = 812;
            
            // Linear height retraction calculation
            const Y = height * (1 - progress); 
            
            // At early pull up, pull the center of the curve upward aggressively creating a concave curve
            // Curve amount reaches maximum deflection at 30% progress, then flattens out
            let curveAmount = 0;
            if (progress > 0 && progress < 0.9) {
                curveAmount = -80 * Math.sin(progress * Math.PI);
            }
            
            const controlPointY = Y + curveAmount;
            
            // Generate standard SVG path instruction coordinates
            const pathData = `M 0 0 L ${width} 0 L ${width} ${Y} Q ${width/2} ${controlPointY} 0 ${Y} Z`;
            
            morphingCurtain.setAttribute('d', pathData);

            if (progress >= 1) {
                morphingSvg.classList.add('hidden');
            } else {
                morphingSvg.classList.remove('hidden');
            }
        }

        function setSplashOpacity(opacity) {
            splashView.style.opacity = opacity;
            if (opacity === 0) {
                splashView.classList.add('pointer-events-none');
            } else {
                splashView.classList.remove('pointer-events-none');
            }
        }

        function setStatusBarColor(color) {
            if (color === 'white') {
                iosStatusBar.classList.remove('text-brand-dark');
                iosStatusBar.classList.add('text-white');
            } else {
                iosStatusBar.classList.remove('text-white');
                iosStatusBar.classList.add('text-brand-dark');
            }
        }

        function applyInteractiveBlink(scaleY_l, scaleY_r) {
            const leftEye = document.getElementById('splash-eye-left');
            const rightEye = document.getElementById('splash-eye-right');
            const leftPupil = document.getElementById('splash-pupil-left');
            const rightPupil = document.getElementById('splash-pupil-right');

            leftEye.style.transform = `scaleY(${scaleY_l})`;
            rightEye.style.transform = `scaleY(${scaleY_r})`;

            if (scaleY_l < 0.2) {
                leftPupil.setAttribute('fill-opacity', '0');
            } else {
                leftPupil.setAttribute('fill-opacity', '1');
            }

            if (scaleY_r < 0.2) {
                rightPupil.setAttribute('fill-opacity', '0');
            } else {
                rightPupil.setAttribute('fill-opacity', '1');
            }
        }

        function setEyebrowCurve(curved) {
            const ebL = document.getElementById('eyebrow-left');
            const ebR = document.getElementById('eyebrow-right');
            if (curved) {
                ebL.setAttribute('d', "M 40 54 C 50 49, 70 49, 85 59 C 80 62, 60 62, 40 54 Z");
                ebR.setAttribute('d', "M 160 54 C 150 49, 130 49, 115 59 C 120 62, 140 62, 160 54 Z");
            } else {
                ebL.setAttribute('d', "M 40 50 C 50 42, 70 42, 85 55 C 80 58, 60 58, 40 50 Z");
                ebR.setAttribute('d', "M 160 50 C 150 42, 130 42, 115 55 C 120 58, 140 58, 160 50 Z");
            }
        }

        timeline.addEventListener('input', (e) => {
            updateTimeline(e.target.value);
            // Stop loop if manual sliding occurs
            if (SIM_STATES.autoplayActive) {
                toggleLoopOff();
            }
        });

        // Autoplay sequence controller
        function autoPlaySimulation() {
            if (SIM_STATES.autoplayActive) {
                toggleLoopOff();
                return;
            }

            SIM_STATES.autoplayActive = true;
            document.getElementById('autoplay-btn').innerHTML = `
                <svg id="pause-icon" xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 fill-current animate-pulse" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zM7 8a1 1 0 012 0v4a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v4a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
                PAUSE INTRO SEQUENCE LOOP
            `;
            document.getElementById('autoplay-btn').classList.remove('bg-green-500');
            document.getElementById('autoplay-btn').classList.add('bg-red-500', 'text-white');
            logToConsole("Starting sequential automatic loop playback...");

            // Reset sequence
            updateTimeline(0);

            SIM_STATES.autoplayInterval = setInterval(() => {
                let current = SIM_STATES.currentTime;
                current += 0.1;
                
                if (current > 11) {
                    current = 0; // seamless reset loop
                    logToConsole("Sequence complete. Resetting to splash...");
                }

                updateTimeline(current);
            }, 100);
        }

        function toggleLoopOff() {
            SIM_STATES.autoplayActive = false;
            clearInterval(SIM_STATES.autoplayInterval);
            document.getElementById('autoplay-btn').innerHTML = `
                <svg id="play-icon" xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 fill-current" viewBox="0 0 20 20"><path d="M4.5 3a.5.5 0 00-.5.5v13a.5.5 0 00.757.429l11-6.5a.5.5 0 000-.858l-11-6.5a.5.5 0 00-.257-.071z"/></svg>
                PLAY SEQUENTIAL VIDEO LOOP
            `;
            document.getElementById('autoplay-btn').classList.remove('bg-red-500', 'text-white');
            document.getElementById('autoplay-btn').classList.add('bg-green-500', 'text-black');
            logToConsole("Loop playback suspended.");
        }

        function changeDuoState(emotion) {
            // Get all primary asset nodes
            const mainBody = document.getElementById('duo-body-main');
            const mainEyeL = document.getElementById('main-eye-l');
            const mainEyeR = document.getElementById('main-eye-r');
            const pupilL = document.getElementById('main-pupil-l');
            const pupilR = document.getElementById('main-pupil-r');
            const eyebrowL = document.getElementById('main-eyebrow-l');
            const eyebrowR = document.getElementById('main-eyebrow-r');
            const beak = document.getElementById('main-beak');
            const blushL = document.getElementById('cheek-blush-l');
            const blushR = document.getElementById('cheek-blush-r');

            // Reset everything to default base properties
            mainEyeL.setAttribute('rx', '22'); mainEyeL.setAttribute('ry', '22');
            mainEyeR.setAttribute('rx', '22'); mainEyeR.setAttribute('ry', '22');
            pupilL.setAttribute('r', '7'); pupilL.setAttribute('cx', '76'); pupilL.setAttribute('cy', '90');
            pupilR.setAttribute('r', '7'); pupilR.setAttribute('cx', '124'); pupilR.setAttribute('cy', '90');
            eyebrowL.setAttribute('d', "M 45 68 C 55 60, 70 60, 80 72");
            eyebrowR.setAttribute('d', "M 155 68 C 145 60, 130 60, 120 72");
            beak.setAttribute('d', "M 100 95 L 110 110 C 110 110, 100 115, 90 110 Z");
            blushL.setAttribute('fill-opacity', '0');
            blushR.setAttribute('fill-opacity', '0');

            logToConsole(`Adjusting Duo character model to emote: [${emotion.toUpperCase()}]`);

            switch(emotion) {
                case 'happy':
                    // Inverted joyous arches
                    mainEyeL.setAttribute('ry', '4');
                    mainEyeR.setAttribute('ry', '4');
                    eyebrowL.setAttribute('d', "M 45 60 C 55 52, 70 52, 80 64");
                    eyebrowR.setAttribute('d', "M 155 60 C 145 52, 130 52, 120 64");
                    blushL.setAttribute('fill-opacity', '0.6');
                    blushR.setAttribute('fill-opacity', '0.6');
                    beak.setAttribute('d', "M 100 95 L 112 114 C 112 114, 100 120, 88 114 Z"); // smiling beak
                    playChime('success');
                    break;
                case 'wink':
                    // Wink right eye
                    mainEyeR.setAttribute('ry', '2');
                    eyebrowR.setAttribute('d', "M 155 64 C 145 58, 130 58, 120 66");
                    blushL.setAttribute('fill-opacity', '0.4');
                    playChime('blink');
                    break;
                case 'shocked':
                    // Tiny pupils, gigantic open beak
                    pupilL.setAttribute('r', '3');
                    pupilR.setAttribute('r', '3');
                    eyebrowL.setAttribute('d', "M 45 62 C 55 52, 70 52, 80 62");
                    eyebrowR.setAttribute('d', "M 155 62 C 145 52, 130 52, 120 62");
                    beak.setAttribute('d', "M 100 95 L 112 115 C 112 122, 100 126, 88 115 Z"); // Open gaping beak
                    break;
                case 'blink':
                    mainEyeL.setAttribute('ry', '2');
                    mainEyeR.setAttribute('ry', '2');
                    playChime('blink');
                    break;
                case 'sleepy':
                    eyebrowL.setAttribute('d', "M 45 74 C 55 78, 70 78, 80 74");
                    eyebrowR.setAttribute('d', "M 155 74 C 145 78, 130 78, 120 74");
                    pupilL.setAttribute('cy', '94');
                    pupilR.setAttribute('cy', '94');
                    break;
                case 'neutral':
                default:
                    // default state
                    break;
            }
        }

        // Idle character physics toggle
        document.getElementById('breathing-toggle').addEventListener('change', (e) => {
            const holder = document.getElementById('onboard-character-holder');
            if (e.target.checked) {
                holder.classList.add('breathing-character');
                logToConsole("Breathing simulation enabled.");
            } else {
                holder.classList.remove('breathing-character');
                logToConsole("Breathing simulation suspended.");
            }
        });

        function handleButtonClick(action) {
            playChime('click');
            if (action === 'get_started') {
                logToConsole("Action detected: Triggered onboarding 'GET STARTED' registration sequence.");
                // Celebrate with micro-jump of Duo
                const holder = document.getElementById('onboard-character-holder');
                holder.classList.remove('breathing-character');
                holder.style.transform = 'translateY(-20px) scale(1.05)';
                setTimeout(() => {
                    holder.style.transform = 'translateY(0) scale(1)';
                    if (document.getElementById('breathing-toggle').checked) {
                        holder.classList.add('breathing-character');
                    }
                }, 300);
            } else if (action === 'have_account') {
                logToConsole("Action detected: Triggered secondary account login navigation.");
            }
        }

        // Interactive Face Tap Event inside splash screen
        document.getElementById('splash-face-zone').addEventListener('click', () => {
            playChime('blink');
            applyInteractiveBlink(0.08, 0.08);
            setEyebrowCurve(true);
            logToConsole("Tactile tap detected on Duo Splash face element. Triggering dynamic blink.");
            setTimeout(() => {
                applyInteractiveBlink(1, 1);
                setEyebrowCurve(false);
            }, 250);
        });

        function setSystemTheme(theme) {
            const root = document.documentElement;
            const superBtn = document.getElementById('theme-super-btn');
            
            if (theme === 'super') {
                root.style.setProperty('--brand-green', '#8549ff');
                root.style.setProperty('--brand-green-shadow', '#6633cc');
                superBtn.classList.add('border-purple-500');
                superBtn.classList.remove('border-transparent');
                logToConsole("UI branding switched to SUPER PURPLE.");
            } else {
                root.style.setProperty('--brand-green', '#58cc02');
                root.style.setProperty('--brand-green-shadow', '#46a302');
                superBtn.classList.remove('border-purple-500');
                superBtn.classList.add('border-transparent');
                logToConsole("UI branding switched to CLASSIC GREEN.");
            }
        }

        // Clock display tick helper
        setInterval(() => {
            const now = new Date();
            const timeStr = now.toTimeString().split(' ')[0];
            document.getElementById('master-clock').innerText = timeStr;
        }, 1000);

        // Run initialization procedures onload
        window.onload = function() {
            updateTimeline(0);
            logToConsole("Simulator loaded. Ready to interact with telemetry system.");
            
            // Trigger automatic initial blink cycle after 1.5 seconds to hook users
            setTimeout(() => {
                applyInteractiveBlink(0.08, 0.08);
                setEyebrowCurve(true);
                setTimeout(() => {
                    applyInteractiveBlink(1, 1);
                    setEyebrowCurve(false);
                }, 200);
            }, 1500);
        };
    </script>
</body>
