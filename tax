    <!-- ==========================================================================
       9. RUNTIME CONTROLLER AND GAME ENGINES (JAVASCRIPT)
       ========================================================================== -->
    <script>
        /* ==========================================================================
           GLOBAL GAME STATE & MANAGEMENT
           ========================================================================== */
        const state = {
            xp: 0,
            level: 1,
            gold: 0,
            streak: 0,
            correctSortsInARow: 0,
            hasBracketUnlocked: false,
            hasSortUnlocked: false,
            hasGainsUnlocked: false,
            hasAuditUnlocked: false
        };

        const LEVEL_THRESHOLD = 100;

        // Custom particle rendering logic on Canvas (Confetti systems)
        const canvas = document.getElementById('particle-canvas');
        const ctx = canvas.getContext('2d');
        let particles = [];

        function resizeCanvas() {
            canvas.width = canvas.parentElement.clientWidth;
            canvas.height = canvas.parentElement.clientHeight;
        }
        window.addEventListener('resize', resizeCanvas);
        resizeCanvas();

        class Particle {
            constructor(x, y, color) {
                this.x = x;
                this.y = y;
                this.size = Math.random() * 6 + 4;
                this.speedX = (Math.random() - 0.5) * 8;
                this.speedY = (Math.random() - 1) * 8 - 4;
                this.color = color;
                this.alpha = 1;
                this.gravity = 0.2;
            }

            update() {
                this.x += this.speedX;
                this.y += this.speedY;
                this.speedY += this.gravity;
                this.alpha -= 0.02;
            }

            draw() {
                ctx.save();
                ctx.globalAlpha = this.alpha;
                ctx.fillStyle = this.color;
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                ctx.fill();
                ctx.restore();
            }
        }

        function createExplosion(x, y, color) {
            for (let i = 0; i < 20; i++) {
                particles.push(new Particle(x, y, color));
            }
        }

        function animateParticles() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            particles = particles.filter(p => p.alpha > 0);
            particles.forEach(p => {
                p.update();
                p.draw();
            });
            requestAnimationFrame(animateParticles);
        }
        animateParticles();

        /* ==========================================================================
           CORE EXPERIENCE & ACHIEVEMENT WRAPPER
           ========================================================================== */
        function triggerFlash(cardId, status) {
            const card = document.getElementById(cardId);
            const overlay = card.querySelector('.flash-overlay');
            
            overlay.className = `flash-overlay flash-${status}`;
            overlay.style.opacity = '1';
            
            card.classList.remove('animate-correct', 'animate-incorrect');
            void card.offsetWidth; // Trigger reflow
            
            if (status === 'success') {
                card.classList.add('animate-correct');
            } else {
                card.classList.add('animate-incorrect');
            }

            setTimeout(() => {
                overlay.style.opacity = '0';
            }, 300);
        }

        function addXP(amount, eventElement, customColor = 'var(--brand-purple)') {
            state.xp += amount;
            state.gold += Math.floor(amount / 2);
            
            // Visualizing numbers moving inside stats panel
            document.getElementById('gold-display').innerText = state.gold;

            // Compute visual explosion of canvas points
            if (eventElement) {
                const rect = eventElement.getBoundingClientRect();
                const containerRect = canvas.getBoundingClientRect();
                const x = rect.left - containerRect.left + (rect.width / 2);
                const y = rect.top - containerRect.top + (rect.height / 2);
                createExplosion(x, y, customColor);
            }

            if (state.xp >= state.level * LEVEL_THRESHOLD) {
                levelUp();
            }

            updateGamificationBar();
        }

        function levelUp() {
            state.xp = state.xp - (state.level * LEVEL_THRESHOLD);
            state.level += 1;
            
            // Animate dynamic text inside modal
            document.getElementById('modal-level-badge').innerText = state.level;
            
            const titles = [
                "Corporate Audit Master",
                "Fiduciary Architect",
                "Compliance Commander",
                "Senior Tax Partner"
            ];
            const chosenTitle = titles[Math.min(state.level - 2, titles.length - 1)];
            document.getElementById('modal-level-description').innerHTML = 
                `Your mastery is ascending! You have been promoted to <strong>${chosenTitle}</strong>. New advanced compliance cases are unlocked.`;
            
            setTimeout(() => {
                document.getElementById('level-modal').classList.add('active');
            }, 500);
        }

        function updateGamificationBar() {
            const nextLevelThreshold = state.level * LEVEL_THRESHOLD;
            const progressPercent = (state.xp / nextLevelThreshold) * 100;
            
            document.getElementById('xp-progress-bar').style.width = `${progressPercent}%`;
            document.getElementById('xp-numbers').innerText = `${state.xp} / ${nextLevelThreshold} XP`;
            
            const rankTitles = [
                "Junior Fiduciary",
                "Strategic Consultant",
                "Lead Auditor",
                "Chief Wealth Planner"
            ];
            const currentRank = rankTitles[Math.min(state.level - 1, rankTitles.length - 1)];
            document.getElementById('level-display').innerText = `Level ${state.level} ${currentRank}`;
        }

        function unlockAchievement(id, rowId, labelId) {
            if (state[id] === true) return; // Prevent double trigger
            state[id] = true;
            
            const label = document.getElementById(labelId);
            label.className = "status-unlocked";
            label.innerText = "UNLOCKED";
            
            const row = document.getElementById(rowId);
            row.style.backgroundColor = "rgba(46, 204, 113, 0.05)";
            
            // Highlight the global progress
            state.streak += 1;
            document.getElementById('streak-display').innerText = `${state.streak} days`;
            
            // Generate visual sparkle on achievements grid
            const rowRect = row.getBoundingClientRect();
            const containerRect = canvas.getBoundingClientRect();
            createExplosion(
                rowRect.left - containerRect.left + 50,
                rowRect.top - containerRect.top + 20,
                'var(--brand-green)'
            );
        }

        // Close the modal system
        document.getElementById('btn-close-modal').addEventListener('click', () => {
            document.getElementById('level-modal').classList.remove('active');
        });

        /* ==========================================================================
           WARP CARD MOUSE PHYSICS (TRANSFORM INTERACTION)
           ========================================================================== */
        const cards = document.querySelectorAll('.warp-card');

        cards.forEach(card => {
            card.addEventListener('mousemove', (e) => {
                const rect = card.getBoundingClientRect();
                const x = e.clientX - rect.left; // x coordinate within client bounds
                const y = e.clientY - rect.top;  // y coordinate within client bounds
                
                const centerX = rect.width / 2;
                const centerY = rect.height / 2;
                
                // Tilt scaling formulas
                const rotateX = ((y - centerY) / centerY) * -12; // Adjusted range
                const rotateY = ((x - centerX) / centerX) * 12;
                
                // Apply matrix scale transitions dynamically
                card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.02, 1.02, 1.02)`;
            });

            card.addEventListener('mouseleave', () => {
                card.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1)';
            });
        });

        /* ==========================================================================
           GAME SYSTEM 1: TAX BRACKETS ENGINE
           ========================================================================== */
        const sliderIncome = document.getElementById('income-slider');
        const labelIncome = document.getElementById('bracket-income-lbl');
        const labelEffective = document.getElementById('effective-rate-lbl');
        const bracketBars = document.querySelectorAll('.bracket-bar');

        const US_BRACKETS = [
            { rate: 0.10, limit: 11600 },
            { rate: 0.12, limit: 47150 },
            { rate: 0.22, limit: 100525 },
            { rate: 0.24, limit: 191950 },
            { rate: 0.32, limit: 243725 },
            { rate: 0.35, limit: 609350 },
            { rate: 0.37, limit: Infinity }
        ];

        function calculateTaxes(income) {
            let taxAccumulator = 0;
            let remainingIncome = income;
            let previousLimit = 0;
            let activeBracketsIndex = [];

            for (let i = 0; i < US_BRACKETS.length; i++) {
                const currentBracket = US_BRACKETS[i];
                const bracketCapacity = currentBracket.limit - previousLimit;

                if (remainingIncome > bracketCapacity) {
                    taxAccumulator += bracketCapacity * currentBracket.rate;
                    remainingIncome -= bracketCapacity;
                    activeBracketsIndex.push(i);
                } else {
                    taxAccumulator += remainingIncome * currentBracket.rate;
                    activeBracketsIndex.push(i);
                    break;
                }
                previousLimit = currentBracket.limit;
            }

            return {
                totalTax: taxAccumulator,
                activeIndices: activeBracketsIndex
            };
        }

        sliderIncome.addEventListener('input', (e) => {
            const rawIncomeK = parseInt(e.target.value);
            const absoluteIncome = rawIncomeK * 1000;
            
            labelIncome.innerText = `$${rawIncomeK}k`;

            const taxResults = calculateTaxes(absoluteIncome);
            const calculatedEffectiveRate = absoluteIncome > 0 
                ? ((taxResults.totalTax / absoluteIncome) * 100).toFixed(1)
                : 0;

            labelEffective.innerText = `${calculatedEffectiveRate}% ($${Math.floor(taxResults.totalTax).toLocaleString()})`;

            // Visual mapping feedback on bar metrics
            bracketBars.forEach((bar, index) => {
                if (taxResults.activeIndices.includes(index)) {
                    bar.classList.add('active');
                    // Render scale transitions depending on income depth
                    bar.style.filter = `brightness(${1 + (index * 0.1)})`;
                } else {
                    bar.classList.remove('active');
                    bar.style.filter = 'brightness(1)';
                }
            });

            // Unlock ladder explorer achievement if income threshold is breached
            if (rawIncomeK >= 180) {
                unlockAchievement('hasBracketUnlocked', 'ach-bracket', 'ach-lbl-bracket');
            }
        });

        /* ==========================================================================
           GAME SYSTEM 2: EXPENSE SORTER ENGINE
           ========================================================================== */
        const itemsToProcess = [
            { name: "Coffee for standard business partner alignment", value: 35, deductible: true },
            { name: "Subscription to Tax Strategy Journal", value: 120, deductible: true },
            { name: "Commute from home to corporate desk", value: 45, deductible: false },
            { name: "Premium Golf Membership for personal recreation", value: 2500, deductible: false },
            { name: "Dedicated office space internet connection", value: 80, deductible: true },
            { name: "New suit purchased for general client meetings", value: 600, deductible: false }
        ];

        let sorterIndex = 0;

        const containerItemTitle = document.getElementById('sorter-item-title');
        const containerItemCost = document.getElementById('sorter-item-cost');
        const btnReject = document.getElementById('btn-reject-expense');
        const btnApprove = document.getElementById('btn-approve-expense');

        function updateSorterCard() {
            const currentItem = itemsToProcess[sorterIndex];
            containerItemTitle.innerText = currentItem.name;
            containerItemCost.innerText = `$${currentItem.value.toFixed(2)}`;
        }

        function evaluatePlayerSortingChoice(chosenStatus) {
            const currentItem = itemsToProcess[sorterIndex];
            const cardElement = document.getElementById('card-sorter');

            if (currentItem.deductible === chosenStatus) {
                // Correct path feedback loop
                triggerFlash('card-sorter', 'success');
                addXP(30, cardElement, 'var(--brand-blue)');
                state.correctSortsInARow += 1;
                
                if (state.correctSortsInARow >= 3) {
                    unlockAchievement('hasSortUnlocked', 'ach-sort', 'ach-lbl-sort');
                }
            } else {
                // False alignment path shake
                triggerFlash('card-sorter', 'error');
                state.correctSortsInARow = 0;
            }

            // Loop and render next cards
            sorterIndex = (sorterIndex + 1) % itemsToProcess.length;
            
            // Warp active card deck dynamically to simulate shifting deck items
            const activeDeckElement = document.getElementById('sorter-active-item');
            activeDeckElement.style.transform = 'translateY(15px) scale(0.9)';
            
            setTimeout(() => {
                updateSorterCard();
                activeDeckElement.style.transform = 'translateY(0) scale(1)';
            }, 200);
        }

        btnReject.addEventListener('click', (e) => {
            e.stopPropagation();
            evaluatePlayerSortingChoice(false);
        });

        btnApprove.addEventListener('click', (e) => {
            e.stopPropagation();
            evaluatePlayerSortingChoice(true);
        });

        updateSorterCard();

        /* ==========================================================================
           GAME SYSTEM 3: CAPITAL GAINS HOLD MATRIX (PORTAL FLIPPER)
           ========================================================================== */
        const sliderGains = document.getElementById('gains-slider');
        const viewGainsDays = document.getElementById('gains-days-lbl');
        const gainsBarFill = document.getElementById('gains-bar-fill');
        const strategyFlipper = document.getElementById('strategy-portal');

        sliderGains.addEventListener('input', (e) => {
            const durationDays = parseInt(e.target.value);
            viewGainsDays.innerText = `Day ${durationDays} of hold`;

            // Compute active path fill width indicator inside the card view
            const percentWidth = Math.min((durationDays / 365) * 100, 100);
            gainsBarFill.style.width = `${percentWidth}%`;

            if (durationDays >= 366) {
                // Long-term tax advantages kick in. Trigger 3D flipper warp animation.
                strategyFlipper.classList.add('flipped');
                gainsBarFill.style.backgroundColor = 'var(--brand-green)';
                unlockAchievement('hasGainsUnlocked', 'ach-gains', 'ach-lbl-gains');
                
                // Add minor one-time state points for achieving standard optimization hold duration
                if (!state.hasGainsUnlocked) {
                    addXP(40, strategyFlipper, 'var(--brand-green)');
                }
            } else {
                strategyFlipper.classList.remove('flipped');
                gainsBarFill.style.backgroundColor = 'var(--brand-red)';
            }
        });

        /* ==========================================================================
           GAME SYSTEM 4: AUDIT EXPOSURE OSCILLATOR ENGINE
           ========================================================================== */
        const btnFileReturn = document.getElementById('btn-file-return');
        const auditRiskText = document.getElementById('audit-risk-value');
        const auditSvgCircle = document.getElementById('audit-svg-circle');
        const auditStatusTip = document.getElementById('audit-status-tip');

        let auditPercentage = 30;
        let incrementOscillator = 1.8;

        // Radial gauge circle mathematics helper variables
        const circleLength = 251.2; // 2 * pi * r (r=40)

        function updateRadialGauge(percentage) {
            const offsetValue = circleLength - (percentage / 100) * circleLength;
            auditSvgCircle.style.strokeDashoffset = offsetValue;
            auditRiskText.innerText = `${Math.floor(percentage)}%`;

            // Dynamic color shift depending on state risks
            if (percentage < 25) {
                auditSvgCircle.style.stroke = 'var(--brand-green)';
                auditStatusTip.innerText = "Compliance risk low. File return!";
                auditStatusTip.style.color = 'var(--brand-green)';
            } else if (percentage < 60) {
                auditSvgCircle.style.stroke = 'var(--brand-amber)';
                auditStatusTip.innerText = "Average compliance level. Caution.";
                auditStatusTip.style.color = 'var(--brand-amber)';
            } else {
                auditSvgCircle.style.stroke = 'var(--brand-red)';
                auditStatusTip.innerText = "High-risk. Postpone audit review.";
                auditStatusTip.style.color = 'var(--brand-red)';
            }
        }

        // Continually run standard visual engine pulse loop mimicking unpredictable state risk shifts
        function auditExposureOscillator() {
            auditPercentage += incrementOscillator;
            if (auditPercentage >= 95 || auditPercentage <= 5) {
                incrementOscillator = -incrementOscillator;
            }
            updateRadialGauge(auditPercentage);
            requestAnimationFrame(auditExposureOscillator);
        }
        
        requestAnimationFrame(auditExposureOscillator);

        btnFileReturn.addEventListener('click', (e) => {
            e.stopPropagation();
            const cardElement = document.getElementById('card-audit');

            if (auditPercentage < 25) {
                triggerFlash('card-audit', 'success');
                addXP(50, cardElement, 'var(--brand-green)');
                unlockAchievement('hasAuditUnlocked', 'ach-audit', 'ach-lbl-audit');
            } else {
                triggerFlash('card-audit', 'error');
                // Penalty warning animation loop
                auditStatusTip.innerText = "AUDIT INITIATED! Penalty applied.";
                auditStatusTip.style.color = 'var(--brand-red)';
            }
        });
    </script>
</body>
</html>
