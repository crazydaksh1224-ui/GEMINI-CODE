    <script>
        /* ==========================================================================
           10.1 GLOBAL ENGINE STATE
           ========================================================================== */
        const state = {
            xp: 0,
            level: 1,
            gold: 0,
            streak: 0,
            correctSortsInARow: 0,
            hasBracketUnlocked: false,
            hasSortUnlocked: false,
            hasGainsUnlocked: false,
            hasAuditUnlocked: false
        };

        const LEVEL_THRESHOLD = 100;

        // Custom Canvas Particle Engine
        const canvas = document.getElementById('particle-canvas');
        const ctx = canvas.getContext('2d');
        let particles = [];

        function resizeCanvas() {
            canvas.width = canvas.parentElement.clientWidth;
            canvas.height = canvas.parentElement.clientHeight;
        }
        window.addEventListener('resize', resizeCanvas);
        resizeCanvas();

        class Particle {
            constructor(x, y, color) {
                this.x = x;
                this.y = y;
                this.size = Math.random() * 5 + 3;
                this.speedX = (Math.random() - 0.5) * 6;
                this.speedY = (Math.random() - 1) * 6 - 3;
                this.color = color;
                this.alpha = 1;
                this.gravity = 0.15;
            }

            update() {
                this.x += this.speedX;
                this.y += this.speedY;
                this.speedY += this.gravity;
                this.alpha -= 0.025;
            }

            draw() {
                ctx.save();
                ctx.globalAlpha = this.alpha;
                ctx.fillStyle = this.color;
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                ctx.fill();
                ctx.restore();
            }
        }

        function createExplosion(x, y, color) {
            for (let i = 0; i < 15; i++) {
                particles.push(new Particle(x, y, color));
            }
        }

        function animateParticles() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            particles = particles.filter(p => p.alpha > 0);
            particles.forEach(p => {
                p.update();
                p.draw();
            });
            requestAnimationFrame(animateParticles);
        }
        animateParticles();

        /* ==========================================================================
           10.2 SLIP-RESISTANT CUSTOM SLIDERS (Pointer Capture API)
           ========================================================================== */
        function initSlipFreeSlider(trackId, thumbId, fillId, onUpdate) {
            const track = document.getElementById(trackId);
            const thumb = document.getElementById(thumbId);
            const fill = document.getElementById(fillId);
            let activeDrag = false;

            function calculateAndSetPercentage(clientX) {
                const rect = track.getBoundingClientRect();
                let ratio = (clientX - rect.left) / rect.width;
                ratio = Math.max(0, Math.min(1, ratio));
                
                thumb.style.left = `${ratio * 100}%`;
                if (fill) fill.style.width = `${ratio * 100}%`;
                
                onUpdate(ratio);
            }

            thumb.addEventListener('pointerdown', (e) => {
                e.preventDefault();
                thumb.setPointerCapture(e.pointerId);
                activeDrag = true;
            });

            thumb.addEventListener('pointermove', (e) => {
                if (!activeDrag) return;
                calculateAndSetPercentage(e.clientX);
            });

            thumb.addEventListener('pointerup', (e) => {
                if (activeDrag) {
                    thumb.releasePointerCapture(e.pointerId);
                    activeDrag = false;
                }
            });

            // Also support clicking directly on the track
            track.addEventListener('pointerdown', (e) => {
                if (e.target !== thumb) {
                    calculateAndSetPercentage(e.clientX);
                    thumb.setPointerCapture(e.pointerId);
                    activeDrag = true;
                }
            });
        }

        /* ==========================================================================
           10.3 GAMIFICATION FUNCTIONS
           ========================================================================== */
        function triggerFlash(cardId, status) {
            const card = document.getElementById(cardId);
            const overlay = card.querySelector('.flash-overlay');
            overlay.className = `flash-overlay flash-${status}`;
            overlay.style.opacity = '1';
            
            card.classList.remove('animate-correct', 'animate-incorrect');
            void card.offsetWidth; // force reflow
            
            if (status === 'success') {
                card.classList.add('animate-correct');
            } else {
                card.classList.add('animate-incorrect');
            }

            setTimeout(() => {
                overlay.style.opacity = '0';
            }, 300);
        }

        function addXP(amount, eventElement, customColor = 'var(--brand-purple)') {
            state.xp += amount;
            state.gold += Math.floor(amount / 2);
            document.getElementById('gold-display').innerText = state.gold;

            if (eventElement) {
                const rect = eventElement.getBoundingClientRect();
                const containerRect = canvas.getBoundingClientRect();
                createExplosion(
                    rect.left - containerRect.left + (rect.width / 2),
                    rect.top - containerRect.top + (rect.height / 2),
                    customColor
                );
            }

            if (state.xp >= state.level * LEVEL_THRESHOLD) {
                levelUp();
            }
            updateGamificationBar();
        }

        function levelUp() {
            state.xp = state.xp - (state.level * LEVEL_THRESHOLD);
            state.level += 1;
            document.getElementById('modal-level-badge').innerText = state.level;
            
            const titles = [
                "1099 Master Strategist",
                "Self-Employed Consultant",
                "Senior Business Architect",
                "Financially Unlocked Advisor"
            ];
            const currentTitle = titles[Math.min(state.level - 2, titles.length - 1)];
            document.getElementById('modal-level-description').innerHTML = 
                `Your mastery of gig-economy adjustments has ascended! You are now a <strong>${currentTitle}</strong>. Keep practicing to optimize tax returns.`;
            
            setTimeout(() => {
                document.getElementById('level-modal').classList.add('active');
            }, 300);
        }

        function updateGamificationBar() {
            const nextThreshold = state.level * LEVEL_THRESHOLD;
            const percentage = (state.xp / nextThreshold) * 100;
            document.getElementById('xp-progress-bar').style.width = `${percentage}%`;
            document.getElementById('xp-numbers').innerText = `${state.xp} / ${nextThreshold} XP`;
            
            const rankTitles = [
                "Junior Hustler",
                "Freelance Strategist",
                "Business Lead",
                "Sole Proprietor Authority"
            ];
            const currentRank = rankTitles[Math.min(state.level - 1, rankTitles.length - 1)];
            document.getElementById('level-display').innerText = `Level ${state.level} ${currentRank}`;
        }

        function unlockAchievement(id, rowId, labelId) {
            if (state[id]) return;
            state[id] = true;
            
            const label = document.getElementById(labelId);
            label.className = "status-unlocked";
            label.innerText = "UNLOCKED";
            
            const row = document.getElementById(rowId);
            row.style.backgroundColor = "rgba(15, 123, 66, 0.03)";
            
            state.streak += 1;
            document.getElementById('streak-display').innerText = `${state.streak} days`;
        }

        document.getElementById('btn-close-modal').addEventListener('click', () => {
            document.getElementById('level-modal').classList.remove('active');
        });

        /* ==========================================================================
           10.4 SYSTEM 1: PROGRESSIVE INCOME BRACKETS
           ========================================================================== */
        const labelIncome = document.getElementById('bracket-income-lbl');
        const labelEffective = document.getElementById('effective-rate-lbl');
        const bracketBars = document.querySelectorAll('.bracket-bar');

        const TAX_BRACKETS_US = [
            { rate: 0.10, limit: 11600 },
            { rate: 0.12, limit: 47150 },
            { rate: 0.22, limit: 100525 },
            { rate: 0.24, limit: 191950 },
            { rate: 0.32, limit: 243725 },
            { rate: 0.35, limit: 609350 },
            { rate: 0.37, limit: Infinity }
        ];

        function processMarginalTaxes(totalEarned) {
            let accruedTax = 0;
            let leftToTax = totalEarned;
            let segmentBase = 0;
            let activeIndices = [];

            for (let i = 0; i < TAX_BRACKETS_US.length; i++) {
                const current = TAX_BRACKETS_US[i];
                const span = current.limit - segmentBase;

                if (leftToTax > span) {
                    accruedTax += span * current.rate;
                    leftToTax -= span;
                    activeIndices.push(i);
                } else {
                    accruedTax += leftToTax * current.rate;
                    activeIndices.push(i);
                    break;
                }
                segmentBase = current.limit;
            }

            return { totalTax: accruedTax, activeIndices };
        }

        initSlipFreeSlider('income-slider-track', 'income-slider-thumb', 'income-slider-fill', (percentage) => {
            const rawIncomeK = Math.round(percentage * 250); // Scale 0 to 250k
            const fullEarned = rawIncomeK * 1000;
            
            labelIncome.innerText = `$${rawIncomeK}k`;

            const calculations = processMarginalTaxes(fullEarned);
            const calculatedRate = fullEarned > 0 
                ? ((calculations.totalTax / fullEarned) * 100).toFixed(1)
                : "0.0";

            labelEffective.innerText = `${calculatedRate}% ($${Math.floor(calculations.totalTax).toLocaleString()})`;

            bracketBars.forEach((bar, idx) => {
                if (calculations.activeIndices.includes(idx)) {
                    bar.classList.add('active');
                } else {
                    bar.classList.remove('active');
                }
            });

            if (rawIncomeK >= 150) {
                unlockAchievement('hasBracketUnlocked', 'ach-bracket', 'ach-lbl-bracket');
            }
        });

        /* ==========================================================================
           10.5 SYSTEM 2: SCENARIO DATABASE GENERATOR (300+ SCENARIOS)
           ========================================================================== */
        // We auto-generate 300+ unique side-hustle and student-oriented situations on load.
        const expensesDatabase = [];

        const youngNiches = [
            { id: "streamer", label: "Twitch Streamer", taxTerm: "1099 Creator" },
            { id: "coder", label: "Freelance Dev", taxTerm: "Independent Contractor" },
            { id: "crafter", label: "Etsy Jewelry Crafter", taxTerm: "Schedule C Seller" },
            { id: "reseller", label: "Depop Fashion Flipper", taxTerm: "Sole Proprietor" },
            { id: "delivery", label: "DoorDash Delivery Rider", taxTerm: "Gig Worker" },
            { id: "musician", label: "Bedroom Music Producer", taxTerm: "Creative Independent" },
            { id: "tutor", label: "Online High-School Tutor", taxTerm: "Private Tutoring" }
        ];

        const writeOffTemplates = [
            // Deductible items (Business Use)
            { prefix: "Professional microphone bought exclusively for streams", minCost: 80, maxCost: 350, deductible: true, why: "Directly necessary equipment for delivering 1099 production value." },
            { prefix: "Procreate app purchase to create client portraits", minCost: 10, maxCost: 15, deductible: true, why: "Software directly utilized to fulfill commission contract revenues." },
            { prefix: "GitHub Copilot API keys to accelerate client coding assignments", minCost: 20, maxCost: 100, deductible: true, why: "Direct software business operation expense helping increase gig output." },
            { prefix: "Premium bubblewrap and packaging boxes for shipping art", minCost: 15, maxCost: 60, deductible: true, why: "Direct cost of goods sold necessary to mail physical inventory." },
            { prefix: "Advertising budget spent on Instagram ads targeting prospective students", minCost: 30, maxCost: 150, deductible: true, why: "Marketing and promotional expenses are fully deductible business costs." },
            { prefix: "Insulated food delivery bag used to keep food warm during delivery shifts", minCost: 25, maxCost: 45, deductible: true, why: "Direct operational tool required for professional gig task performance." },
            { prefix: "Digital software plugins and synthesizer sounds for commercial beats", minCost: 40, maxCost: 200, deductible: true, why: "Asset acquisition directly related to trade tools for musical licensing." },
            { prefix: "Figma Professional subscription to wireframe paid apps", minCost: 15, maxCost: 90, deductible: true, why: "Required prototyping software for professional design contracts." },
            { prefix: "Postage fees for delivering vintage apparel on Depop", minCost: 8, maxCost: 45, deductible: true, why: "Direct shipping expenses are deductible against your sole proprietor income." },
            
            // Non-Deductible items (Personal / Non-Business)
            { prefix: "Gym membership to build stamina for sitting while coding", minCost: 30, maxCost: 80, deductible: false, why: "General physical health is categorized as a personal non-deductible expense." },
            { prefix: "University chemistry textbook for major college program", minCost: 120, maxCost: 250, deductible: false, why: "Regular college supplies do not qualify as Schedule C business deductions, though education tax credits exist." },
            { prefix: "Daily iced latte from local coffee shop to get focused", minCost: 6, maxCost: 18, deductible: false, why: "Daily personal food and beverages are not ordinary and necessary business expenses." },
            { prefix: "Nintendo Switch bought to play games during breaks", minCost: 300, maxCost: 350, deductible: false, why: "Recreational gaming gear without verified production use is considered a personal expense." },
            { prefix: "General commuter subway card to travel to high school classes", minCost: 20, maxCost: 60, deductible: false, why: "Commuting expenses for standard school or a typical job are never tax-deductible." },
            { prefix: "Noise-cancelling headphones purchased to block out sibling noise while playing personal Valorant", minCost: 100, maxCost: 250, deductible: false, why: "Personal comfort item used mainly for recreation is not deductible." },
            { prefix: "Acne face wash to look presentable on normal webcam chats", minCost: 15, maxCost: 35, deductible: false, why: "Personal hygiene expenses are strictly non-deductible personal grooming." },
            { prefix: "Designer shoes worn during gig shifts", minCost: 120, maxCost: 300, deductible: false, why: "Street clothes suitable for everyday wear cannot be claimed as business uniform write-offs." }
        ];

        function buildEndlessDatabase() {
            // Seed a large, diverse set of scenarios by crossing templates and niches with random pricing
            let scenarioId = 1;
            while (expensesDatabase.length < 320) {
                const template = writeOffTemplates[Math.floor(Math.random() * writeOffTemplates.length)];
                const niche = youngNiches[Math.floor(Math.random() * youngNiches.length)];
                const calculatedCost = Math.round(template.minCost + Math.random() * (template.maxCost - template.minCost));
                
                expensesDatabase.push({
                    id: scenarioId++,
                    niche: niche.label,
                    name: `${template.prefix} (#${scenarioId})`,
                    cost: calculatedCost,
                    deductible: template.deductible,
                    why: template.why
                });
            }
        }
        buildEndlessDatabase();

        let currentActiveIdx = 0;
        const domNiche = document.getElementById('sorter-item-niche');
        const domName = document.getElementById('sorter-item-title');
        const domCost = document.getElementById('sorter-item-cost');
        const btnDeductible = document.getElementById('btn-approve-expense');
        const btnPersonal = document.getElementById('btn-reject-expense');

        function loadScenarioCard() {
            const item = expensesDatabase[currentActiveIdx];
            domNiche.innerText = item.niche;
            domName.innerText = item.name;
            domCost.innerText = `$${item.cost}.00`;
        }

        function runMatchOutcome(chosenDeductible) {
            const item = expensesDatabase[currentActiveIdx];
            const area = document.getElementById('card-sorter');

            if (item.deductible === chosenDeductible) {
                triggerFlash('card-sorter', 'success');
                addXP(30, area, 'var(--brand-blue)');
                state.correctSortsInARow++;
                
                if (state.correctSortsInARow >= 4) {
                    unlockAchievement('hasSortUnlocked', 'ach-sort', 'ach-lbl-sort');
                }
            } else {
                triggerFlash('card-sorter', 'error');
                state.correctSortsInARow = 0;
            }

            // Animate card slide/warp
            const targetDeck = document.getElementById('sorter-active-item');
            targetDeck.style.transform = 'translateY(12px) scale(0.97)';
            
            currentActiveIdx = (currentActiveIdx + 1) % expensesDatabase.length;

            setTimeout(() => {
                loadScenarioCard();
                targetDeck.style.transform = 'translateY(0px) scale(1)';
            }, 180);
        }

        btnDeductible.addEventListener('click', (e) => { e.stopPropagation(); runMatchOutcome(true); });
        btnPersonal.addEventListener('click', (e) => { e.stopPropagation(); runMatchOutcome(false); });

        loadScenarioCard();

        /* ==========================================================================
           10.6 SYSTEM 3: ASSET STRATEGY PORTAL
           ========================================================================== */
        const gainsDaysLabel = document.getElementById('gains-days-lbl');
        const gainsFill = document.getElementById('gains-bar-fill');
        const strategyGate = document.getElementById('strategy-portal');

        initSlipFreeSlider('gains-slider-track', 'gains-slider-thumb', 'gains-slider-fill', (percentage) => {
            const durationInDays = Math.round(percentage * 450);
            gainsDaysLabel.innerText = `Day ${durationInDays} of hold`;

            const percentageWidth = Math.min((durationInDays / 365) * 100, 100);
            gainsFill.style.width = `${percentageWidth}%`;

            if (durationInDays >= 366) {
                strategyGate.classList.add('flipped');
                gainsFill.style.backgroundColor = 'var(--brand-green)';
                unlockAchievement('hasGainsUnlocked', 'ach-gains', 'ach-lbl-gains');
                
                if (!state.hasGainsUnlocked) {
                    addXP(40, strategyGate, 'var(--brand-green)');
                }
            } else {
                strategyGate.classList.remove('flipped');
                gainsFill.style.backgroundColor = 'var(--brand-red)';
            }
        });

        /* ==========================================================================
           10.7 SYSTEM 4: SCHEDULE C AUDIT SIMULATOR (COMPLIANCE SYSTEM)
           ========================================================================== */
        const auditCheckboxOptions = {
            use: { active: false, refundDelta: 400, riskDelta: 40 },
            round: { active: false, refundDelta: 150, riskDelta: 25 },
            cash: { active: false, refundDelta: 300, riskDelta: 35 }
        };

        const optUse = document.getElementById('audit-opt-use');
        const optRound = document.getElementById('audit-opt-round');
        const optCash = document.getElementById('audit-opt-cash');
        const btnSubmitReturn = document.getElementById('btn-submit-return');

        const labelReturnAmount = document.getElementById('audit-return-amt');
        const labelStatusWord = document.getElementById('audit-status-word');
        const svgAuditCircle = document.getElementById('audit-svg-circle');
        const labelRiskPct = document.getElementById('audit-risk-value');

        function updateScheduleCDashboard() {
            let refundAccrued = 0;
            let currentRiskScore = 15; // Base DIF Score (minimum random assessment risk)

            if (auditCheckboxOptions.use.active) {
                refundAccrued += auditCheckboxOptions.use.refundDelta;
                currentRiskScore += auditCheckboxOptions.use.riskDelta;
            }
            if (auditCheckboxOptions.round.active) {
                refundAccrued += auditCheckboxOptions.round.refundDelta;
                currentRiskScore += auditCheckboxOptions.round.riskDelta;
            }
            if (auditCheckboxOptions.cash.active) {
                refundAccrued += auditCheckboxOptions.cash.refundDelta;
                currentRiskScore += auditCheckboxOptions.cash.riskDelta;
            }

            labelReturnAmount.innerText = `$${refundAccrued}`;
            labelRiskPct.innerText = `${currentRiskScore}%`;

            // Adjust Dash-offset (Radius=32, Length=201)
            const lengthOffset = 201 - (currentRiskScore / 100) * 201;
            svgAuditCircle.style.strokeDashoffset = lengthOffset;

            // Gauge classification mapping
            if (currentRiskScore <= 35) {
                svgAuditCircle.style.stroke = 'var(--brand-green)';
                labelStatusWord.innerText = "SAFE";
                labelStatusWord.style.color = 'var(--brand-green)';
            } else if (currentRiskScore <= 60) {
                svgAuditCircle.style.stroke = 'var(--brand-amber)';
                labelStatusWord.innerText = "WARNING";
                labelStatusWord.style.color = 'var(--brand-amber)';
            } else {
                svgAuditCircle.style.stroke = 'var(--brand-red)';
                labelStatusWord.innerText = "HIGH AUDIT RISK";
                labelStatusWord.style.color = 'var(--brand-red)';
            }

            return { refundAccrued, currentRiskScore };
        }

        function bindRowToggle(dom, key) {
            dom.addEventListener('click', (e) => {
                e.stopPropagation();
                auditCheckboxOptions[key].active = !auditCheckboxOptions[key].active;
                if (auditCheckboxOptions[key].active) {
                    dom.classList.add('checked');
                } else {
                    dom.classList.remove('checked');
                }
                updateScheduleCDashboard();
            });
        }

        bindRowToggle(optUse, 'use');
        bindRowToggle(optRound, 'round');
        bindRowToggle(optCash, 'cash');

        btnSubmitReturn.addEventListener('click', (e) => {
            e.stopPropagation();
            const { refundAccrued, currentRiskScore } = updateScheduleCDashboard();
            const component = document.getElementById('card-audit');

            if (currentRiskScore <= 55) {
                // Success Path
                triggerFlash('card-audit', 'success');
                addXP(50, component, 'var(--brand-amber)');
                
                if (refundAccrued >= 400 && currentRiskScore <= 40) {
                    unlockAchievement('hasAuditUnlocked', 'ach-audit', 'ach-lbl-audit');
                }
            } else {
                // Fail Path
                triggerFlash('card-audit', 'error');
                labelStatusWord.innerText = "AUDIT TRIPPED!";
                labelStatusWord.style.color = 'var(--brand-red)';
            }
        });

        updateScheduleCDashboard();
    </script>
</body>
</html>
