<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Notion-Style Gamified Tax Widget</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        /* Notion-style CSS Variables */
        :root {
            --bg-color: #ffffff;
            --page-bg: #f7f7f5;
            --text-main: #37352f;
            --text-muted: #787774;
            --border-color: rgba(55, 53, 47, 0.09);
            --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.05);
            --shadow-md: rgba(15, 15, 15, 0.1) 0px 4px 12px, rgba(15, 15, 15, 0.05) 0px 1px 3px;
            --font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, "Apple Color Emoji", Arial, sans-serif;
            
            /* Notion Tag Colors */
            --tag-green-bg: #e6eed5;
            --tag-green-text: #4c653f;
            --tag-yellow-bg: #fbf3db;
            --tag-yellow-text: #937229;
            --tag-blue-bg: #e2ecf3;
            --tag-blue-text: #335d82;
            --tag-gray-bg: #f1f1ef;
            --tag-gray-text: #787774;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: var(--font-family);
            background-color: var(--page-bg);
            color: var(--text-main);
            line-height: 1.5;
            padding: 40px 20px;
            overflow-x: hidden; /* Prevent horizontal scroll */
        }

        /* Widget Container: Aligned & Scroll-Friendly */
        .tax-widget-container {
            max-width: 960px;
            margin: 0 auto;
            background: var(--bg-color);
            border-radius: 12px;
            padding: 40px;
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--border-color);
        }

        /* Header & Gamification Progress */
        .widget-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-bottom: 32px;
            padding-bottom: 24px;
            border-bottom: 1px solid var(--border-color);
            flex-wrap: wrap;
            gap: 20px;
        }

        .header-title h1 {
            font-size: 24px;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .header-title p {
            color: var(--text-muted);
            font-size: 14px;
            margin-top: 4px;
        }

        .user-level {
            background: var(--tag-blue-bg);
            padding: 12px 16px;
            border-radius: 8px;
            min-width: 200px;
        }

        .level-header {
            display: flex;
            justify-content: space-between;
            font-size: 13px;
            font-weight: 600;
            color: var(--tag-blue-text);
            margin-bottom: 8px;
        }

        .progress-bar {
            width: 100%;
            height: 8px;
            background: rgba(255, 255, 255, 0.5);
            border-radius: 4px;
            overflow: hidden;
        }

        .progress-fill {
            height: 100%;
            width: 65%; /* Hardcoded progress */
            background: var(--tag-blue-text);
            border-radius: 4px;
            transition: width 1s ease-in-out;
        }

        /* Responsive Grid: Prevents Overlapping completely */
        .quest-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 24px;
            perspective: 1000px; /* Crucial for 3D Warp effects */
        }

        /* Curvy Cornered Cards with 3D Warp Transforms */
        .quest-card {
            background: var(--bg-color);
            border: 1px solid var(--border-color);
            border-radius: 16px; /* Curvy corners */
            padding: 24px;
            cursor: pointer;
            box-shadow: var(--shadow-sm);
            display: flex;
            flex-direction: column;
            gap: 12px;
            transform-style: preserve-3d;
            /* Smooth transition when cursor leaves */
            transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), 
                        box-shadow 0.4s ease, border-color 0.2s ease;
            position: relative;
        }

        /* Interaction states */
        .quest-card:hover {
            border-color: rgba(55, 53, 47, 0.2);
            /* The real-time warp transform is handled by JS, this is a fallback */
            box-shadow: var(--shadow-md);
            z-index: 10;
        }

        /* Badge Styles (Notion Tags) */
        .badge {
            align-self: flex-start;
            padding: 2px 8px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            gap: 4px;
            transform: translateZ(20px); /* 3D pop effect during warp */
        }

        .badge.green { background: var(--tag-green-bg); color: var(--tag-green-text); }
        .badge.yellow { background: var(--tag-yellow-bg); color: var(--tag-yellow-text); }
        .badge.gray { background: var(--tag-gray-bg); color: var(--tag-gray-text); }

        /* Card Typography & Content */
        .quest-title {
            font-size: 16px;
            font-weight: 600;
            color: var(--text-main);
            transform: translateZ(30px); /* 3D pop effect */
        }

        .quest-desc {
            font-size: 14px;
            color: var(--text-muted);
            flex-grow: 1;
            transform: translateZ(20px); /* 3D pop effect */
        }

        /* Card Footer: XP and Action */
        .quest-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 8px;
            padding-top: 16px;
            border-top: 1px dashed var(--border-color);
            transform: translateZ(10px);
        }

        .xp-reward {
            font-size: 13px;
            font-weight: 600;
            color: var(--text-main);
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .xp-reward svg {
            width: 14px;
            height: 14px;
            fill: #E5A822; /* Gold coin color */
        }

        .action-btn {
            font-size: 13px;
            font-weight: 500;
            color: var(--text-muted);
            background: none;
            border: none;
            cursor: pointer;
        }

        .quest-card:hover .action-btn {
            color: var(--text-main);
            text-decoration: underline;
        }

        /* Responsive */
        @media (max-width: 600px) {
            .widget-header {
                flex-direction: column;
                align-items: flex-start;
            }
            .user-level {
                width: 100%;
            }
            .tax-widget-container {
                padding: 20px;
            }
        }
    </style>
</head>
<body>

    <div class="tax-widget-container">
        <!-- Header Section -->
        <header class="widget-header">
            <div class="header-title">
                <h1>🗺️ TaxMastery Quests</h1>
                <p>Complete tax modules to optimize your returns and earn XP.</p>
            </div>
            
            <div class="user-level">
                <div class="level-header">
                    <span>Level 4: Exemption Explorer</span>
                    <span>650 / 1000 XP</span>
                </div>
                <div class="progress-bar">
                    <div class="progress-fill"></div>
                </div>
            </div>
        </header>

        <!-- Dynamic Grid Section -->
        <div class="quest-grid">
            
            <!-- Card 1 -->
            <div class="quest-card">
                <div class="badge green">● Completed</div>
                <h3 class="quest-title">W-2 Warrior</h3>
                <p class="quest-desc">Master the basics of standard income reporting and double-check your employer withholdings.</p>
                <div class="quest-footer">
                    <div class="xp-reward">
                        <svg viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
                        +100 XP
                    </div>
                    <button class="action-btn">Review</button>
                </div>
            </div>

            <!-- Card 2 -->
            <div class="quest-card">
                <div class="badge yellow">◐ In Progress</div>
                <h3 class="quest-title">Deduction Detective</h3>
                <p class="quest-desc">Find hidden tax breaks in your daily expenses. Uncover standard vs. itemized benefits.</p>
                <div class="quest-footer">
                    <div class="xp-reward">
                        <svg viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
                        +250 XP
                    </div>
                    <button class="action-btn">Continue</button>
                </div>
            </div>

            <!-- Card 3 -->
            <div class="quest-card">
                <div class="badge gray">○ Locked</div>
                <h3 class="quest-title">Capital Gains Guru</h3>
                <p class="quest-desc">Navigate the maze of investment taxes, crypto reporting, and loss harvesting.</p>
                <div class="quest-footer">
                    <div class="xp-reward">
                        <svg viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
                        +500 XP
                    </div>
                    <button class="action-btn">Unlock at Lvl 5</button>
                </div>
            </div>

            <!-- Card 4 -->
            <div class="quest-card">
                <div class="badge gray">○ Locked</div>
                <h3 class="quest-title">Freelancer Fortress</h3>
                <p class="quest-desc">Write-offs, 1099s, and quarterly estimated tax planning for the self-employed.</p>
                <div class="quest-footer">
                    <div class="xp-reward">
                        <svg viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
                        +750 XP
                    </div>
                    <button class="action-btn">Unlock at Lvl 6</button>
                </div>
            </div>

        </div>
    </div>

    <!-- JavaScript for 3D Warp + Transform Animations -->
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const cards = document.querySelectorAll('.quest-card');

            cards.forEach(card => {
                // Interactive 3D Warp Effect on Mouse Move
                card.addEventListener('mousemove', (e) => {
                    const rect = card.getBoundingClientRect();
                    const x = e.clientX - rect.left; // Mouse X relative to card
                    const y = e.clientY - rect.top;  // Mouse Y relative to card
                    
                    const centerX = rect.width / 2;
                    const centerY = rect.height / 2;
                    
                    // Calculate rotation degrees based on cursor position
                    // Divider controls the intensity of the warp (higher = less intense)
                    const rotateX = ((y - centerY) / centerY) * -8; 
                    const rotateY = ((x - centerX) / centerX) * 8;

                    // Apply the Warp+Transform
                    card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.03, 1.03, 1.03)`;
                    
                    // Dynamic Lighting (Notion style subtleness)
                    const shineX = (x / rect.width) * 100;
                    const shineY = (y / rect.height) * 100;
                    card.style.background = `radial-gradient(circle at ${shineX}% ${shineY}%, #ffffff, var(--bg-color))`;
                });

                // Reset the transform smoothly when the mouse leaves
                card.addEventListener('mouseleave', () => {
                    card.style.transform = `perspective(1000px) rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1)`;
                    card.style.background = `var(--bg-color)`;
                });
            });
        });
    </script>
</body>
</html>
