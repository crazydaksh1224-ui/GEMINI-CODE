<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TaxMaster - Notion Style Learning</title>
    <style>
        /* ==========================================================================
           1. CSS VARIABLES & NOTION DESIGN SYSTEM
           ========================================================================== */
        :root {
            /* Typography */
            --font-stack: ui-sans-serif, -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, "Apple Color Emoji", Arial, sans-serif, "Segoe UI Emoji", "Segoe UI Symbol";
            --font-size-base: 15px;
            --font-size-sm: 13px;
            --font-size-lg: 18px;
            --font-size-xl: 24px;
            --font-size-xxl: 32px;
            
            /* Colors - Light Theme (Notion Inspired) */
            --bg-body: #ffffff;
            --bg-sidebar: #fbfbfa;
            --bg-hover: rgba(55, 53, 47, 0.08);
            --bg-hover-dark: rgba(55, 53, 47, 0.16);
            --bg-card: #ffffff;
            --bg-card-back: #f8f8f7;
            
            --text-main: #37352f;
            --text-muted: rgba(55, 53, 47, 0.65);
            --text-placeholder: rgba(55, 53, 47, 0.4);
            
            --border-color: rgba(55, 53, 47, 0.16);
            --border-light: rgba(55, 53, 47, 0.09);
            
            /* Gamification Colors */
            --color-xp: #0f7b6c;
            --color-xp-bg: #e2f1ef;
            --color-level: #eb5757;
            --color-locked: #e9e5e3;
            --color-success: #0f7b6c;
            
            /* Layout & Spacing */
            --sidebar-width: 260px;
            --content-max-width: 900px;
            --radius-sm: 4px;
            --radius-md: 8px;
            --radius-lg: 16px;
            --radius-xl: 24px;
            
            /* Shadows & Effects */
            --shadow-sm: 0 1px 2px rgba(15, 15, 15, 0.1);
            --shadow-md: 0 4px 12px rgba(15, 15, 15, 0.1);
            --shadow-card: 0 8px 24px rgba(15, 15, 15, 0.08);
            --shadow-card-hover: 0 16px 40px rgba(15, 15, 15, 0.15);
            
            /* Transitions */
            --transition-fast: 0.15s ease;
            --transition-smooth: 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
            --transition-bounce: 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        /* ==========================================================================
           2. RESET & BASE STYLES
           ========================================================================== */
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: var(--font-stack);
            font-size: var(--font-size-base);
            color: var(--text-main);
            background-color: var(--bg-body);
            line-height: 1.6;
            overflow-x: hidden;
            display: flex;
            height: 100vh;
        }

        h1, h2, h3, h4, h5, h6 {
            font-weight: 700;
            line-height: 1.2;
            color: var(--text-main);
        }

        a {
            text-decoration: none;
            color: inherit;
        }

        button {
            font-family: var(--font-stack);
            background: none;
            border: none;
            cursor: pointer;
            color: inherit;
        }

        ul {
            list-style: none;
        }

        /* ==========================================================================
           3. LAYOUT & STRUCTURE
           ========================================================================== */
        .app-container {
            display: flex;
            width: 100%;
            height: 100%;
        }

        /* --- Sidebar --- */
        .sidebar {
            width: var(--sidebar-width);
            background-color: var(--bg-sidebar);
            border-right: 1px solid var(--border-light);
            display: flex;
            flex-direction: column;
            padding: 16px 0;
            flex-shrink: 0;
            height: 100%;
            overflow-y: auto;
        }

        .sidebar-header {
            padding: 0 16px 16px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .user-avatar {
            width: 32px;
            height: 32px;
            background-color: var(--color-xp-bg);
            color: var(--color-xp);
            border-radius: 4px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            font-size: var(--font-size-sm);
        }

        .user-info {
            display: flex;
            flex-direction: column;
        }

        .user-name {
            font-weight: 600;
            font-size: var(--font-size-sm);
        }

        .user-role {
            font-size: 11px;
            color: var(--text-muted);
        }

        .nav-section {
            margin-top: 16px;
        }

        .nav-title {
            font-size: 11px;
            font-weight: 600;
            color: var(--text-muted);
            padding: 0 16px 8px;
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 8px 16px;
            color: var(--text-main);
            font-size: var(--font-size-sm);
            transition: background var(--transition-fast);
            cursor: pointer;
        }

        .nav-item:hover {
            background-color: var(--bg-hover);
        }

        .nav-item.active {
            background-color: var(--bg-hover-dark);
            font-weight: 500;
        }

        .nav-icon {
            width: 18px;
            height: 18px;
            fill: var(--text-muted);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* --- Main Content Area --- */
        .main-content {
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            overflow-y: auto;
            position: relative;
        }

        .topbar {
            height: 48px;
            padding: 0 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(8px);
            z-index: 100;
        }

        .breadcrumb {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: var(--font-size-sm);
            color: var(--text-muted);
        }

        .topbar-actions {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .content-wrapper {
            max-width: var(--content-max-width);
            margin: 0 auto;
            padding: 40px 60px 100px;
            width: 100%;
        }

        /* ==========================================================================
           4. GAMIFICATION WIDGETS
           ========================================================================== */
        .gamification-header {
            margin-bottom: 40px;
            animation: fadeInDown 0.8s ease forwards;
        }

        .page-icon {
            font-size: 72px;
            margin-bottom: 24px;
            display: block;
        }

        .page-title {
            font-size: 40px;
            font-weight: 700;
            letter-spacing: -0.03em;
            margin-bottom: 16px;
        }

        .stats-container {
            display: flex;
            gap: 24px;
            margin-bottom: 32px;
            background: var(--bg-sidebar);
            padding: 20px;
            border-radius: var(--radius-md);
            border: 1px solid var(--border-light);
        }

        .stat-box {
            flex: 1;
        }

        .stat-label {
            font-size: 12px;
            color: var(--text-muted);
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .stat-value {
            font-size: 24px;
            font-weight: 700;
            color: var(--text-main);
            display: flex;
            align-items: baseline;
            gap: 4px;
        }

        .stat-value span {
            font-size: 14px;
            font-weight: 400;
            color: var(--text-muted);
        }

        /* Progress Bar */
        .progress-wrapper {
            margin-top: 12px;
            width: 100%;
        }

        .progress-track {
            height: 8px;
            background: var(--border-light);
            border-radius: 4px;
            overflow: hidden;
            position: relative;
        }

        .progress-fill {
            position: absolute;
            top: 0;
            left: 0;
            height: 100%;
            background: var(--color-xp);
            border-radius: 4px;
            width: 0%;
            transition: width 1s cubic-bezier(0.22, 1, 0.36, 1);
        }

        /* Level Badge */
        .level-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: var(--color-level);
            color: white;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 600;
            box-shadow: 0 2px 8px rgba(235, 87, 87, 0.3);
            animation: pulse 2s infinite;
        }

        /* ==========================================================================
           5. 3D WARP & TRANSFORM CARD ENGINE
           ========================================================================== */
        .module-section {
            margin-bottom: 48px;
        }

        .module-title {
            font-size: var(--font-size-xl);
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .module-desc {
            color: var(--text-muted);
            margin-bottom: 24px;
            font-size: 15px;
        }

        .card-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 24px;
            /* Prevents overlapping and allows natural flow */
            align-items: stretch;
        }

        /* The 3D Scene / Perspective Container */
        .card-scene {
            perspective: 1200px;
            width: 100%;
            min-height: 320px;
            cursor: pointer;
        }

        /* The Card Wrapper handling 3D transformations */
        .warp-card {
            width: 100%;
            height: 100%;
            position: relative;
            transform-style: preserve-3d;
            transition: transform 0.6s cubic-bezier(0.25, 0.8, 0.25, 1);
            border-radius: var(--radius-xl);
        }

        .card-scene:hover .warp-card {
            /* Handled dynamically via JS for precision, but fallback here */
            transform: scale3d(1.02, 1.02, 1.02);
            transition: transform 0.1s linear; /* Fast response on move */
        }

        /* Return to normal smoothly when mouse leaves */
        .card-scene.leave .warp-card {
            transition: transform 0.6s cubic-bezier(0.25, 0.8, 0.25, 1);
            transform: rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1);
        }

        /* Front and Back Faces */
        .card-face {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            backface-visibility: hidden;
            -webkit-backface-visibility: hidden;
            border-radius: var(--radius-xl);
            padding: 24px;
            display: flex;
            flex-direction: column;
            box-shadow: var(--shadow-card);
            border: 1px solid var(--border-light);
            background-color: var(--bg-card);
            transform-style: preserve-3d;
        }

        /* 3D Floating Elements inside the card */
        .card-face > * {
            transform: translateZ(40px); /* Pushes content out for parallax */
        }

        /* Back face is rotated initially */
        .card-face.back {
            transform: rotateY(180deg);
            background-color: var(--bg-card-back);
        }

        /* Flip Action */
        .card-scene.is-flipped .warp-card {
            transform: rotateY(180deg) scale3d(1.05, 1.05, 1.05);
            transition: transform 0.8s cubic-bezier(0.34, 1.56, 0.64, 1); /* Bouncy flip */
        }
        
        .card-scene.is-flipped:hover .warp-card {
            /* Dynamic JS will take over, but base state when flipped */
        }

        /* Card Content Styles */
        .card-tag {
            align-self: flex-start;
            background: rgba(15, 123, 108, 0.1);
            color: var(--color-xp);
            padding: 4px 10px;
            border-radius: var(--radius-sm);
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: auto;
        }

        .card-icon {
            font-size: 48px;
            margin-bottom: 16px;
            filter: drop-shadow(0 4px 8px rgba(0,0,0,0.1));
            transform: translateZ(60px) !important; /* Extra pop */
        }

        .card-title {
            font-size: var(--font-size-lg);
            font-weight: 700;
            margin-bottom: 8px;
            color: var(--text-main);
        }

        .card-text {
            font-size: 14px;
            color: var(--text-muted);
            margin-bottom: 24px;
            line-height: 1.5;
        }

        .card-action {
            margin-top: auto;
            width: 100%;
            padding: 10px;
            background: var(--bg-body);
            border: 1px solid var(--border-light);
            border-radius: var(--radius-md);
            font-weight: 500;
            font-size: 13px;
            transition: all var(--transition-fast);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transform: translateZ(30px) !important;
        }

        .card-action:hover {
            background: var(--bg-hover);
            border-color: var(--border-color);
        }

        /* Glare effect for warp animation */
        .glare {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            border-radius: var(--radius-xl);
            background: radial-gradient(circle at 50% 50%, rgba(255,255,255,0.4) 0%, rgba(255,255,255,0) 60%);
            opacity: 0;
            pointer-events: none;
            mix-blend-mode: overlay;
            transition: opacity 0.3s;
            transform: translateZ(1px); /* Keep glare flat on card */
        }

        .card-scene:hover .glare {
            opacity: 1;
        }

        /* Back Card specific */
        .card-face.back {
            justify-content: center;
            text-align: center;
        }

        .back-title {
            font-size: var(--font-size-lg);
            font-weight: 700;
            margin-bottom: 12px;
            color: var(--color-xp);
        }

        .back-text {
            font-size: 14px;
            color: var(--text-main);
            margin-bottom: 20px;
        }

        .btn-claim {
            background: var(--text-main);
            color: white;
            padding: 12px 24px;
            border-radius: var(--radius-md);
            font-weight: 600;
            font-size: 14px;
            transition: transform var(--transition-fast), background var(--transition-fast);
            border: none;
            cursor: pointer;
        }

        .btn-claim:hover {
            background: black;
            transform: scale(1.05);
        }

        .btn-claim:active {
            transform: scale(0.95);
        }

        .btn-claim.claimed {
            background: var(--color-success);
            pointer-events: none;
        }

        /* Locked State */
        .card-scene.locked .card-face.front {
            background-color: var(--color-locked);
            border: 1px dashed var(--border-color);
            opacity: 0.8;
            filter: grayscale(100%);
        }

        .card-scene.locked .card-tag {
            background: rgba(0,0,0,0.05);
            color: var(--text-muted);
        }

        .card-scene.locked .card-action {
            background: transparent;
            color: var(--text-muted);
            border-style: dashed;
        }

        .lock-icon {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) translateZ(50px) !important;
            font-size: 40px;
            background: rgba(255,255,255,0.9);
            width: 80px;
            height: 80px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            box-shadow: var(--shadow-md);
        }

        /* ==========================================================================
           6. ANIMATIONS & PARTICLES
           ========================================================================== */
        @keyframes fadeInDown {
            from { opacity: 0; transform: translateY(-20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes pulse {
            0% { box-shadow: 0 0 0 0 rgba(235, 87, 87, 0.4); }
            70% { box-shadow: 0 0 0 10px rgba(235, 87, 87, 0); }
            100% { box-shadow: 0 0 0 0 rgba(235, 87, 87, 0); }
        }

        @keyframes popIn {
            0% { transform: scale(0.8); opacity: 0; }
            100% { transform: scale(1); opacity: 1; }
        }

        .confetti {
            position: fixed;
            width: 10px;
            height: 10px;
            background-color: #f00;
            border-radius: 0;
            z-index: 9999;
            pointer-events: none;
            animation: fall 3s ease-in forwards;
        }

        @keyframes fall {
            0% { transform: translateY(-10vh) rotate(0deg) scale(1); opacity: 1; }
            100% { transform: translateY(100vh) rotate(720deg) scale(0); opacity: 0; }
        }

        /* ==========================================================================
           7. MEDIA QUERIES (Responsive Design)
           ========================================================================== */
        @media (max-width: 768px) {
            .app-container {
                flex-direction: column;
            }
            .sidebar {
                width: 100%;
                height: auto;
                border-right: none;
                border-bottom: 1px solid var(--border-light);
                padding: 10px;
            }
            .sidebar-nav {
                display: flex;
                overflow-x: auto;
            }
            .nav-section { margin-top: 0; }
            .nav-title { display: none; }
            .nav-item { padding: 8px; border-radius: 8px; }
            .nav-item span { display: none; }
            .content-wrapper { padding: 24px 16px; }
            .stats-container { flex-direction: column; gap: 12px; }
        }

    </style>
</head>
