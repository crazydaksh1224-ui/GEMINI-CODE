<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WhatsApp AI Agent Dashboard</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts (Inter) -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- FontAwesome for gorgeous modern icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                    },
                    colors: {
                        waGreen: {
                            50: '#eefdf4',
                            100: '#d4f9e1',
                            500: '#07D974', // WhatsApp Neon
                            600: '#128C7E', // WhatsApp Classic
                            700: '#075E54', // Dark WhatsApp
                        }
                    }
                }
            }
        }
    </script>
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: radial-gradient(circle at 50% 50%, #0d1527 0%, #050814 100%);
            min-height: 100vh;
            color: #f3f4f6;
            overflow-x: hidden;
        }

        /* Warp Transform Core Animations */
        .warp-card-container {
            perspective: 1200px;
        }

        .warp-card {
            transition: transform 0.2s cubic-bezier(0.25, 1, 0.5, 1), box-shadow 0.3s ease, border-color 0.3s ease;
            transform-style: preserve-3d;
            border-radius: 1.8rem; /* Curvy corners */
            will-change: transform;
        }

        .warp-card:hover {
            box-shadow: 0 25px 50px -12px rgba(7, 217, 116, 0.25);
        }

        .warp-child {
            transform: translateZ(30px);
            transition: transform 0.2s cubic-bezier(0.25, 1, 0.5, 1);
        }

        /* Glassmorphism custom classes */
        .glass-panel {
            background: rgba(13, 22, 41, 0.65);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        .glass-card {
            background: rgba(17, 28, 52, 0.45);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.06);
        }

        /* Card Entry Animation */
        @keyframes scaleIn {
            0% {
                opacity: 0;
                transform: scale(0.9) translateY(20px);
            }
            100% {
                opacity: 1;
                transform: scale(1) translateY(0);
            }
        }

        .animate-scale-in {
            animation: scaleIn 0.45s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
        }

        /* Shimmer Glowing Effect */
        @keyframes shimmer {
            0% { background-position: -200% 0; }
            100% { background-position: 200% 0; }
        }
        .bg-shimmer {
            background: linear-gradient(90deg, rgba(7,217,116,0.1) 25%, rgba(18,140,126,0.3) 50%, rgba(7,217,116,0.1) 75%);
            background-size: 200% 100%;
            animation: shimmer 1.8s infinite linear;
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
        }
        ::-webkit-scrollbar-track {
            background: rgba(5, 8, 20, 0.5);
        }
        ::-webkit-scrollbar-thumb {
            background: rgba(7, 217, 116, 0.3);
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: rgba(7, 217, 116, 0.6);
        }
    </style>
</head>
<body class="antialiased">

    <!-- App Container -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        
        <!-- Dashboard Header -->
        <header class="glass-panel rounded-3xl p-6 mb-8 flex flex-col md:flex-row items-center justify-between gap-6 border-waGreen-500/20 relative overflow-hidden animate-scale-in">
            <!-- Decorative Glow -->
            <div class="absolute -top-10 -left-10 w-40 h-40 bg-waGreen-500/10 rounded-full blur-3xl pointer-events-none"></div>
            <div class="absolute -bottom-10 -right-10 w-40 h-40 bg-waGreen-600/10 rounded-full blur-3xl pointer-events-none"></div>

            <div class="flex items-center gap-4">
                <div class="w-14 h-14 bg-gradient-to-tr from-waGreen-600 to-waGreen-500 rounded-2xl flex items-center justify-center shadow-lg shadow-waGreen-500/30">
                    <i class="fa-brands fa-whatsapp text-3xl text-white animate-bounce-slow"></i>
                </div>
                <div>
                    <h1 class="text-2xl md:text-3xl font-extrabold tracking-tight bg-gradient-to-r from-white via-slate-100 to-waGreen-500 bg-clip-text text-transparent">
                        WhatsApp AI Agent
                    </h1>
                    <p class="text-slate-400 text-sm">
                        Curvy-card multi-tone message engine powered by Google Gemini
                    </p>
                </div>
            </div>

            <!-- Settings / Credentials Hub -->
            <div class="flex flex-wrap items-center gap-3 w-full md:w-auto">
                <div class="relative w-full sm:w-64">
                    <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-slate-500 text-xs">
                        <i class="fa-solid fa-key"></i>
                    </span>
                    <input type="password" id="geminiApiKey" 
                        class="w-full pl-9 pr-8 py-2.5 bg-slate-950/60 border border-slate-800 rounded-xl text-xs text-slate-300 focus:outline-none focus:border-waGreen-500 focus:ring-1 focus:ring-waGreen-500 transition-all placeholder-slate-600" 
                        placeholder="Paste Gemini API Key (Optional sandbox)">
                    <button onclick="toggleKeyVisibility()" class="absolute inset-y-0 right-0 flex items-center pr-3 text-slate-500 hover:text-slate-300">
                        <i id="eyeIcon" class="fa-solid fa-eye-slash text-xs"></i>
                    </button>
                </div>
                <button onclick="openCreateModal()" class="w-full sm:w-auto px-5 py-2.5 bg-gradient-to-r from-waGreen-600 to-waGreen-500 hover:from-waGreen-500 hover:to-waGreen-600 text-white rounded-xl text-sm font-semibold shadow-lg shadow-waGreen-500/20 hover:shadow-waGreen-500/45 transition-all flex items-center justify-center gap-2">
                    <i class="fa-solid fa-circle-plus"></i> New Agent Card
                </button>
            </div>
        </header>

        <!-- Main Agent Workspace Layout -->
        <main class="grid grid-cols-1 lg:grid-cols-4 gap-8">
            
            <!-- Left Side controls / Agent quick stats -->
            <section class="lg:col-span-1 flex flex-col gap-6">
                <!-- Status Box -->
                <div class="glass-panel p-6 rounded-3xl relative overflow-hidden animate-scale-in" style="animation-delay: 0.1s;">
                    <h3 class="text-lg font-bold mb-4 flex items-center gap-2 text-slate-200">
                        <i class="fa-solid fa-chart-bar text-waGreen-500"></i> Agent Monitor
                    </h3>
                    
                    <div class="space-y-4">
                        <div class="bg-slate-950/40 p-4 rounded-2xl border border-slate-800/60 flex justify-between items-center">
                            <div>
                                <p class="text-xs text-slate-400">Active Task Cards</p>
                                <p class="text-2xl font-black text-white mt-1" id="activeCardsCount">0</p>
                            </div>
                            <div class="p-3 bg-blue-500/10 rounded-xl text-blue-400">
                                <i class="fa-solid fa-file-invoice text-xl"></i>
                            </div>
                        </div>

                        <div class="bg-slate-950/40 p-4 rounded-2xl border border-slate-800/60 flex justify-between items-center">
                            <div>
                                <p class="text-xs text-slate-400">Drafts Elaborated</p>
                                <p class="text-2xl font-black text-waGreen-500 mt-1" id="elaboratedCount">0</p>
                            </div>
                            <div class="p-3 bg-waGreen-500/10 rounded-xl text-waGreen-500">
                                <i class="fa-solid fa-wand-magic-sparkles text-xl"></i>
                            </div>
                        </div>

                        <div class="bg-slate-950/40 p-4 rounded-2xl border border-slate-800/60 flex justify-between items-center">
                            <div>
                                <p class="text-xs text-slate-400">Sent to WhatsApp</p>
                                <p class="text-2xl font-black text-emerald-400 mt-1" id="sentCount">0</p>
                            </div>
                            <div class="p-3 bg-emerald-500/10 rounded-xl text-emerald-400">
                                <i class="fa-solid fa-paper-plane text-xl"></i>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Custom instructions / System Rule Card -->
                <div class="glass-panel p-6 rounded-3xl animate-scale-in" style="animation-delay: 0.2s;">
                    <h3 class="text-base font-bold mb-3 flex items-center gap-2 text-slate-200">
                        <i class="fa-solid fa-gears text-waGreen-500"></i> Base AI Persona
                    </h3>
                    <p class="text-xs text-slate-400 leading-relaxed mb-4">
                        Define how the Gemini AI structures the WhatsApp elaboration. This system prompt ensures the outputs sound authentic, conversational, and direct.
                    </p>
                    <textarea id="systemInstruction" 
                        class="w-full h-32 p-3 bg-slate-950/60 border border-slate-800 rounded-xl text-xs text-slate-300 focus:outline-none focus:border-waGreen-500 resize-none"
                        placeholder="System Persona...">You are an expert copywriter and communications assistant. Convert the rough messages into engaging, natural, and friendly WhatsApp messages. Use clear paragraphs, professional structuring, and dynamic emojis where appropriate.</textarea>
                </div>
            </section>

            <!-- Workspace: Dynamic Grid of Cards with Curvy Corners -->
            <section class="lg:col-span-3">
                <div class="flex items-center justify-between mb-6">
                    <h2 class="text-xl font-extrabold text-slate-100 tracking-wide flex items-center gap-2">
                        <i class="fa-solid fa-cubes text-waGreen-500"></i> Agent Warp Workspace
                    </h2>
                    <span class="text-xs bg-slate-800/60 px-3 py-1.5 rounded-full text-slate-400 border border-slate-700/50">
                        Move mouse over cards for 3D Transform effect
                    </span>
                </div>

                <!-- Cards Grid -->
                <div id="agentCardsGrid" class="grid grid-cols-1 md:grid-cols-2 gap-6 min-h-[400px]">
                    <!-- Empty State -->
                    <div id="emptyState" class="col-span-full flex flex-col items-center justify-center text-center p-12 glass-panel rounded-3xl border-dashed border-slate-800">
                        <div class="w-16 h-16 rounded-full bg-slate-900 flex items-center justify-center text-slate-600 text-2xl mb-4 border border-slate-800">
                            <i class="fa-solid fa-wand-magic-sparkles text-waGreen-500/40"></i>
                        </div>
                        <h4 class="text-lg font-bold text-slate-300">No active agent cards in workspace</h4>
                        <p class="text-sm text-slate-500 max-w-sm mt-2">
                            Add a card to state your message objective. AI will build a professional draft to broadcast straight to WhatsApp.
                        </p>
                        <button onclick="openCreateModal()" class="mt-5 px-6 py-2.5 bg-waGreen-500/10 text-waGreen-500 border border-waGreen-500/30 rounded-xl hover:bg-waGreen-500/20 text-sm font-semibold transition-all">
                            Create First Card
                        </button>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <!-- Modal: Create New Agent Card -->
    <div id="createCardModal" class="fixed inset-0 bg-slate-950/80 backdrop-blur-md hidden items-center justify-center z-50 p-4 transition-all duration-300">
        <div class="glass-panel w-full max-w-md rounded-[2rem] overflow-hidden border border-slate-800 shadow-2xl animate-scale-in relative">
            
            <div class="absolute -top-12 -right-12 w-32 h-32 bg-waGreen-500/10 rounded-full blur-2xl pointer-events-none"></div>

            <div class="p-6 border-b border-slate-800/80 flex justify-between items-center">
                <h3 class="text-lg font-bold text-slate-100 flex items-center gap-2">
                    <i class="fa-solid fa-address-card text-waGreen-500"></i> New WhatsApp Card
                </h3>
                <button onclick="closeCreateModal()" class="text-slate-400 hover:text-slate-200 transition-colors">
                    <i class="fa-solid fa-xmark text-lg"></i>
                </button>
            </div>

            <!-- Modal Forms -->
            <form id="newCardForm" onsubmit="handleCreateCard(event)" class="p-6 space-y-4">
                <div>
                    <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Contact Name</label>
                    <div class="relative">
                        <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-slate-500">
                            <i class="fa-solid fa-user text-xs"></i>
                        </span>
                        <input type="text" id="contactName" required
                            class="w-full pl-9 pr-4 py-3 bg-slate-950/70 border border-slate-800 rounded-xl text-sm text-slate-200 focus:outline-none focus:border-waGreen-500 focus:ring-1 focus:ring-waGreen-500 transition-all placeholder-slate-600"
                            placeholder="John Doe">
                    </div>
                </div>

                <div>
                    <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Phone Number (with Country Code)</label>
                    <div class="relative">
                        <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-slate-500 font-mono text-xs">
                            +
                        </span>
                        <input type="tel" id="contactPhone" required
                            class="w-full pl-9 pr-4 py-3 bg-slate-950/70 border border-slate-800 rounded-xl text-sm text-slate-200 focus:outline-none focus:border-waGreen-500 focus:ring-1 focus:ring-waGreen-500 transition-all placeholder-slate-600"
                            placeholder="15550199 (No spaces or '+' symbols)">
                    </div>
                </div>

                <div>
                    <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Message Intent / Rough Draft</label>
                    <textarea id="roughDraft" required rows="3"
                        class="w-full p-3 bg-slate-950/70 border border-slate-800 rounded-xl text-sm text-slate-200 focus:outline-none focus:border-waGreen-500 focus:ring-1 focus:ring-waGreen-500 transition-all placeholder-slate-600 resize-none"
                        placeholder="e.g. Ask John if we are still meeting at 3pm today, apologize for short notice."></textarea>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Message Tone</label>
                        <select id="messageTone" 
                            class="w-full p-3 bg-slate-950/70 border border-slate-800 rounded-xl text-xs text-slate-300 focus:outline-none focus:border-waGreen-500 focus:ring-1 focus:ring-waGreen-500 transition-all">
                            <option value="Professional">Professional 👔</option>
                            <option value="Friendly" selected>Friendly 🤗</option>
                            <option value="Urgent">Urgent 🚨</option>
                            <option value="Sarcastic">Sarcastic 🤪</option>
                            <option value="Persuasive">Persuasive 📈</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">TTS Voice</label>
                        <select id="ttsVoice"
                            class="w-full p-3 bg-slate-950/70 border border-slate-800 rounded-xl text-xs text-slate-300 focus:outline-none focus:border-waGreen-500 focus:ring-1 focus:ring-waGreen-500 transition-all">
                            <option value="Zephyr">Zephyr (Bright)</option>
                            <option value="Puck">Puck (Upbeat)</option>
                            <option value="Kore">Kore (Firm)</option>
                            <option value="Fenrir">Fenrir (Excitable)</option>
                            <option value="Sadachbia">Sadachbia (Lively)</option>
                        </select>
                    </div>
                </div>

                <div class="pt-4 flex gap-3">
                    <button type="button" onclick="closeCreateModal()" class="w-1/2 py-3 bg-slate-900 hover:bg-slate-850 border border-slate-800 rounded-xl text-sm font-semibold text-slate-400 hover:text-slate-200 transition-all">
                        Cancel
                    </button>
                    <button type="submit" class="w-1/2 py-3 bg-gradient-to-r from-waGreen-600 to-waGreen-500 hover:from-waGreen-500 hover:to-waGreen-600 text-white rounded-xl text-sm font-semibold shadow-lg shadow-waGreen-500/20 transition-all">
                        Create Card
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Custom Dialog Toast/Message Box -->
    <div id="toastNotification" class="fixed bottom-6 right-6 z-50 transform translate-y-20 opacity-0 transition-all duration-350 pointer-events-none">
        <div class="glass-panel px-6 py-4 rounded-2xl flex items-center gap-3 border border-slate-800/90 shadow-xl">
            <span id="toastIcon" class="w-8 h-8 rounded-full flex items-center justify-center text-white text-sm"></span>
            <div>
                <p id="toastTitle" class="text-sm font-bold text-slate-100"></p>
                <p id="toastDesc" class="text-xs text-slate-400"></p>
            </div>
        </div>
    </div>

    <!-- Audio container for Gemini TTS previews -->
    <audio id="ttsAudioPlayer" class="hidden"></audio>

    <script>
        // Local state management for agent cards
        let agentCards = [];
        let stateStats = {
            elaborated: 0,
            sent: 0
        };

        // Initialize App
        window.onload = function() {
            loadSavedData();
            renderGrid();
            updateStatsUI();
            
            // Start the tilt and dynamic interactive triggers
            initTiltWarpEffects();
        };

        function saveToLocalStorage() {
            localStorage.setItem('wa_agent_cards', JSON.stringify(agentCards));
            localStorage.setItem('wa_agent_stats', JSON.stringify(stateStats));
        }

        function loadSavedData() {
            const savedCards = localStorage.getItem('wa_agent_cards');
            const savedStats = localStorage.getItem('wa_agent_stats');
            
            if (savedCards) {
                try {
                    agentCards = JSON.parse(savedCards);
                } catch(e) {
                    agentCards = [];
                }
            }
            if (savedStats) {
                try {
                    stateStats = JSON.parse(savedStats);
                } catch(e) {
                    stateStats = { elaborated: 0, sent: 0 };
                }
            }
        }

        function updateStatsUI() {
            document.getElementById('activeCardsCount').innerText = agentCards.length;
            document.getElementById('elaboratedCount').innerText = stateStats.elaborated;
            document.getElementById('sentCount').innerText = stateStats.sent;
        }

        // Key visibility handler
        function toggleKeyVisibility() {
            const input = document.getElementById('geminiApiKey');
            const icon = document.getElementById('eyeIcon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.className = 'fa-solid fa-eye text-xs';
            } else {
                input.type = 'password';
                icon.className = 'fa-solid fa-eye-slash text-xs';
            }
        }

        // Modal triggers
        function openCreateModal() {
            document.getElementById('createCardModal').classList.remove('hidden');
            document.getElementById('createCardModal').classList.add('flex');
        }

        function closeCreateModal() {
            document.getElementById('createCardModal').classList.add('hidden');
            document.getElementById('createCardModal').classList.remove('flex');
            document.getElementById('newCardForm').reset();
        }

        function handleCreateCard(event) {
            event.preventDefault();
            
            const contactName = document.getElementById('contactName').value;
            let contactPhone = document.getElementById('contactPhone').value;
            const roughDraft = document.getElementById('roughDraft').value;
            const messageTone = document.getElementById('messageTone').value;
            const ttsVoice = document.getElementById('ttsVoice').value;

            // Strip prefix +, spaces, and brackets
            contactPhone = contactPhone.replace(/[\s\+\(\)\-]/g, "");

            const newCard = {
                id: 'card_' + Date.now(),
                name: contactName,
                phone: contactPhone,
                roughDraft: roughDraft,
                tone: messageTone,
                voice: ttsVoice,
                elaboratedText: "",
                status: "Draft", // Draft, Refining, Ready
                created: new Date().toLocaleDateString()
            };

            agentCards.push(newCard);
            saveToLocalStorage();
            renderGrid();
            updateStatsUI();
            closeCreateModal();
            showToast("Success", "Agent Card loaded into active workspace", "bg-waGreen-500", "fa-solid fa-check");
        }

        function deleteCard(id) {
            agentCards = agentCards.filter(c => c.id !== id);
            saveToLocalStorage();
            renderGrid();
            updateStatsUI();
            showToast("Card Removed", "Agent Card cleared from workspace", "bg-red-500", "fa-solid fa-trash");
        }

        // Main function to run the Gemini Text Elaboration API
        async function elaborateMessage(id) {
            const card = agentCards.find(c => c.id === id);
            if (!card) return;

            // Update UI State on card to "Refining"
            card.status = "Refining";
            renderGrid();

            const customKey = document.getElementById('geminiApiKey').value;
            const systemInstruction = document.getElementById('systemInstruction').value;
            
            // Build Prompt
            const prompt = `Convert this rough WhatsApp message into an elaborate, refined, and professional WhatsApp message.
Tone required: ${card.tone}
Recipient Name: ${card.name}
Rough draft input: "${card.roughDraft}"

Guidelines:
- Make it sound natural for WhatsApp (short paragraphs, appropriate conversational tags).
- Include appropriate formatting like bullet points, bold markers where needed (*bold*), and some emojis matching the tone.
- Do NOT include subject lines, headers, or signature templates -- output ONLY the pure chat message body ready to copy.`;

            // Prepare Gemini Request
            const payload = {
                contents: [{ parts: [{ text: prompt }] }],
                systemInstruction: {
                    parts: [{ text: systemInstruction }]
                }
            };

            const apiUrl = `https://generativelanguage.googleapis.com/v1beta/models/gemini-3-flash-preview:generateContent?key=${customKey}`;

            let success = false;
            let errorMsg = "Unknown error occurred";
            
            try {
                // Implement Fetch with Exponential Backoff
                let delay = 1000;
                let response;
                
                for (let attempt = 0; attempt < 3; attempt++) {
                    response = await fetch(apiUrl, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });
                    
                    if (response.status === 429) {
                        // Backoff delay
                        await new Promise(resolve => setTimeout(resolve, delay));
                        delay *= 2;
                    } else {
                        break;
                    }
                }

                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }

                const result = await response.json();
                const textOutput = result.candidates?.[0]?.content?.parts?.[0]?.text;

                if (textOutput) {
                    card.elaboratedText = textOutput.trim();
                    card.status = "Ready";
                    stateStats.elaborated++;
                    success = true;
                } else {
                    errorMsg = "Empty response structure from Gemini API.";
                }

            } catch (err) {
                console.error("Gemini API Error: ", err);
                errorMsg = err.message;
            }

            if (!success) {
                card.status = "Draft";
                showToast("AI Elaboration Failed", errorMsg, "bg-amber-600", "fa-solid fa-circle-exclamation");
            } else {
                showToast("AI Elaboration Success", "Draft message elaborated in tone: " + card.tone, "bg-waGreen-500", "fa-solid fa-wand-magic-sparkles");
            }

            saveToLocalStorage();
            renderGrid();
            updateStatsUI();
        }

        // Convert elaborated message to WAV via raw signed PCM16 TTS
        async function playTTS(id) {
            const card = agentCards.find(c => c.id === id);
            if (!card || !card.elaboratedText) {
                showToast("No Text Ready", "Elaborate the text first with the AI model.", "bg-amber-500", "fa-solid fa-volume-xmark");
                return;
            }

            // Update UI button state temporarily
            const ttsBtn = document.getElementById(`tts-btn-${id}`);
            const originalHtml = ttsBtn.innerHTML;
            ttsBtn.innerHTML = `<i class="fa-solid fa-spinner animate-spin"></i> Loading Audio...`;
            ttsBtn.disabled = true;

            const apiKey = document.getElementById('geminiApiKey').value;
            const textToSpeak = `Say in an engaging tone matching ${card.tone}: ${card.elaboratedText}`;

            const payload = {
                contents: [{
                    parts: [{ text: textToSpeak }]
                }],
                generationConfig: {
                    responseModalities: ["AUDIO"],
                    speechConfig: {
                        voiceConfig: {
                            prebuiltVoiceConfig: { voiceName: card.voice || "Zephyr" }
                        }
                    }
                },
                model: "gemini-2.5-flash-preview-tts"
            };

            const apiUrl = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-tts:generateContent?key=${apiKey}`;

            try {
                const response = await fetch(apiUrl, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                if (!response.ok) {
                    throw new Error(`TTS API failed with status ${response.status}`);
                }

                const result = await response.json();
                const part = result?.candidates?.[0]?.content?.parts?.[0];
                const audioData = part?.inlineData?.data;
                const mimeType = part?.inlineData?.mimeType;

                if (audioData && mimeType && mimeType.startsWith("audio/")) {
                    // Extract Sample rate from mimeType if available (e.g. rate=24000)
                    let sampleRate = 24000;
                    const rateMatch = mimeType.match(/rate=(\d+)/);
                    if (rateMatch) {
                        sampleRate = parseInt(rateMatch[1], 10);
                    }

                    const pcmData = base64ToArrayBuffer(audioData);
                    const pcm16 = new Int16Array(pcmData);
                    const wavBlob = pcmToWav(pcm16, sampleRate);
                    const audioUrl = URL.createObjectURL(wavBlob);

                    const player = document.getElementById('ttsAudioPlayer');
                    player.src = audioUrl;
                    player.play();

                    showToast("Synthesized Voice", `Previewing with voice: ${card.voice || 'Zephyr'}`, "bg-blue-500", "fa-solid fa-circle-play");
                } else {
                    throw new Error("No inline audio payload received.");
                }

            } catch (err) {
                console.error("TTS Synthesis Error: ", err);
                showToast("TTS Error", err.message, "bg-red-500", "fa-solid fa-volume-xmark");
            } finally {
                ttsBtn.innerHTML = originalHtml;
                ttsBtn.disabled = false;
            }
        }

        // Base64 helper for speech data
        function base64ToArrayBuffer(base64) {
            const binaryString = window.atob(base64);
            const len = binaryString.length;
            const bytes = new Uint8Array(len);
            for (let i = 0; i < len; i++) {
                bytes[i] = binaryString.charCodeAt(i);
            }
            return bytes.buffer;
        }

        // WAV Header Generation helper for Audio/L16 PCM raw formats
        function pcmToWav(pcm16, sampleRate) {
            const buffer = new ArrayBuffer(44 + pcm16.length * 2);
            const view = new DataView(buffer);

            // "RIFF"
            view.setUint32(0, 0x52494646, false);
            // File size minus chunk ID & size fields (36 + data size)
            view.setUint32(4, 36 + pcm16.length * 2, true);
            // "WAVE"
            view.setUint32(8, 0x57415645, false);
            // "fmt "
            view.setUint32(12, 0x666d7420, false);
            // Subchunk size (16 for PCM)
            view.setUint32(16, 16, true);
            // Audio format (1 = PCM)
            view.setUint16(20, 1, true);
            // Number of channels (1 = Mono)
            view.setUint16(22, 1, true);
            // Sample rate
            view.setUint32(24, sampleRate, true);
            // Byte rate (SampleRate * NumChannels * BitsPerSample/8)
            view.setUint32(28, sampleRate * 2, true);
            // Block align (NumChannels * BitsPerSample/8)
            view.setUint16(32, 2, true);
            // Bits per sample
            view.setUint16(34, 16, true);
            // "data"
            view.setUint32(36, 0x64617461, false);
            // Subchunk2 size
            view.setUint32(40, pcm16.length * 2, true);

            // Write PCM audio data
            for (let i = 0; i < pcm16.length; i++) {
                view.setInt16(44 + i * 2, pcm16[i], true);
            }

            return new Blob([buffer], { type: 'audio/wav' });
        }

        // Direct Send logic to trigger native WhatsApp redirection
        function sendToWhatsApp(id) {
            const card = agentCards.find(c => c.id === id);
            if (!card) return;

            const finalMessage = card.elaboratedText || card.roughDraft;
            const waUrl = `https://api.whatsapp.com/send?phone=${card.phone}&text=${encodeURIComponent(finalMessage)}`;
            
            // Increment Stats
            stateStats.sent++;
            saveToLocalStorage();
            updateStatsUI();

            showToast("Opening WhatsApp", `Redirecting to chat with ${card.name}...`, "bg-emerald-600", "fa-solid fa-paper-plane");
            
            setTimeout(() => {
                window.open(waUrl, '_blank');
            }, 800);
        }

        // Helper to copy final text safely
        function copyTextToClipboard(id) {
            const card = agentCards.find(c => c.id === id);
            if (!card || !card.elaboratedText) return;

            const textToCopy = card.elaboratedText;
            const tempInput = document.createElement("textarea");
            tempInput.value = textToCopy;
            document.body.appendChild(tempInput);
            tempInput.select();
            document.execCommand("copy");
            document.body.removeChild(tempInput);

            showToast("Copied!", "Message copied to clipboard.", "bg-blue-600", "fa-solid fa-copy");
        }

