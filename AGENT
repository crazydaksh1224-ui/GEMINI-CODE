<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        body { font-family: -apple-system, sans-serif; background: #0f172a; color: #f8fafc; padding: 15px; margin: 0; display: flex; justify-content: center; }
        .widget-card { background: #1e293b; padding: 20px; border-radius: 12px; width: 100%; max-width: 400px; box-shadow: 0 4px 10px rgba(0,0,0,0.3); }
        h3 { margin-top: 0; color: #10b981; font-size: 18px; text-align: center; }
        .formula { background: #334155; padding: 8px; border-radius: 6px; font-family: monospace; font-size: 12px; text-align: center; margin: 10px 0; color: #cbd5e1; }
        label { display: block; margin-top: 12px; font-size: 13px; color: #94a3b8; }
        .row { display: flex; align-items: center; justify-content: space-between; gap: 10px; }
        input[type="range"] { flex-grow: 1; accent-color: #10b981; }
        .val { font-weight: bold; color: #10b981; min-width: 70px; text-align: right; }
        .badge { text-align: center; font-weight: bold; padding: 10px; border-radius: 6px; margin-top: 15px; font-size: 14px; text-transform: uppercase; letter-spacing: 1px;}
        .pass { background: #065f46; color: #34d399; border: 1px solid #059669; }
        .fail { background: #991b1b; color: #fca5a5; border: 1px solid #dc2626; }
        .scenario-btn { background: #334155; border: none; color: #e2e8f0; padding: 5px 10px; border-radius: 4px; font-size: 11px; cursor: pointer; }
        .scenario-btn:hover { background: #475569; }
    </style>
</head>
<body>
    <div class="widget-card">
        <h3>⚖️ The Asymmetry Ratio System</h3>
        <div class="formula">Asymmetry = Potential Upside / Capped Downside</div>
        
        <div style="display:flex; gap:5px; justify-content:center; margin-bottom:10px;">
            <button class="scenario-btn" onclick="loadScenario(50000, 50000)">⚠️ Volatile Bakery Idea</button>
            <button class="scenario-btn" onclick="loadScenario(100000, 2000)">🚀 Capped Franchise Recipe</button>
        </div>

        <label>Potential Upside (Max Gain $):</label>
        <div class="row">
            <input type="range" id="upside" min="1000" max="150000" value="50000" step="1000" oninput="evalAsymmetry()">
            <span class="val" id="upVal">$50,000</span>
        </div>

        <label>Potential Downside (Capped Loss $):</label>
        <div class="row">
            <input type="range" id="downside" min="500" max="100000" value="50000" step="500" oninput="evalAsymmetry()">
            <span class="val" id="downVal">$50,000</span>
        </div>

        <div class="badge id="statusBadge"">Ratio: 1.00 - REJECTED</div>
    </div>

    <script>
        function evalAsymmetry() {
            let up = parseFloat(document.getElementById('upside').value);
            let down = parseFloat(document.getElementById('downside').value);
            
            document.getElementById('upVal').innerText = '$' + up.toLocaleString();
            document.getElementById('downVal').innerText = '$' + down.toLocaleString();
            
            let ratio = up / down;
            let badge = document.getElementById('statusBadge');
            
            if (ratio > 1) {
                badge.className = "badge pass";
                badge.innerHTML = `Ratio: ${ratio.toFixed(2)}<br>🟢 Optimal Asymmetry (Accept Allocation)`;
            } else {
                badge.className = "badge fail";
                badge.innerHTML = `Ratio: ${ratio.toFixed(2)}<br>🔴 Unacceptable Risk (Reject Allocation)`;
            }
        }
        function loadScenario(u, d) {
            document.getElementById('upside').value = u;
            document.getElementById('downside').value = d;
            evalAsymmetry();
        }
        evalAsymmetry();
    </script>
</body>
</html>
