        // Advanced Math for 3D coordinate-based rotation transform (Hover Warp)
        function applyTiltEffect(card) {
            card.addEventListener('mousemove', (e) => {
                const rect = card.getBoundingClientRect();
                const x = e.clientX - rect.left; // x position inside element
                const y = e.clientY - rect.top;  // y position inside element
                
                const width = rect.width;
                const height = rect.height;
                
                const midX = width / 2;
                const midY = height / 2;
                
                // Max degrees tilt
                const maxTilt = 10;
                
                // Relative coordinate (-1 to 1)
                const relativeX = (x - midX) / midX; 
                const relativeY = (midY - y) / midY; // Inverse for correct up/down pitch
                
                const rotateX = relativeY * maxTilt;
                const rotateY = relativeX * maxTilt;
                
                // Apply perspective & rotating transform
                card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.025, 1.025, 1.025)`;
                
                // Add elegant dynamic reflection coordinate style
                const glowLeft = (x / width) * 100;
                const glowTop = (y / height) * 100;
                card.style.backgroundImage = `radial-gradient(circle at ${glowLeft}% ${glowTop}%, rgba(7, 217, 116, 0.08) 0%, transparent 70%)`;
            });

            card.addEventListener('mouseleave', () => {
                // Return to neutral state
                card.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1)';
                card.style.backgroundImage = 'none';
            });
        }

        // Initialize overall interactive effects
        function initTiltWarpEffects() {
            const cards = document.querySelectorAll('.warp-card');
            cards.forEach(card => applyTiltEffect(card));
        }

        // Custom Toast UI message trigger (replaces native alerts)
        function showToast(title, desc, iconBg, iconClass) {
            const toast = document.getElementById('toastNotification');
            const toastIcon = document.getElementById('toastIcon');
            const toastTitle = document.getElementById('toastTitle');
            const toastDesc = document.getElementById('toastDesc');

            toastIcon.className = `w-10 h-10 rounded-xl flex items-center justify-center text-white text-base ${iconBg} shadow-lg`;
            toastIcon.innerHTML = `<i class="${iconClass}"></i>`;
            toastTitle.innerText = title;
            toastDesc.innerText = desc;

            // Animate In
            toast.classList.remove('translate-y-20', 'opacity-0');
            toast.classList.add('translate-y-0', 'opacity-100');

            setTimeout(() => {
                // Animate Out
                toast.classList.add('translate-y-20', 'opacity-0');
                toast.classList.remove('translate-y-0', 'opacity-100');
            }, 3500);
        }
    </script>
